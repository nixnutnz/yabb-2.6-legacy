$subfooterbar = qq~<div class="titlebg right">
                    <span class="small">{yabb admin selector}</span>{yabb admin selectorb}<span class="small">{yabb admin selectorc} <label for="checkall">{yabb messageindex_txt_737}</label></span>
                    <span class="titlebg center" style="white-space: nowrap">{yabb admin checkboxes}</span>
                </div>~;

