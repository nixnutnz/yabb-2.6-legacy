# Thread bar                               #

$threadbar = qq~                <div class="{yabb altthdcolor} padd_4px"><div style="float: left;">{yabb threadpic} {yabb icon}{yabb favorite} {yabb new}
                    <br />{yabb poll}{yabb subjectlink}
                    <br /><span class="small">$messageindex_txt{'527'} {yabb starttime} $messageindex_txt{'526'} {yabb starter}{yabb pages}<br />{yabb permalink}</span>
                </div>
