$msg_attach_win = qq~<a href="javascript:void(window.open('$scripturl?action=viewdownloads;thread={yabb mnum}','_blank','width=818,height=650,scrollbars=yes,resizable=yes,menubar=no,toolbar=no,top=150,left=150'))">~;

# Board Notification                     #

$brd_notify = qq~
    <form action="$scripturl?action=boardnotify3;board={yabb currentboard}" method="post">
    <div style="width: 30em; margin: 0 auto">
        <div class="tabtitle" style="padding-left: 10px;">
            <img src="$imagesdir/$brd_notify_img" alt="$notify_txt{'136'} - {yabb boardname}" title="$notify_txt{'136'} - {yabb boardname}" /> <strong>$notify_txt{'136'} - {yabb boardname}</strong>
        </div>
        <div class="windowbg" style="padding:1em 4px; text-align:center;">
            {yabb my_delopt}
            <select name="{yabb currentboard}">
                <option value="1"{yabb selected1}>$notify_txt{'132'}</option>
                <option value="2"{yabb selected2}>$notify_txt{'133'}</option>
                {yabb deloption}
            </select>
        </div>
        <div class="catbg" style="text-align:center"><input type="submit" value="$notify_txt{'124'}" class="button" /></div>
    </div>
    </form>~;

