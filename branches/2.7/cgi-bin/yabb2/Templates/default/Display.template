</head>
<body>
     <div id="maincontainer">
<script type="text/javascript">
function NoPost(op) {
    if (document.getElementById("newboard").options[op].className == "nopost") {
        alert("{yabb sstxt_27}");
        document.getElementById("newboard").selectedIndex = 0;
    }
}
</script>
<form action="$scripturl?action=split_splice;board={yabb currentboard};thread={yabb INFO_thread}" method="post" name="split_splice" onsubmit="return submitproc()" accept-charset="$yymycharset">
            <input type="hidden" name="formsession" value="{yabb formsession}" />
            <div style="width:90%; margin:0 auto">
                <div class="tabtitle" style="line-height:3em; vertical-align:bottom; padding-left:.5em"><img src="$imagesdir/$admin_move" alt="{yabb sstxt_1}" /> <b>{yabb sstxt_1}</b></div>
                <div class="catbg padd_8px"><b>{yabb sstxt_2}:</b></div>
                <div class="windowbg padd_8px"><b>{yabb sstxt_3}</b></div>
                <div class="windowbg2 padd_8px">
                        <label for="oldposts">{yabb sstxt_14}<br />
                    <select name="oldposts" id="oldposts" size="{yabb size1}" multiple="multiple">{yabb postlist}</select>
                    <br /><span class="small">{yabb sstxt_14a}</span></label>
                </div>
                <div class="windowbg padd_8px"><b>{yabb sstxt_4}</b></div>
                <div class="windowbg2 padd_8px">
                        <label for="leave">{yabb sstxt_15}</label><br />
                        <select name="leave" id="leave">{yabb leavelist}</select>
                </div>
                <div class="catbg padd_8px"><b>{yabb sstxt_5}:</b></div>
