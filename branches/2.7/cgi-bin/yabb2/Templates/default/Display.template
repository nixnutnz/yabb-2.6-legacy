$mymove_top = qq~<!DOCTYPE html>
<html lang="$abbr_lang">
<head>
    <title>{yabb sstxt_1}</title>
    <meta charset="$yymycharset">
    <link rel="stylesheet" href="$yyhtml_root/Templates/Forum/$usestyle.css" type="text/css" />
