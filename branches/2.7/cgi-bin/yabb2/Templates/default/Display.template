$threadhandellist = qq~
      {yabb notify}{yabb favorite}{yabb sendtopic}{yabb print}{yabb markunread}
~;
$threadhandellist2 = qq~
    {yabb notify2}{yabb favorite2}{yabb sendtopic}{yabb print}{yabb markunread}
~;

