$newload = qq~
        <script type="text/javascript">
        var new_mess = "$newload{'new_mess'}";
        var brd_new = "$newload{'brd_new'}";
        var brd_old = "$newload{'brd_old'}";
        var sub_brd_new = "$newload{'sub_brd_new'}";
        var sub_brd_old = "$newload{'sub_brd_old'}";
        var brd_col = "$newload{'brd_col'}";
        var brd_exp = "$newload{'brd_exp'}";
        var imopen = "$newload{'imopen'}";
        var imopen2 = "$newload{'imopen2'}";
        var imclose = "$newload{'imclose'}";
        var imclose2 = "$newload{'imclose2'}";
        </script>~;

#####################################################################
#                   JS Variables for im_post, post                  #
#####################################################################
@jspostlist = qw( xx exclamation thumbup thumbdown question lamp smiley angry cheesy grin sad wink );
$js_postlist = q{};
for (@jspostlist) {
        $js_postlist .= qq~'$_', '$micon_bg{$_}',\n~;
}
$js_postlist =~ s/\,\n\Z//xsm;
$js_post = qq~
var jsPost = new Hash($js_postlist);
~;

@jspstatlist = qw( thread hide locked sticky announcement stickylock hidesticky hidelock hidestickylock announcementlock veryhotthread hotthread);
for (@jspstatlist) {
        $js_pstatlist .= qq~'$_', '$micon_bg{$_}',\n~;
}
$js_pstatlist =~ s/\,\n\Z//xsm;
$js_pstat = qq~
var jsPstat = new Hash($js_pstatlist);
~;

@js_imlist = qw( standard confidential urgent );
$js_imlist = q{};
for (@js_imlist) {
        $js_imlist .= qq~'$_', '$micon_bg{$_}',\n~;
}
$js_imlist =~ s/\,\n\Z//xsm;
$js_im = qq~
var jsIM = new Hash($js_imlist);
~;

$my_sep = q{ };
if ( $use_menu_type && $use_menu_type == 1 ) {
    $my_sep = q{ | };
}
1;
