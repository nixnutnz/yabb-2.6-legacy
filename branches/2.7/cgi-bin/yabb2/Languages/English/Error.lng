no warnings;
$englisherrorlngver = 'YaBB 2.7.00 $Revision$';
@englisherrorlngmods = ();
if (@englisherrorlngmods) {
    $englisherrorlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%error_txt = (
## General Errors ##
'error_occurred'       => q~An Error Has Occurred.~,
'untrapped'            => q~Untrapped Error~,
'cannot_open'          => q~Unable to open~,
