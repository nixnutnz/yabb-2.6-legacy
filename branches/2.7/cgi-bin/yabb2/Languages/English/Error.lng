'no_password'          => q~Password field is empty~,
'no_action'            => q~No action specified.~,
'no_info'              => q~No info specified in url~,
'password_mismatch'    => q~Passwords are not the same.~,
'bad_credentials'      => q~User ID  / Password mismatch. <br />The User ID you specified does not exist or you entered a wrong password.~,
'invalid_character'    => q~There is an invalid character detected in the~,
'invalid_email'        => q~Please enter a valid e-mail address.~,
'invalid_picture'      => q~Invalid Board Picture Input.~,
'no_secret_answer'     => q~You need to fill out an answer to the question asked~,
'no_verification_code' => q~The Verification code was not filled out. It is required.~,
'wrong_verification_code'    => q~The Verification code was not the same as the image presented on screen, please go back, refresh (hit F5 on most browsers) and try again.~,
'invalid_verification_code'  => q~Verification code contains invalid characters. Only a-z and 0-9 are valid~,
'form_spoofing'        => q~<strong>ALERT</strong> Form Spoofing Detected coming from IP address:~,
'post_flooding'        => q~The last POST request from your IP was less than~,
'denial_of_service'    => q~The last POST request created an error message: ~,
'speed_alert'          => q~Posting this fast is considered spamming.<br />You are only allowed <strong>{yabb spam_hits_left_count}</strong> more attempt(s) after which you will be banned as spammer.~,
'tsc_alert'            => q~One of the form fields contains text which is considered spam.<br />You are only allowed <strong>{yabb spam_hits_left_count}</strong> more attempt(s) after which you will be banned as a spammer.~,
'speedpostban'         => q~You are currently banned from posting due to possible spamming.<br />After <strong>{yabb detention_left}</strong> second(s) your ban will automatically be lifted.~,
'truncation_error'     => q~Please make sure you have 'fake truncation' turned on in your Settings.pm file.<br />\$faketruncation = 1;<br />Could not truncate file~,
'referer_violation'    => q~This action is not allowed from an outside domain. <br />Action is: ~,
'egg'                  => q~Self Destruct Sequence Started!<br />~,
'domain_not_allowed'   => q~You may not register with, post as a guest or change your e-mail address to one from the domain~,
'module_missing'       => q~Module(s) or functionality needed not installed on this server.~,
'low_diskspace'        => q~The available disk/hostspace is low. The forum was put to maintenance to avoid file corruption. Please notify the administrator of this error.~,
'invalid_key'          => q~Masterkey is invalid.<br />This should be a text string between 8 and 24 characters long.~,
'wrong_pass'            => q~The password you entered is not correct~,
'corrupt_member_file'  => q~The member data file is corrupt. Please notify the administrator of this error.~,
'no_admin_passwrd'    => q~You need to fill in the correct administrator password to enter the Admin Center.~,
'default_password'    => qq~You are still using the YaBB Setup default password. Please login to your <a href="$scripturl?action=myprofile;username=$username;sid=$mysid">User profile</a> and change your password to something more secure.~,
