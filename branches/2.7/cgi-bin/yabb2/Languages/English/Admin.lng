%floodtxt = (
'1' => q~YaBB Security Center:~,
'2' => q~Activate validation code (CAPTCHA) on registration and forgot password?~,
'3' => q~Activate validation code (CAPTCHA) for Guest posting, Guest contact Admin by Broadcast Message, Guest sending Alert Moderator message, Guest sending a topic, Guest adding event to Calendar, or member sending PM without the minimum number of posts?~,
'5' => q~Maximum number of messages returned for Recent Posts on forum and/or by user?<br /> <span class="small">-1 will disable Recent Posts</span>~,
'5a' => q~Maximum number of messages returned for Recent Topics on forum?<br /> <span class="small">-1 will disable Recent Topics</span>~,
'6' => q~Maximum number of messages returned for a search?<br /> <span class="small">-1 will disable Search</span>~,
'7' => q~Validation Code Max. Length (max 15)~,
'9' => q~Validation Image Background Transparent?~,
'f' => q~Validation Image Foreground color (RGB hex value)~,
's' => q~Validation Image Shade color (RGB hex value)~,
'b' => q~Validation Image Background color (RGB hex value)~,
'rnd' => q~Select if and how you want to add random noise to your validation image background~,
'style' => q~Select what characters are generated in the CAPTCHA<br /><span class="small">Keep in mind that both upper and lowercase may make the CAPTCHA more difficult to read</span>~,
'lower' => q~Lower case characters + Digits~,
'upper' => q~Upper case characters + Digits~,
'all' => q~Upper and lower case characters + Digits~,
'masterkey' => q~Set a masterkey for encryption<br /><span class="small">A random text string (&gt; 8 and &lt; 24 characters long)</span>~,
'rm0' => q~No Random Noise~,
'rm1' => q~Using only the shade color~,
'rm2' => q~Using only the foreground color~,
'rm3' => q~Using both the shade and foreground color~,
'dis' => q~CAPTCHA background to shade color randomizer level<br /><span class="small">Could make CAPTCHA very hard to read in certain color combinations.</span>~,
'vpreview' => q~Preview your validation code<br /><span class="small">Check this after clicking 'Save' to apply the new settings</span>~,
'extra_chars_start' => q~Number of extra characters to add to the start of the validation code:~,
'extra_chars_end' => q~Number of extra characters to add to the end of the validation code:~,
'extra_chars_desc' => q~This will add random characters which do not need to be entered by the user and will fool spambots.<br />e.g. XX<br /><span class="small">0 disables</span>~,
'casewarning' => q~Please type the characters that appear in the image. The characters must be typed in the same order, and they are case-sensitive.~,
'casewarning_1' => q~Please type the characters exactly as they appear in the image,~,
'casewarning_2' => q~<br /><span style="font-weight: bold;">without the first~,
'casewarning_3' => q~<br /><span style="font-weight: bold;">without the last~,
'casewarning_4' => q~and last~,
'casewarning_5' => q~characters.</span><br />The characters must be typed in the same order,<br />and they are case-sensitive.~,
);

