$englishmovesplitsplicelngver = 'YaBB 2.7.00 $Revision$';
@englishmovesplitsplicelngmods = ();
if(@englishmovesplitsplicelngmods){
    $englishmovesplitsplicelngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%sstxt=(
'1' => q‾Move, Split &amp; Splice‾,
'2' => q‾Split Posts‾,
'3' => q‾Posts‾,
'4' => q‾Leave‾,
'5' => q‾Splice To‾,
'6' => q‾Category‾,
'7' => q‾Board‾,
