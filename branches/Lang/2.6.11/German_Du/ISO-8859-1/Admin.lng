'506' => 'Themen-Index neuaufbauen',
'507' => 'Themen-Index wurde neu aufgebaut.',
'509' => qq~Die neuesten Beiträge oder Themen im Forenindex anzeigen?<br />(Um die Anzahl einzustellen, gehe zu <a href="$boardurl/AdminIndex.$yyaext?action=newsettings;page=advanced">Erweiterte Einstellungen - Erweitert</a>)~,
'509a' => 'Zeige weder',
'509b' => 'Zeige Beiträge',
'509c' => 'Zeige Themen',
'509d' => 'Zeige Themen und Beiträge',
'521' => qq~Menüstil auswählen:<br /><span class="small"><b>Note</b>: Menüstyles für jedes Template können eingestellt werden in der <a href="$boardurl/AdminIndex.$yyaext?action=modskin">Template Konfiguration</a></span>~,
'521a' => 'Icon + Text',
'521b' => 'Nur Text',
'521c' => 'Nur Buttons',
'522' => 'Aktuelle Position im Forum als Link anzeigen?',
'523' => 'Profilbutton unter Beiträgen anzeigen?',
'524' => 'URLs automatisch verlinken?',
'525' => 'Auf GROSSBUCHSTABEN prüfen?<br /><span class="small">Wenn 0, wird nichts überprüft. Bei einem anderen Wert ist die hier eingetragene Zahl die Anzahl von aufeinanderfolgenden Großbuchstaben, die einen JavaScript Hinweis beim abschicken der Nachricht öffnen in dem steht, daß so viele aufeinanderfolgende Großbuchstaben nicht erlaubt sind.</span>',
'526' => 'Benutzertools in den Links (QuickLinks) der Benutzernamen anzeigen?',
'527' => qq~Aktiviere Beitragstools?<br /><span class="small">Wenn diese Option aktiviert wird, werden Beiträge in einem Drop-Down Menü anstelle von Buttons angezeigt.<br /><b>Note</b>: Beitrags-Werkzeuge können für jedes Template aktiviert werden in der <a href="$boardurl/AdminIndex.$yyaext?action=modskin">Template Konfiguration</a></span>~,
'528' => qq~Aktiviere Thementools?'<br /><span class="small">Wenn diese Option aktiviert wird, werden Themen in einem Drop-Down Menü anstelle von Buttons angezeigt.<br /><b>Note</b>: Themen-Werkzeuge können für jedes Template aktiviert werden in der <a href="$boardurl/AdminIndex.$yyaext?action=modskin">Template Konfiguration</a></span>~,,
'529' => 'Benutzer-Info-Stil:<br /><span class="small">Wenn diese Option aktiviert ist, werden Benutzerinfos links vom Beitrag wie in den vorherigen Versionen angezeigt. Wenn diese Option deaktiviert ist, werden die Beutzerinfos über jeden Beitrag im neuen Format angezeigt.</span>',
'530' => 'Der Neuaufbau des Themen-Index kann bei Foren mit sehr vielen Themen einige Zeit in Anspruch nehmen.<br />Bist Du sicher, dass Du einen Neuaufbau jetzt durchführen willst?<br />',
'531' => 'Klicke hier, um den Prozess zu starten.',
'532' => 'Die Ausführung des Prozesses erfolgt in einzelnen Zeitschritten zu je',
'533' => 'Sekunden',
'534' => 'Der Neuaufbau des Themen-Index kann bei Foren mit sehr vielen Themen einige Zeit in Anspruch nehmen.<br />Die einzelnen Zeitschritte ($max_process_time) sind gesetzt auf',
'535' => 'Der letzte Schritt dauerte',
'536' => 'Der Themen-Index wurde neu aufgebaut in:',
'537' => 'Minuten',
'538' => 'Verlorene oder leere Themen wurden gelöscht',
'539' => 'Themen und Prozesse wurden geladen.',
'540' => 'Foren wurden neu geschrieben.',
'540a' => 'Entfernen toter Dateien.',
'541' => 'Zählen der Themen in jedem Forum und abschließen des Vorganges.',
'542' => 'Wenn Du innerhalb von 5 Sekunden keine Aktivität feststellst,',
'543' => ' klicke hier um fortzufahren.',
'544' => q~Wenn Du den Themen-Index-Neuaufbau stoppen möchtest, <a href="javascript:stoptick();">klicke hier</a>.<br />Kopiere die aktuelle Browser-Adresse und trage sie anschließend ein, wenn Du fortfährst.<br />Beachte, dass der Wartungsmodus auf 'aktiv' gesetzt ist. Wenn Du ihn 'deaktivierst' geht alles das, was der Neuaufbau-Prozess bisher durchgeführt hat, verloren.~,
'545' => 'Neuaufbau des Themen-Index - bitte warten.<br />Wenn Du den Vorgang stoppen möchtest, klicke auf STOP, bevor die rot eingefärbte Nachricht auf der nächsten Seite erscheint.',
'579' => 'Tage',
'584' => 'Nutzungsbedingungen bei Registrierung bestätigen lassen?',
'584a' => 'Nicht mehr anzeigen',
'584b' => 'Anzeigen vor der Registrierung',
'584c' => 'Anzeigen bei der Registrierung',
'585' => 'Benutzer-Registrierung deaktivieren (Nur der Administrator kann neue Benutzer registrieren)?',
'586' => 'Benutzer erlauben, ihren Account zu löschen?<br /><span class="small">Wenn aktiviert, wird ein Button dem Benutzerprofil hinzugefügt, um sich selbst aus dem Forum zu entfernen</span>',
'587' => 'Standard-Zeitformat auswählen:',
'593' => 'Mitgliederliste neu aufbauen',
'594' => 'Die Mitgliederliste (memberlist.txt) wurde neu aufgebaut und enthält',
'594a' => 'registrierte Mitglieder.',
'595' => 'Benutzer-Onlinelog zurücksetzen',
'596' => "Das Benutzer-Onlinelog ($vardir/log.txt) wurde zurückgesetzt.",
'597' => 'Mitglieder-Historie neu aufbauen ',
'598' => 'Alle Mitglieder-Historie-Logs (.rlog) wurden neu aufgebaut.',
'600' => 'eMail-Einstellungen für den Versand von Foren-Themen',
'601' => 'Wie soll der Versand "Thema per eMail an einen Freund" erfolgen?',
'602' => 'Button "Thema versenden" deaktivieren',
'603' => 'Thema per eMail an einen Freund über das Forum senden',
'604' => 'Thema über das eMail-Programm des Benutzers an einen Freund senden',
'605' => 'Benutzer wählen lassen, wie der eMail Versand erfolgen soll',
'617' => 'Bist Du sicher, dass Du diese(n) Punkt(e) löschen willst?',
'619' => 'Willkommensmail an Benutzer senden, wenn das Zufallspasswort nicht per eMail verschickt wird?',
'630' => '\'Fake\' File Truncation benutzen?<br /><span class="small">Diese Option sollte nur eingeschaltet werden, wenn Dein Server folgenden Fehler meldet: \'truncate() not supported on this platform.\'</span>',
'632' => 'Gastzugang deaktivieren?',
'639' => 'Neues Passwort versenden, wenn ein Benutzer die eMail Adresse ändert?',
'645' => 'YaBB-Statistik',
'656' => 'Neuestes Mitglied:',
'657' => 'Verschiedenes',
'658' => 'Kategorien insgesamt:',
'659' => 'Neuester Beitrag:',
'665' => 'Foren insgesamt:',
'666' => 'Unterforen insgesamt:',
'670' => 'Eine Neuigkeit pro Zeile. YaBBC-Tags, wie [b], [i] und [u] sind ebenso wie Smileys erlaubt.',
'677' => 'Hier kannst Du Foren hinzufügen oder bearbeiten. Klicke auf den Button vor dem Kategorienamen und Du kannst die Reihenfolge der Foren sortieren, wie sie in den Kategorien angezeigt werden sollen.',
'678' => 'Hier kannst Du Deine Kategorien bearbeiten. Klicke auf den Button über den Titeln, um die Reihenfolge der Kategorien zu ändern. Klicke auf den Button vor dem Kategorienamen und Du kannst die Reihenfolge der Foren in dieser Kategorie ändern.',
'682' => 'Dies ist das Template Deines YaBB-Forums. Du kannst hier nach Belieben mit HTML Änderungen vornehmen. Das Aussehen Deines Forums wird automatisch geändert, sobald Du die Änderungen gespeichert hast.',
'684' => 'Administrator(en)',
'684a' => 'Globale(r)-Moderator(en)',
'684b' => 'Forum-Moderator(en)',
'689' => 'Maximal erlaubte Zeichen in der Signatur',
'689a' => 'Maximal erlaubte Zeichen in der \'Abwesenheit\' Nachricht',
'690' => 'Zeitraum (in Minuten), in dem alle Klicks in Deinem Forum gespeichert werden<br />(muss weniger als 1440 (= 24 Stunden) sein)',
'691' => 'Klicks insgesamt',
'692' => "in den letzten $ClickLogTime Minuten",
'692a' => 'abgeschaltet',
'693' => 'Zugriffsstatistik ansehen',
'694' => 'IP-Zugriffe',
'695' => 'Browser',
'696' => 'Betriebssysteme',
'696a' => 'Scriptaufrufe',
'697' => "Dies ist ein einfaches System, welches die LOG-Datei analysiert. Es gibt einen groben Überblick über Traffic, Browser und Betriebssysteme der $mbname Besucher. Die Zahlen in Klammern neben jedem Eintrag geben die Anzahl an, wie oft dieser Eintrag in der Log-Datei vorkommt.",
'698' => "<br /><br />Die LOG-Datei ist im Moment auf $ClickLogTime Minuten eingestellt.",
'698a' => '<br /><br />Du hast derzeit das Logsystem abgeschaltet.',
'699' => 'Reservierte Namen verhindern, dass Deine Benutzer diese Namen als Benutzername oder als angezeigten Namen verwenden. Wähle die gewünschten Optionen unten aus, bevor Du die Einstellungen abspeicherst.',
'702' => 'Beim Registrieren Zufallspasswort per eMail versenden?',
'710' => 'Passwort-Längenprüfung - Sicherheitscheck<br /><span class ="small">Hier kannst Du festlegen, nach wieviel Zeichen die Sicherheitslinie in das nächsthöhere Level springt. Die Standardwerte für das jeweils nächsthöhere Level sind gesetzt auf <i>10,15,30,40</i> Zeichen. <font color="red">Trage hier nur Zahlen und Kommas ein oder es kann zu Problemen kommen.</font><br />Setze die Werte auf <i>-1,-1,-1,-1</i> zum Deaktivieren der Passwort-Längenprüfung. Dann wird lediglich angezeigt, ob das gewählte Passwort zu kurz oder Ok ist.</span>',
'711' => 'Passwort-Längenprüfung - Unsichere Passwörter<br /><span class ="small">Trage hier alle Wörter oder Kombinationen ein, die als "Unsicheres Passwort" angezeigt werden sollen. Diese Wörter müssen zwischen "" Zeichen stehen und durch Kommata getrennt werden. Beispiel:<br />"123456","abcdef","passwort"</span>',
'712' => 'Passwort-Längenprüfung - Minimale Zeichenanzahl<br /><span class ="small">Trage hier die Anzahl der Zeichen ein die nötig sind, damit ein Passwort nicht als zu kurz deklariert wird.</span>',
'723' => 'Das verstecken von eMail-Adressen (außer vor dem Admin) erlauben?',
'724' => 'IPs bannen: (z.B. 192.168.12.213 oder 128.0.) - ein Eintrag pro Zeile',
'724a' => 'Klicke auf die IP, um sie von der Liste zu entfernen.',
'725' => 'eMail-Adressen bannen: (z.B. blödmann\@sonstwo.de) - ein Eintrag pro Zeile, Wildcards sind <font color="red">nicht</font> erlaubt',
'725b' => 'Klicke auf die eMail-Adresse, um sie von der Liste zu entfernen',
'725a' => 'Benutzer-ID bannen: (z.B. super_Trottel13) - ein Eintrag pro Zeile',
'725c' => 'Klicke auf die Benutzer-ID, um die Verbannung aufzuheben',
'725d' => 'Bereinige Banliste',
'725e' => 'Bereinigt',
'725f' => 'Verbanne IP',
'725g' => 'Enferne abgelaufene Zeit-Verbannungen von der Bannliste',
'726' => 'Nur ganze Namen beachten. Wenn nicht gewählt, werden reservierte Namen auch als Teil eines Namens nicht akzeptiert.',
'727' => 'Groß-/Kleinschreibung beachten. Wenn nicht gewählt, wird die Schreibweise nicht beachtet.',
'728' => 'Auf Benutzer-ID anwenden.',
'729' => 'Auf angezeigten Namen anwenden.',
'732' => 'Forenbeschreibung in der Themenübersicht anzeigen?',
'733' => 'Haupt-Forum kann (darf) nicht gleich dem ausgewählten Forum zum Verschieben sein.',
'734' => 'Du musst zunächst ein Forum zum Update auswählen.',
'735' => 'Haupt-Forum kann (darf) nicht identisch mit dem zu editierenden Forum sein.',
'737' => 'Alle auswählen',
'738' => 'Dies ist eine Liste Deiner Forenkategorien. Wähle die Kategorie, die Du verschieben möchtest.',
'738a' => 'Verschiebe die gewählte Kategorie rauf oder runter.',
'738b' => 'Keine Kategorien zu verschieben.',
'739' => 'Dies ist eine Liste der Foren in dieser Kategorie. Wähle das Forum, welches Du bewegen möchtest.',
'739a' => 'Rauf',
'739b' => 'Runter',
'739c' => 'Verschiebe das gewählte {board} zu einer anderen Kategorie.',
'739d' => 'Verschiebe das gewählte {board} rauf oder runter.',
'739e' => 'Keine Foren in dieser Kategorie.',
'739f' => 'Verschiebe das gewählte {board} in ein anderes Forum.',
'739g' => 'Aktualisieren',
'739h' => 'Dies ist eine Liste der Unterforen in diesem Forum. Wähle das Unterforum, welches Du verschieben möchtest.',
'739i' => 'Keine Unterforen in diesem Forum.',
'739j' => 'Unter-',
'740' => 'YaBBC-Buttons beim Schreiben von Beiträgen und Privatnachrichten anzeigen?',
'743' => 'Besucher insgesamt',
'744' => 'Browser insgesamt',
'745' => 'Betriebssyteme insgesamt',
'746' => 'Dürfen Benutzer im Profil Avatare aussuchen?',
'747' => 'Mitgliedern erlauben, ihr eigenes Avatar Bild (gif, png, jpg, jpeg) auf den Server hochzuladen?',
'747a' => 'Auf der rechten Seite wird der Avatar Verzeichnis Pfad angezeigt <br />sofern das Verzeichnis existiert und ob die korrekten Zugriffsberechtigungen gesetzt sind (Ja/Nein).',
'748' => 'Spezifiziere die Mitgliedergruppen, die eigene Avatare hochladen dürfen:<br /><span class ="small">Ist keine Mitgliedergruppe explizit ausgewählt, so sind automatisch alle Mitgliedergruppen berechtigt Avatare hochzuladen.<br />Benutze die Ctrl oder Shift Taste zum selektieren/deselektieren von Gruppen.</span>',
'749' => 'Größenlimit für Avatar Dateien:<br /><span class ="small">Setze den Wert 0 zum deaktivieren der Prüfung (nicht empfohlen) oder einen Höchstwert von beispielsweise 100&nbsp;KB.</span>',
'750' => 'Größenlimit des Avatar Verzeichnisses:<br /><span class ="small">Setze den Wert 0 zum deaktivieren der Prüfung (nicht empfohlen).</span>',
'751' => 'Benutzern erlauben, Avatare in den Beiträgen zu verstecken?',
'752' => 'Benutzern erlauben, Benutzer Text in Beiträgen zu verstecken?',
'753' => 'Benutzern erlauben, angehängte Bilder in Beiträgen zu verstecken?',
'754' => 'Benutzern erlauben, Signaturen in Themen verbergen?',
'755' => 'Benutzern erlauben, die Smilie-Reihe unter den Nachrichten-Eingabebereich zu verstecken?',
'756' => 'Benutzern erlauben, Bilder in Beiträgen zu verstecken?',
'764' => 'Vereinbarung bearbeiten',
'765' => 'In diesem Formular kannst Du Deine "agreement.txt" in den verfügbaren Sprachen bearbeiten. Es ist ein einfaches Textdokument, das bei der Registrierung angezeigt wird. Einige HTML-Tags sind erlaubt.',
'802' => 'Browser-Cache-Verhalten?<br /><span class="small">Deaktiviert: Browser soll nicht cachen. Aktiviert: Cache erlaubt</span>',
'803' => 'Benutzeraktionen (Klick) mitschreiben?<br /><span class="small">Erzeugt eine Statistik im AdminCenter, kann aber die Ladegeschwindigkeit des Forum beeinträchtigen</span>',
'804' => 'Flash-Tags auslesen?<br /><span class="small">Kann ein <b>Sicherheitsrisiko</b> für Dein Forum bedeuten</span>',
'813' => 'Standard-Template auswählen:',
'816' => 'Standard-Sprache auswählen:',
'816a' => 'Standard-Zeichenkodierung (in der Regel entweder ISO-8859-1 oder UTF-8)<br /><span class="small"><b>Achtung</b>:<br /> Die Wahl der falschen Codierung können einige Zeichen unlesbar machen. Wenn Du zusätzliche Sprachpakete oder ein älteres Forum importiert hast, wähle ISO-8859-1.</span>',
'825' => 'Original Reihenfolge',
'826' => 'Neue Reihenfolge',
'827' => q~Die \'Neue Reihefolge\'-Liste enthält Foren, die nicht in der \'Original Reihenfolge\'-Liste sind und umgekehrt.~,
'829' => 'Kategorien neu sortieren',
'830' => 'Die Kategorie mit der ID',
'831' => 'wurde erfolgreich gelöscht.',
'832' => 'Foren in dieser Kategorie neu sortieren',
'832a'=> 'Unterforen in diesem Forum neu sortieren',
'833' => 'Du hast eine ungültige ID gewählt. Bitte versuche es erneut.',
