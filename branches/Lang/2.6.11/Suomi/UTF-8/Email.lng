$suomiemaillngver = 'YaBB 2.6.11 $Revision: 1611 $';
@suomiemaillngmods = ();
if(@suomiemaillngmods){
    $suomiemaillngmods = 1;
}
if ( $action eq 'detailedversion' ) { return 1; }

$emailcharset = 'UTF-8';

%yabbtagdesc = (
# Constant tags
'scripturl' => "Osoite YaBB-foorumille. Esimerkki: $scripturl",
'adminurl' => "YaBB ylläpitokeskuksen osoite. Esimerkki: $adminurl",
'mbname' => "Foorumin nimi. Esimerkki: $mbname",

# New Member related
'userip' => "Käyttäjän IP-osoite.",
'useremail' => "Käyttäjän sähköpostiosoite.",

# User-related
'username' => "Käyttäjän käyttäjätunnus.",
'displayname' => "Käyttäjän näyttönimi.",
'cryptusername' => "Käyttäjätunnus, joka on salattu URL:eissa käytettäessä.",
'reviewer' => "Ylläpitäjän/yleisen valvojan todellinen nimi, rekisteröintien tarkistaja.",

# Topic/PM-related
'sender' => "Yksityisviestin lähettäjä.",
'num' => "Aiheen tunniste (käytetään URL:eissa)",
'start' => "Viestin tunniste (käytetään URL:eissa)",
'tmessage' => "Uuden aiheen teksti",
'tauthor' => "Kirjoittajan nimi",

# Registration/Password
'activationcode' => "Rekisteröitymisviestin mukana lähetetty aktivointitunniste.",
'remindercode' => "Salasanamuistutinviestin mukana lähetetty tunniste.",
'preregspan' => "Esirekisteröitymisen umpeutumisen aika. Tällä hetkellä käytössä oleva: $preregspan",
'reason' => "Ylläpitäjän antama lisäselvitys rekisteröinnin hyväksymisessä (mikäli käytössä)",

# Sending a Topic
'toname' => "Aiheen vastaanottaja.",

# PMs
'sendto' => "Yksityisviestin vastaanottaja.",
'email' => "Sähköpostia käyttäjältä.",
'date' => "Lähetyspäivä.",
'subject' => "Viestin aihe.",
'message' => "Yksityisviestin sisältö.",
);

# Pre registration subject lines
%mailreg_txt=(
'apr_result_activate' => "Aktivointitiedot",
'apr_result_validate' => "Onnistunut rekisteröinti",
'apr_result_info' => "Rekisteröitymistiedot",
'apr_result_wait' => "Rekisteröinti odottaa hyväksymistä",
'apr_result_reject' => "Rekisteröityminen hylätty",
'apr_result_approved' => "Rekisteröityminen hyväksytty",
'new_member_info' => "Uusi rekisteröityminen!",
);

$yabbtags{'preregemail'} = qq~displayname preregspan cryptusername activationcode~;
$emaildesc{'preregemail'} = qq~Rekisteröinnin vahvistusviesti joka lähetetään esirekisteröinnin tunnisteen kanssa.~;
$preregemail = qq~Tervetuloa, {yabb displayname}!
Tässä sinulle tunnuksesi varmistustunniste {yabb displayname}.

Tunnuksesi on nyt esirekisteröity foorumille: {yabb mbname}.
Muistathan vahvistaa rekisteröitymisen {yabb preregspan} tunnin sisällä!

Ole hyvä ja napsauta allaolevaa linkkiä aktivoidaksesi tunnuksesi

<a href="{yabb scripturl}?action=activate&username={yabb cryptusername}&activationkey={yabb activationcode}">{yabb scripturl}?action=activate&username={yabb cryptusername}&activationkey={yabb activationcode}</a>

Jos linkki ei toimi (tai käytät selainpohjaista sähköpostiohjelmaa) kopioi linkki selaimesi osoiteriville itse.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'approveregemail'} = qq~username displayname~;
$emaildesc{'approveregemail'} = qq~Hyväksymistä odottavan tunnuksen viesti, silloin kun ei lähetetä salasanaa tai ennakkorekisteröintitunnistetta~;
$approveregemail = qq~Hei, {yabb displayname}!

Hakemuksesi käyttäjätunnukselle "{yabb username}" odottaa hyväksymistä, jonka suorittaa {yabb mbname} ylläpito.

Prosessi voi viedä jonkin aikaa ennenkuin ylläpito ehtii paneutua asiaan, joten odota kärsivällisesti.
Saat tiedon heti kun hakemuksesi on käsitelty.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'instantapprovedemail'} = qq~username displayname reviewer~;
$emaildesc{'instantapprovedemail'} = qq~Välittömästi hyväksyttävän rekisteröinnin viesti kun salasanaa tai ennakkorekisteröintitunnistetta ei lähetetä~;
$instantapprovedemail = qq~Hei, {yabb displayname}!

Onnittelut ja tervetuloa.

Rekisteröitymisesi on hyväksytty (käsittelijä: {yabb reviewer}).

Voit nyt kirjautua foorumille käyttäen joko nimimerkkiäsi ({yabb displayname}), sähköpostiosoitettasi tai käyttäjätunnustasi ({yabb username}).

Voit muuttaa salasanaasi kirjautumisen jälkeen menemällä omaan profiiliisi. Napsauta Käyttäjäasetukset painiketta foorumin {yabb mbname} etusivulla osoitteessa <a href="{yabb scripturl}">{yabb scripturl}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'pwinstantapprovedemail'} = qq~username displayname reviewer password~;
$emaildesc{'pwinstantapprovedemail'} = qq~Välittömästi hyväksyttävän rekisteröinnin viesti kun salasana lähetetään~;
$pwinstantapprovedemail = qq~Hei, {yabb displayname}!

Onnittelut ja tervetuloa.

Rekisteröitymisesi on hyväksytty (käsittelijä: {yabb reviewer}).

Voit nyt kirjautua foorumille käyttäen joko nimimerkkiäsi ({yabb displayname}), sähköpostiosoitettasi tai käyttäjätunnustasi ({yabb username}).
Tämänhetkinen salasanasi on: {yabb password}

Voit muuttaa salasanaasi kirjautumisen jälkeen menemällä omaan profiiliisi. Napsauta Käyttäjäasetukset painiketta foorumin {yabb mbname} etusivulla osoitteessa <a href="{yabb scripturl}">{yabb scripturl}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'instantrejectedemail'} = qq~username displayname reviewer~;
$emaildesc{'instantrejectedemail'} = qq~Välittömän hylkäämisen viesti~;
$instantrejectedemail = qq~Hei, {yabb displayname}!

Valitettavasti rekisteröimääsi tunnusta ei voitu hyväksyä (käsittelijä: {yabb reviewer}).
Mitä erityistä syytä ei annettu päätöstä tehdessä, mutta luultavasti kyseessä olivat puutteelliset tai väärät rekisteröintitiedot.

Jos päätös on mielestäsi virheellinen, voit luonnollisesti yrittää rekisteröityä uudelleen uusilla tiedoilla.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'reviewapprovedemail'} = qq~username displayname reviewer~;
$emaildesc{'reviewapprovedemail'} = qq~Erikseen käsiteltävän rekisteröinnin viesti kun salasanaa tai ennakkorekisteröintitunnistetta ei lähetetä~;
$reviewapprovedemail = qq~Hei, {yabb displayname}!

Onnittelut ja tervetuloa.

Hakemuksesi on hyväksytty {yabb reviewer} :n toimesta {yabb mbname} Foorumille.
{yabb reviewer} antoi syyksi:

{yabb reason}

Voit nyt kirjautua foorumille käyttäen joko nimimerkkiäsi ({yabb displayname}), sähköpostiosoitettasi tai käyttäjätunnustasi ({yabb username}).

Voit vaihtaa salasanasi käyttäjäprofiilissasi, kun olet kirjautunut sisään. Napsauta Hallintapaneeli-välilehteä {yabb mbname} foorumin pääsivulla: <a href="{yabb scripturl}">{yabb scripturl}</a> ja napsauta "Muuta profiilia" (turvallisuussyistä sinun täytyy antaa salasanasi).

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'pwreviewapprovedemail'} = qq~username displayname reviewer password~;
$emaildesc{'pwreviewapprovedemail'} = qq~Hyväksyntäsähköposti lähetettäessä salasanaa~;
$pwreviewapprovedemail = qq~Hei, {yabb displayname}!

Onnittelut ja tervetuloa.

Hakemuksesi on hyväksytty {yabb reviewer} :n toimesta {yabb mbname} Foorumille.

{yabb reviewer} antoi syyksi:

{yabb reason} 

Voit kirjautua sisään käyttämällä käyttäjänimeäsi ({yabb displayname}), sähköpostiosoitettasi, tai käyttäjätunnustasi ({yabb username}).
Salasanasi on: {yabb password}

Voit vaihtaa salasanasi käyttäjäprofiilissasi, kun olet kirjautunut sisään. Napsauta Hallintapaneeli-välilehteä {yabb mbname} foorumin pääsivulla: <a href="{yabb scripturl}">{yabb scripturl}</a> ja napsauta "Muuta profiilia" (turvallisuussyistä sinun täytyy antaa salasanasi).

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'reviewrejectedemail'} = qq~username displayname reviewer reason~;
$emaildesc{'reviewrejectedemail'} = qq~Käsitellyn, mutta hylätyn rekisteröinnin ilmoitusviesti~;
$reviewrejectedemail = qq~Hei, {yabb displayname}!

Hakemuksesi {yabb mbname} foorumille on hylätty {yabb reviewer} :n toimesta.

{yabb reviewer} antoi syyksi:

{yabb reason} 

Jos päätös on mielestäsi virheellinen, voit luonnollisesti yrittää rekisteröityä uudelleen uusilla tiedoilla.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'passwordregemail'} = qq~username password displayname~;
$emaildesc{'passwordregemail'} = qq~Rekisteröinnin ilmoitusviesti kun käyttäjälle lähetetään satunnainen salasana~;
$passwordregemail = qq~Tervetuloa, {yabb displayname}!

Käyttäjätunnuksesi on {yabb username}, ja salasanasi on {yabb password}.

Voit kirjautua sisään käyttämällä käyttäjänimeäsi ({yabb displayname}), sähköpostiosoitettasi, tai käyttäjätunnustasi ({yabb username}).

Voit vaihtaa salasanasi käyttäjäprofiilissasi, kun olet kirjautunut sisään. Napsauta Hallintapaneeli-välilehteä {yabb mbname} foorumin pääsivulla: <a href="{yabb scripturl}">{yabb scripturl}</a> ja napsauta "Muuta profiilia" (turvallisuussyistä sinun täytyy antaa salasanasi).

Terveisin,
Ylläpito
{yabb mbname}~;

