$yabbtags{'newmemberemail'} = qq~displayname username userip useremail~;
$emaildesc{'newmemberemail'} = qq~Uudesta käyttäjästä ylläpitoa muistuttava viesti~;
$newmemberemail = qq~Uusi käyttäjä on rekisteröitynyt foorumille!

Käyttäjätunnus: {yabb displayname}
Käyttäjänimi: {yabb username}
IP-osoite: {yabb userip}
Sähköpostiosoite: {yabb useremail}

Uuden käyttäjän rekisteröinnin tarkastamiseksi kirjaudu foorumille ja napauta alla olevaa linkkiä.
{yabb adminurl}?action=view_reglog

Jos linkki ei toimi (tai käytät selainpohjaista sähköpostiohjelmaa) kopioi linkki osoiteriville itse.

Tarkastaaksesi uuden käyttäjän profiilin, kirjaudu foorumille.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'passwordreminderemail'} = qq~displayname mbname remindercode cryptusername~;
$emaildesc{'passwordreminderemail'} = qq~Salasanan palautusviesti~;
$passwordreminderemail = qq~Hei, {yabb displayname},

Tätä toimintoa käytettiin seuraavalla foorumilla: {yabb mbname}. Mikäli sen teki joku muu, ole hyvä äläkä välitä tästä viestistä.

Jos pyysit uutta salasanaa, ole hyvä ja siirry osoitteeseen <a href="{yabb scripturl}?action=resetpass&ID={yabb remindercode}&user={yabb cryptusername}">{yabb scripturl}?action=resetpass&ID={yabb remindercode}&user={yabb cryptusername}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'boardnewtopicnotificationemail'} = qq~num subject tmessage tauthor~;
$emaildesc{'boardnewtopicnotificationemail'} = qq~Ilmoitus uudesta aiheesta (aihealuetason ilmoitukset)~;
$boardnewtopicnotificationemail = qq~Uusi aihe, "{yabb subject}", jonka kirjoitti {yabb tauthor}, on luettavissa aihealueella josta olet tilannut ilmoitukset.

########################################

{yabb tmessage}

########################################

Tarkista aihe osoitteessa <a href="{yabb scripturl}?num={yabb num}">{yabb scripturl}?num={yabb num}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'boardnotificationemail'} = qq~num start subject tmessage tauthor~;
$emaildesc{'boardnotificationemail'} = qq~Ilmoitus uudesta viestistä olemassa olevassa aiheessa (aihealuetason ilmoitukset)~;
$boardnotificationemail = qq~Aiheeseen, "{yabb subject}", joka sijaitsee seuraamallasi aihealueella, on vastannut käyttäjä {yabb tauthor}.

########################################

{yabb tmessage}

########################################

Tarkista uusi viesti osoitteessa <a href="{yabb scripturl}?num={yabb num}/{yabb start}">{yabb scripturl}?num={yabb num}/{yabb start}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'topicnotificationemail'} = qq~num subject start tmessage tauthor~;
$emaildesc{'topicnotificationemail'} = qq~Ilmoitus vanhan aiheen uudesta viestistä~;
$topicnotificationemail = qq~Seuraamaasi aiheeseen, "{yabb subject}", on vastannut käyttäjä {yabb tauthor}.

########################################

{yabb tmessage}

########################################

Tarkista uusi viesti osoitteessa <a href="{yabb scripturl}?num={yabb num}/{yabb start}">{yabb scripturl}?num={yabb num}/{yabb start}</a>

Saat seuraavan ilmoituksen uudesta viestistä vasta kun olet käynyt tarkistamassa aiheen.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'profilenewpasswordemail'} = qq~displayname password~;
$emaildesc{'profilenewpasswordemail'} = qq~Ilmoitus salasanan muuttamisesta~;
$profilenewpasswordemail = qq~Hei, {yabb displayname},

Salasanasi on vaihdettu. Uusi salasanasi on {yabb password}.

Voit vaihtaa sen uudelleen oman käyttäjäprofiilisi kautta.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'sendtopicemail'} = qq~toname subject displayname num~;
$emaildesc{'sendtopicemail'} = qq~Aiheen ilmoittamisesta kaverille~;
$sendtopicemail = qq~Hei {yabb toname},

Luulen että haluaisit nähdä tämän aiheen, "{yabb subject}", löydät sen täältä: {yabb mbname}. 
Nähdäksesi aiheen, ole hyvä ja napsauta allaolevaa linkkiä:

<a href="{yabb scripturl}?num={yabb num}">{yabb scripturl}?num={yabb num}</a>

Terveisin,
{yabb displayname}~;

$yabbtags{'privatemessagenotificationemail'} = qq~sender subject message~;
$emaildesc{'privatemessagenotificationemail'} = qq~The Private Message Notification Email~;
$privatemessagenotificationemail = qq~{yabb sender} lähetti sinulle yksityisviestin.

Aihe: {yabb subject}
Viesti: {yabb message}
{yabb attachments}

Löydät viestin omien yksityisviestiesi saapuneet-kansiosta {yabb mbname}\: <a href="{yabb scripturl}">{yabb scripturl}</a>~;

## for online alert pms. 
%online_alert = (
newnotify => "Uusi viesti!",
replynotify => "Uusi vastaus!",
);



$yabbtags{'replyguestmail'} = qq~sender email sendto date subject message~;
$emaildesc{'replyguestmail'} = qq~Vieraiden ylläpidolle lähettämän viestin sähköpostitekstit~;
$replyguestmail = qq~Hyvä {yabb sender},

Terveisin,
Ylläpito
{yabb mbname}
<a href="{yabb scripturl}">{yabb scripturl}</a>

-----------------------------
----- Original Message -----
From: "{yabb sender}" <{yabb email}>
To: "{yabb sendto}", <{yabb scripturl}>
Sent: {yabb date}
Subject: {yabb subject}

{yabb message}
~;


$yabbtags{'deleteduseremail'} = qq~displayname~;
$emaildesc{'deleteduseremail'} = qq~Ilmoitus tunnuksen poistamisesta~;
$deletedusersybject = qq~Tunnuksesi on poistettu~;
$deleteduseremail = qq~Hei, {yabb displayname}!

{yabb mbname} käyttäjätunnuksesi on nyt poistettu eikä sitä voi enää käyttää!

Terveisin,
Ylläpito
{yabb mbname}
<a href="{yabb scripturl}">{yabb scripturl}</a>
~;

1;
