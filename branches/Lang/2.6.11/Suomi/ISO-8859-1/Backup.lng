$suomibackuplngver = 'YaBB 2.6.11 $Revision: 1611 $';
@suomibackuplngmods = ();
if(@suomibackuplngmods){
    $suomibackuplngmods = 1;
}
if ( $action eq 'detailedversion' ) { return 1; }

$script_root = $ENV{'SCRIPT_FILENAME'};
if( ! $script_root ) {
    $script_root = $ENV{'PATH_TRANSLATED'};
}
($support_env_path = $script_root) =~ s~/\w+\.pl~~;

%backup_txt = (
'1' => 'YaBB varmuuskopio',
'2' => 'Et ole tallentanut varmuuskopiointiasetuksiasi! Sinun tulee tehd‰ t‰m‰ ennen kuin voit varmuuskopioida foorumiasi.',
'3' => 'Valitse varmuuskopioitavat hakemistot. Huomio: YaBB-hakemistojen sijainti tarkistetaan Paths.pl-tiedostosta.',
'4' => 'YaBB-hakemistot',
'5' => 'Valitse/Poista valinta kaikista',
'6' => 'Jos valitset kaikki, koko foorumisi varmuuskopioidaan (suositus).<br />T‰m‰ voi aiheuttaa palautusongelmia todella suurilla foorumeilla. T‰llˆin on j‰rkev‰mp‰‰ varmuuskopioida kaikki enemm‰n tai v‰hemm‰n staattiset (muuttumattomat) hakemistot erikseen ja Boards-, Members- ja Messages-hakemistot erikseen!',
'path1' => 'Tar- ja Zip-ohjelmien polku:',
'path2' => 'gzip- ja bzip2-ohjelmien polku (asettaa myˆs polun gzip-ohjelmalle Laajennetuissa asetuksissa):',
'path3' => 'T‰yt‰ polut <b>vain</b> jos YaBB ei automaattisesti lˆyd‰ Tar-, Zip-, gzip-, ja bzip2-ohjelmia. Muuten j‰t‰ yll‰olevat kohdat tyhjiksi.',

