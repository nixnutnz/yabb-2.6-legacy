'12' => '(sis‰lt‰‰ kaikki YaBB:n asetukset)',
'and' => 'ja', # Odd name, yes, but could be useful in more then one place
'13' => 'ja muu l‰hdekoodi (sis‰lt‰‰ YaBB:n l‰hdekoodin)',
'14' => '(sis‰lt‰‰ foorumin kuvat ja tyylitiedostot poislukien seuraavalla rivill‰ eritellyt hakemistot)',
'14a' => '(sis‰lt‰‰ kaikki k‰ytt‰jien lataamat tiedostot)',

# Begin the backup method selection
'15' => 'Varmuuskopiointitapa',

# Don't translate command names (such as /bin/tar) or 'tar'.
'16' => 'Ensimm‰isen vaihtoehdon tulisi olla Tar (pakkauksella) tai Zip.<br />K‰yt‰ Archive::Tar (Compress::Zlib tai Compress::Bzip2 kanssa) tai Archive::Zip -varmuuskopiointia viimeisen‰ vaihtoehtona.<br />bzip2 tai Bzip2 tekee pienimm‰t varmuuskopiot mutta vie eniten aikaa.<br /><span style="color: red;"><b>Huomio:</b><br /></span> Jotkin palvelimet eiv‰t tue suuria varmuuskopioita. T‰llˆin saat virheilmoituksen kuten "Internal server error" tai pelk‰n tyhj‰n sivun. Yrit‰ silloin jotain toista varmuuskopiotapaa. Jos t‰m‰ ei auta v‰henn‰ varmuuskopioitavien YaBB-hakemistojen m‰‰r‰‰.',
'17' => 'Ei tar-pakkausta',
'18' => '(Tar-pakkaukselle)',
'19' => 'Varmuuskopiohakemisto',
'19a' => 'Koko polku, ei pelk‰st‰‰n ./Backups',
'19b' => 'Muistuta minua varmuuskopioista',
'19c' => 'Muistuta minua kun viimeisin varmuuskopio on vanhempi kuin',
'19d' => 'p‰iv‰‰. Laita 0 tai j‰t‰ tyhj‰ksi poistaaksesi muistutuksen k‰ytˆst‰.',
'20' => 'Tallenna asetukset',

# Begin run backup area
'21' => 'Varmuuskopioi',
'22' => 'Paina alapuolella olevaa nappia varmuuskopoiodaksesi foorumin. Varmuuskopio ilmestyy',
'23' => '-hakemistoon, joka on asetettu yll‰.',
'24' => 'Varmuuskopioinnin aikana foorumi asetettaan huoltotilaan.<br /><br />Jos varmuuskopioit eritt‰in suurta foorumia, voi menn‰ aikaa ennen kuin foorumi vastaa! Odota ainakin viisi minuuttia! Jos mit‰‰n ei tapahdu lue huomio varmuuskopiotapojen kohdalta.<br /><br />Ensimm‰isen varmuuskopion j‰lkeen voit valita varmuuskopioitavaksi vain muuttuneet tiedostot. Varmuuskopioasetuksia muuttaessasi joudut aina ajamaan t‰yden varmuuskopion ensin. Aika viimeisimm‰st‰ varmuuskopiosta tarkistetaan <i>sekunneissa</i> Tar, Archive::Tar ja Archive::Zip -tapauksissa ja <i>p‰iviss‰</i> Zip-tapauksessa.',
'25' => 'Varmuuskopioi',
'25a' => 'Varmuuskopioi vain uudemmat tiedostot kuin',

