'33' => 'Varmuuskopio vei: ',
'34' => 'sekuntia',

# Begin manage backups area
'35' => 'Hallitse varmuuskopioita',
'36' => 'Varmuuskopiohakemisto',
'37' => 'Voit:<ul><li>Ladata varmuuskopion (LATAA)</li><li>L‰hett‰‰ varmuuskopion s‰hkˆpostilla',
'37a' => ' (EMAIL)</li><li>Varmuuskopioida uudelleen samoilla asetuksilla (VARMUUSKOPIOI)</li><li>Varmuuskopioida vai muuttuneet samoilla asetuksilla(UUDEMMAT)</li><li>Palauttaa varmuuskopion mik‰li tuettu(PALAUTA)</li><li>Poistaa varmuuskopion(POISTA)</li></ul>',
'38' => 'Ei varmuuskopioita',

