$contexthelplngver = 'YaBB 2.6.11 $Revision: 1005 $';

### Do not translate uppercase words in sharp brackets

%contextxt = (
'clicktip' => q~Clic droit pour l'aide~,
'url' => q~Insérer un lien "URL":<br /><br />Sélectionnez l'URL: [SELECT]http://www.yabbforum.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [url]http://www.yabbforum.com[/url]<hr />insérer un lien "Texte":<br /><br />sélectionez l'URL <span class="under">et</span> le texte: [SELECT]http://www.yabbforum.com Forum YaBB[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [url=http://www.yabbforum.com]Forum YaBB[/url]<hr />La balise YaBBC [link] fonctionne de la même manière que la balise [url], a l'exception que la balise [link] ouvrira lorsque l'on clique sur un lien ce lien dans la fenêtre actuelle, tandis que la balise [url] ouvrira ce lien dans une nouvelle fenêtres. (il n'y a aucun bouton d'insertion pour la balise)~,
'ftp' => q~Insérer un lien "FTP":<br /><br />Sélectionnez l'adresse FTP: [SELECT]ftp://ftpdom[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [ftp]ftp://ftpdom[/ftp]~,
'img' => q~Insérer une Image:<br /><br />Sélectionnez le répertoire de l'image: [SELECT]http://repertoire/image.gif[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [img]http://imagedirectory/image.gif[/img]~,
'image' => q~Insérer une Image:<br /><br />Sélectionnez le répertoire de l'image: [SELECT]http://repertoire/image.gif[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [img]http://imagedirectory/image.gif[/img]~,
'email2' => q~Insérer un lien "Address courriel":<br /><br />Sélectionnez l'adresse courriel: [SELECT]monnom\@domaine.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [email]monnom\@domaine.com[/email]<hr />Insérer un lien "texte" de courriel:<br /><br />Sélectionnez l'adresse courriel <span class="under">et</span> le texte: [SELECT]Écrivez moi sur monnom\@domaine.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> Pour me rejoindre [email=monnom\@domaine.com]Écrivez-moi[/email]~,
'media' => q~Insérer un fichier multimédia:<br /><br />Sélectionnez l'URL du fichier multimédia: [SELECT]http://www.votre-domaine.com/yabbchelp.swf[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [media]http://www.votre-domaine.com/yabbchelp.swf[/media]~,
'table' => q~Insérer une table vide d'une cellule:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [table][tr][td][/td][/tr][/table]<hr />Incorporer un texte ou une image dans une cellule de table:<br /><br />Sélectionner le texte ou une répertoire d'image: [SELECT]Bonjour le Monde[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [table][tr][td]Bonjour le Monde[/td][/tr][/table]~,
'tr' => q~Insérer une rangée d'une table:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [tr][/tr]~,
'td' => q~Insérer une cellule d'une table::<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [td][/td]~,
'hr' => q~Insérer une règle horizontale:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [hr]~,
'tele' => q~Changer le texte à télétype:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [tt]Bonjour le monde[/tt] bla bla<br /><br /><strong>Résultat:</strong> bla bla <tt>Bonjour le monde</tt> bla bla~,
'teletype' => q~Changer le texte à télétype:<br /><br />Sélectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [tt]Bonjour le monde[/tt] bla bla<br /><br /><strong>Résultat:</strong> bla bla <tt>Bonjour le monde</tt> bla bla~,
'code' => q~Insérer du code dans une boîte:<br /><br />Sélectionnez le Code:<br /><br />[SELECT]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br /><br />[code]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/code]<br /><br /><strong>Résultat:</strong><br /><br /><strong>Code:</strong>[CODE]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/CODE]~,
'quote2' => q~Insérer une citation dans une boîte:<br /><br />Sélectionnez la citation: [SELECT]Être ou ne pas être...[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [quote]To be or not to be...[/quote]<br /><br /><strong>Résultat:</strong><br /><br /><strong>Quote:</strong>[QUOTE]To be or not to be...[/QUOTE]~,
'edit' => q~Insérer un message édité dans une boîte:<br /><br />Sélectionnez le message édité: [SELECT]Nouveau paquet zip joint.[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [edit]Nouveau paquet zip joint.[/edit]<br /><br /><strong>Résultat:</strong><br /><br /><strong>Edited:</strong>[EDIT]Nouveau paquet zip joint.[/EDIT]~,
'sup' => q~Changer le texte en Exposant "Superscript":<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [sup]Bonjour le monde[/sup] bla bla<br /><br /><strong>Résultat:</strong> bla bla <sup>Bonjour le monde</sup> bla bla~,
'sub' => q~Changer le texte en indice "Subscript":<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [sub]Bonjour le monde[/sub] bla bla<br /><br /><strong>Résultat:</strong> bla bla <sub>Bonjour le monde</sub> bla bla~,
'list' => q~Insérer une liste non triée avec un élément:<br /><br />Sélectionnez le texte de l'élément de liste: [SELECT]Item 1[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br /><br />[list][*]Item 1<br />[/list]<br /><br />Pour ajouter plus d'éléments de liste, vous devez taper les balises ([*]) à la main:<br /><br />[list][*]Item 1<br />[*]Item 2<br />[*]Item 3<br />[/list]<br /><br /><strong>Résultat:</strong><ul><li>Item 1</li><li>Item 2</li><li>Item 3</li></ul>Vous pouvez créer deux ou trois listes de niveaux en incluant une liste dans une autre liste:<br /><br />[list][*]Item 1<br />[*]Item 2[list][*]Sous item 1<br />[*]Sous item 2<br />[/list][*]Item 3<br />[/list]<br /><br /><strong>Résultat:</strong><ul><li>Item 1</li><li>Item 2<ul><li>Sous item 1</li><li>Sous item 2</li></ul></li><li>Item 3</li></ul><hr />La balise YaBBC [olist][*][/olist] fonctionne de la même manière que la balise [list][*][/list]  mais créera une liste triée avec des nombres au lieu de puces (il n'y a aucun bouton d'insertion pour les balises [olist]).~,
'me' => q~Insérer votre nom (pseudonyme):<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> /me dits Bonjour le monde<br /><br /><strong>Résultat:</strong> [ME] dits Bonjour le monde<br />~,
'move' => q~Déplacer un texte ou une image dans le message de droite à gauche:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> Déplacer les mots [move]Bonjour le monde[/move]<br /><br /><strong>Résultat:</strong><br />Déplacer les mots [MOVE]Bonjour le monde[/MOVE]~,
'timestamp' => q~Insérer un horodatage:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [timestamp=1121602762]<br /><br />Cette balise insérera un horodatage dans le format des lecteurs (membres)\.~,
'bold' => q~Changer le texte en gras:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [b]Bonjour le monde[/b] bla bla<br /><br /><strong>Résultat:</strong> bla bla <strong>Bonjour le monde</strong> bla bla~,
'italicize' => q~Changer le texte en italique:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [i]Bonjour le monde[/i] bla bla<br /><br /><strong>Résultat:</strong> bla bla <em>Bonjour le monde</em> bla bla~,
'underline' => q~Souligner le texte:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [u]Bonjour le monde[/u] bla bla<br /><br /><strong>Résultat:</strong> bla bla <span class="under">Bonjour le monde</span> bla bla~,
'strike' => q~Barré le texte:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [s]Bonjour le monde[/s] bla bla<br /><br /><strong>Résultat:</strong> bla bla <s>Bonjour le monde</s> bla bla~,
'highlight' => q~Surligner le texte:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [highlight]Bonjour le monde[/highlight] bla bla<br /><br /><strong>Résultat:</strong> bla bla [HIGHLIGHT]Bonjour le monde[/HIGHLIGHT] bla bla~,
'palette1' => q~Choisir la couleur du texte:<br /><br />Sélectionnez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]" et choisissez une des 228 couleurs pré établies ou créez votre propre balise de couleur\.<br /><br /><strong>Code YaBBC:</strong> bla bla [color=#ff0000]Bonjour le monde[/color] bla bla<br /><br /><strong>Résultat:</strong> bla bla [RED]Bonjour le monde[/RED] bla bla~,
'pre' => q~Insérer du texte pré formaté:<br /><br />Sélectionnez le texte: [SELECT]Ce &nbsp\;texte est &nbsp\; &nbsp\;pré formaté[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong>[pre]This &nbsp\;text is &nbsp\; &nbsp\;preformatted[/pre]<br /><br /><strong>Résultat:</strong>[PRE]Ce  texte est    préformatté[/PRE]~,
'left' => q~Alligner le texte par la gauche<br /><br />Sélectionnez le texte:<br />[SELECT]Ce texte<br />est aligné à gauche[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[left]This text<br />is left aligned[/left]<br /><br /><strong>Résultat:</strong><br />[LEFT]Ce texte<br />est aligné à gauche[/LEFT]~,
'center' => q~Centrer le texte:<br /><br />Sélectionnez le texte:<br />[SELECT]This text<br />est centré[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[center]This text<br />is centered[/center]<br /><br /><strong>Résultat:</strong><br />[CENTER]Ce texte<br />est centré[/CENTER]~,
'right' => q~Aligner le texte par la droite:<br /><br />Sélectionnez le texte:<br />[SELECT]Ce texte<br />est aligné à droite[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[right]This text<br />is right aligned[/right]<br /><br /><strong>Résultat:</strong><br />[RIGHT]Ce texte<br />est aligné à droite[/RIGHT]~,
'noparse' => q~Ne pas interpréter:<br /><br />Sélectionnez le code YaBBC:<br />[SELECT][table][tr][td]Cette table n'est pas interprété[/td][/tr][/table][/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[noparse][table][tr][td]Cette table de seras pas interprétée[/td][/tr][/table][/noparse]<br /><br /><strong>Résultat:</strong><br />[table][tr][td]Cette table de seras pas interprétée[/td][/tr][/table]~,
);

1;
