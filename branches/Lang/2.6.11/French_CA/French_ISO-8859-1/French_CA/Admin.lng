'siddescript' => q~Pour des raisons de sťcuritť, vous devez confirmer votre mot de passe pour accťder au centre d'administration.~,
'capslock' => q~Le verrouillage des majuscules est activť.~,
'wrong_char' => q~Ce caractŤre dans le mot de passe est invalide~,
'nodebug' => q~N'utilise pas le mode debug~,
'alldebug' => q~Utiliser le mode debug - Tout le monde voit la sortie~,
'admindebug' => q~Utiliser le mode debug - Seul Admin voit la sortie~,
'loadtime' => q~Afficher le temps de chargement de la page uniquement - Tout le monde voit la sortie~,
'show_ip_admin' => q~Afficher l'IP dans la liste des membres en ligne de l'index du forum pour tous les membres/invitťs en ligne aux administrateurs?~,
'show_ip_gmod' => q~Afficher l'IP dans la liste des membres en ligne de l'index du forum pour tous les membres/invitťs en ligne sur les modťrateurs globaux?~,
'show_ip_fmod' => q~Montrer l'IP dans la liste en ligne de l'index du forum pour tous les membres/invitťs en ligne des modťrateurs du forum?~,
'guestmedia' => q~EmpÍcher les invitťs de voir ldes fichiers multimťdias ou d'avoir des liens auto-cliquables dans les publications?~,
'guestlang' => q~Activer la sťlection de la langue pour les invitťs?~,
'checkspace' => qq~L'activation de cette fonction vous permettra de dťfinir les diffťrents contrŰles de l'espace disque libre. La vťrification de l'espace disque libre est principalement une fonction Linux et peut ne pas fonctionner correctement sur les serveurs Windows/IIS. Les fonctions d'espace disque libre peuvent renvoyer des valeurs incorrectes lorsqu'elles sont utilisťes sur des services d'hťbergement partagť.~,
'checkspace2' => qq~(Si la page de l'utilitaire Fonction Espace disque libre ne parvient pas ŗ se charger cela signifie que votre serveur <strong>ne supporte pas cette fonction</strong>.)~,
'checkspclabel' => qq~ParamŤtres avancťs - Fonctions de l'espace disque libre~,
'quota' => q~<em>quota</em>: En activant ceci, utilisez la commande shell "quota" de Linux pour vťrifier l'espace disque disponible. C'est la mťthode prťfťrťe ŗ utiliser. La case ŗ cocher sera dťsactivťe si cette commande n'est pas disponible sur votre serveur.<br /><span class="small">Si votre espace disque disponible est infťrieur ŗ 100 octets (100 Ko), le forum passera automatiquement en maintenance Mode pour ťviter de manquer d'espace et de perdre des donnťes.<br /><strong>Rappel</strong>:seuls les administrateurs peuvent accťder au forum en mode maintenance.</span>~,
'quota_value' => q~<em>quota</em>: Sťlectionnez le systŤme de fichiers sur lequel votre forum est:<br /><span class="small">Le bon systŤme de fichiers doit Ítre sťlectionnť si "quota" a ťtť sauvegardť <em>dťsactivť</em>auparavant.</span>~,
'quotahostuser' => q~<em>quota</em>: Votre nom d'utilisateur sur votre serveur hŰte:<br /><span class="small">Doit Ítre prťenregistrť. Disponible si ce qui prťcŤde est cochť.</span>~,
'findtime' => q~<em>find</em>: Temps entre la commande shell "find" de Linux pour vťrifier la taille des fichiers dans le rťpertoire que vous devez insťrer ci-dessous et ses sous-rťpertoires. Ce champ et les deux suivants seront dťsactivťs si cette commande n'est pas disponible sur votre serveur.<br />Mettre ŗ 0 pour pouvoir choisir une autre mťthode de vťrification comme "quota" ou la vťrification de l'espace disque libre.<br /><span class="small">Comme ce travail peut Ítre trŤs long, vous devriez insťrer une valeur ťlevťe raisonnable, par exemple 300 (cinq heures) ou 1440 (un jour). Une fois que l'espace libre est obtenu du serveur aprŤs chaque "find". Cette mťthode utilise beaucoups moins de ressource du serveur.</span>~,
'findroot' =>q~<em>find</em>: Chemin d'accŤs du rťpertoire racine de votre compte utilisateur sur un systŤme hŰte ŗ plusieurs utilisateurs.<br /><span class="small">Le chemin doit Ítre<strong> de la racine du systŤme ŗ la racine de l'utilisateur</strong>. Exemple:<br />/var/www/votre_nom_domaine/<br />/var/www/web1234/<br /><br />Vous pouvez ťgalement spťcifier un chemin vers votre forum ou un rťpertoire dans votre forum et spťcifier un Le nombre maximum d'espace en tant que limite pour cela "find" utilisera cette limite au lieu des limites de votre compte d'hŰte. Exemple:<br />/var/www/votre_nom_domaine/cgi-bin/yabb2/<br />/var/www/v/your_domain_name/public_html/yabbfiles/Attachments/</span>~,
'findmax' => q~<em>find</em>: Espace disponible que vous Ítes autorisť ŗ utiliser dans le rťpertoire ci-dessus (en mťgaoctets).<br /><span class="small">Cela devrait Ítre la mÍme quantitť de Comme vous devez dťfinir "find" pour vťrifier l'espace hŰte disponible uniquement toutes les X heures ou une fois par jour, vous devez dťfinir cette valeur plus bas que l'espace que votre hŰte vous fournit, ťvitez de manquer d'espace en raison d'une augmentation soudaine de l'utilisation du disque, par exemple par des piŤces jointes ou d'autres publications volumineuses.<br />Pour activer la recherche de l'espace hŰte libre, Pour activer "find" pour vťrifier l'espace libre du serveur, cette valeur doit Ítre &gt; 0. Si l'espace utilisť dans le rťpertoire ci-dessus est supťrieur ŗ cette valeur, le forum passe automatiquement en "Mode Maintenance" pour ťviter de manquer d'espace et de perdre des donnťes<br /><strong>Rappel</strong>: Seul les admin on accŤs au forum lorsqu'il est en mode de maintenance.<br />Au cas ou vous auriez oubliť: 1 GB = 1024 MB</span>~,
'diskspacecheck' => q~Activer la vťrification de l'espace disque libre?<br /><span class="small">Ceci vťrifie l'espace disque physique disponible sur le serveur Linux ou Windows. Sachez que tout cet espace disque ne peut pas Ítre utilisť par vous. Il peut afficher un nombre supťrieur ŗ celui autorisť par votre plan d'hťbergement personnel.<br />Si votre espace disque disponible tombe en dessous de 100 000 octets (100 Ko), le forum passera automatiquement en mode maintenance pour ťviter de manquer d'espace et de perdre data.<br />Rappel: seuls les administrateurs peuvent accťder au forum en mode maintenance.</span>', Mode.</span>~,
'minlinkpost' => q~Nombre minimum de publications qu'un membre doit avoir avant que les liens et les images puissent Ítre publiťs~,
'minlinkpost_exp' => q~Cela empÍche les spammeurs de spammer directement aprŤs l'enregistrement~,
'minlinksig' => q~Nombre de publications qu'un membre doit avoir avant que les liens et les images puissent Ítre crťťs dans la signature~,
'minlinksig_exp' => q~Cela ťvite que les spambots ne crťent des signatures de spams directement aprŤs l'enregistrement~,
'minlinkweb' => q~Nombre de publications qu'un membre doit possťder avant de pouvoir accťder ŗ un site Web dans son profil~,
'minlinkweb_exp' => q~Ceci empÍche les spammeurs de se connecter ŗ un site directement aprŤs l'enregistrement~,
'stealth' => q~Activer le mode "Stealth" pour les administrateurs et les mods globaux?<br /><span class="small">Si vous cochez cette case, les administrateurs et les mods globaux auront la possibilitť de ne pas apparaÓtre "en ligne" Groupes ou invitťs.<br />Il doit Ítre activť dans le profil utilisateur CP - Profil - Coordonnťes.</span>~,
'mlview' => q~Sťlectionnez les groupes de membres autorisťs ŗ voir la liste des membres?~,
'buddylist' => q~Activer la liste de contacts?~,
'regreason' => q~Nombre maximal de caractŤres autorisťs dans les "Raisons pour l'enregistrement" de l'utilisateur,~,
'showall' => q~Afficher "Tous" sur les sťlecteurs de page et le rťsumť de sujet?~,
'imageinquote' => q~Si cochť, les images incorporťes dans les articles apparaÓtront entre guillemets.<br /><span class="small">Si dťsactivť, les images des articles citťs seront montrťes comme des liens vers les images.</span>~,
'extendedprofiles' => q~Utiliser les profils ťtendus?<br /><span class="small">Si activť, un ťlťment supplťmentaire appelť "Champs du profil" sera affichť dans la barre latťrale ŗ gauche. Lŗ, vous pouvez ajouter des fonctions aux profils des utilisateurs.<br />Laissez cette case dťcochťe si vous n'utilisez pas cette fonction pour sauvegarder la charge du serveur.</span>~,
'forumnumbformat' => q~Sťlectionnez le format des nombres par dťfaut:~,
'nospammer' => q~Envoyer un courriel par dťfaut aux utilisateurs rejetťs mÍme si aucune raison n'est donnťe lors de l'enregistrement par l'approbation de l'administrateur. Vťrifiez pour "oui"~,
'honeypot' => q~Activer l'attrapeur de spambot "Honeypot Spambot catcher". Cocher "oui" (<a href="$boardurl/AdminIndex.$yyaext?action=honeypot"> Modifier le Honeypot</a>)~,
'spamfruits' => q~Activer SpamFruits Spambot catcher. Vťrifiez pour "oui"~,
'eventcal_set' => q~ParamŤtres du calendrier des ťvťnements~,
'eventcal_set1' => q~Modifier les paramŤtres de votre calendrier d'ťvťnements~,
'calsplit' => q~Nombre maximal d'anniversaires indiquť sur la page.<br /><span class="small">La page sera divisťe en plusieurs affichages mensuels. Laissez vide ou mettre ŗ 0 pour dťsactiver.</span>~,
'addtab_on' => q~Afficher Ajouter et ťditer des onglets sur le forum?~,
'rules' => q~RŤgles du forum~,
'rules1' => q~Activer les rŤgles du forum~,
'rules2' => q~Titre des rŤgles~,
'rules3' => q~RŤgles~,
'rules4' => q~Vous pouvez utiliser HTML ici.~,
'iplookup' => q~Activer la recherche IP?<br /><span class="small">Cocher cette option transformera les adresses IP en liens actifs vous permettant de les rechercher sur un serveur Whois.</span>~,
'iplookup_urls' => q~ Serveurs Whois de recherche IP:<br /><span class="small">Ici vous pouvez ajouter ou supprimer des serveurs Whois de/vers la page de recherche IP.<br />Utilisez {ip} dans l'URL pour substituer l'adresse IP rťelle et sťparer le titre et l'URL avec un symbole de pipe "|".<br />Une URL par ligne. Les espaces dans le nom du site doivent Ítre remplacťs par "_".<br />Exemple: Mon_sitelookup | Monsitelookup.com?ip={ip}</span>~,
'iplookup_protocols' => q~Les protocoles valides sont http et https.~,
'show_user_age' => q~Afficher l'‚ge de l'utilisateur dans la vue des publications?~,
'show_reg_date' => q~Afficher la date d'enregistrement de l'utilisateur dans la vue des publications?~,
'edit_gender_limit' => q~Fixe une limite au nombre de fois que les membres peuvent ťditer leur genre:<br /><span class="small">1 = Ne peut pas Ítre ťditť aprŤs la premiŤre fois qu'il a ťtť entrť.<br />0 = Aucune limite.</span>~,
'edit_age_limit' => q~Fixe une limite au nombre de fois que les membres peuvent modifier leur date de naissance:<br /><span class="small">1 = Ne peut pas Ítre ťditť aprŤs la premiŤre fois qu'il a ťtť entrť.<br />0 = Aucune limite.</span>~,
'min_reg_time' => q~Durťe minimale en secondes qui doit Ítre passťe sur la page d'inscription:<br /><span class="small">C'est pour arrÍter les spambots qui remplissent automatiquement le formulaire d'inscription dans un temps qui est humainement impossible.<br />Mettre ŗ 0 pour dťsactiver.</span>~,
'ipblock' => q~Block IP dans Guardian~,
'ipblock2' => q~Bloquer IP dans .htaccess~,
'ipblock_confirm' => q~ tes-vous sŻr de vouloir bloquer cette adresse IP? \ n \ n~,
'ipban_confirm' => q~Es-tu sŻr de vouloir interdire cette adresse IP? \ n \ n~,
'userpicml' => q~Afficher l'avatar de l'utilisateur dans la liste des membres?~,
'group_stars_ml' => q~Afficher les ťtoiles de groupe dans la liste des membres?~,
'default_avatar' => q~Montrer un avatar par dťfaut si le membre n'a pas ajoutť de photo?~,
'default_userpic' => q~Image avatar par dťfaut:<br /><span class="small">Types de fichiers autorisťs: png jpg jpeg gif<br />Taille du fichier maximum:250 Ko</span>~,
'edit' => q~Modifier~,
'delete' => q~Supprimer~,
'cancel' => q~Annuler~,
'enable_guest_view_limit' => q~Activer la limite de vue du sujet invitť?<br /><span class="small">Cochez cette option pour configurer un cookie afin de limiter le nombre de sujets que les invitťs peuvent consulter avant de les enregistrer. Vous pouvez dťfinir le nombre de vues de sujet et la maniŤre dont vous voulez qu'il se comporte ci-dessous.</span>~,
'guest_view_limit' => q~Limite de la vue du sujet invitť:<br /><span class="small">Dťfinir le nombre de sujets que les invitťs peuvent consulter avant d'Ítre invitťs ŗ s'enregistrer.</span>~,
'guest_view_limit_block' => q~EmpÍche les invitťs d'afficher les sujets aprŤs avoir atteint la limite de vue du sujet?<br /><span class="small">Cochez cette option pour empÍcher les invitťs d'afficher d'autres sujets aprŤs que la limite de la vue du sujet a ťtť atteint.<br />Ne pas cocher affichera un message amical en haut de l'affichage de la publication.</span>~,
'topichover' => q~Activer le survol des sujets sur l'index des messages~,
'staff_reason' => qq~Activer "Motif de l'ťdition" pour les membres du Staff~,
'user_reason' => qq~Activer "Motif de l'ťdition" pour les membres~,
'brdrss1' => q~RSS~,
'brdrss2' => q~Cochez cette case pour afficher le flux RSS de cette catťgorie dans l'index du forum.<br /><strong>Note:</strong> Uniquement si le flux RSS est activť.~,
'brdrss3' => q~Cochez cette case pour afficher le flux RSS de ce forum sur l'Index du forum.<br /><strong>Note:</strong> Uniquement pertinent si RSS est activť et si le forum n'est pas un forum de liaison externe.~,
'actions' => q~Actions~,
'remove_file' => q~Supprimer le fichier~,
'current_img' => q~Image actuelle~,
'remove_img' => q~Supprimer l'image~,
'for_template' => q~Pour le modŤle~,
'setsettings' => qq~ParamŤtres envoyťs~,
'maxadminlog' => qq~Le nombre maximum d'entrťes stockťes dans le journal d'administration.~,
'imp_email_check' => q~Activer la vťrification amťliorťe des courriels?<br /><span class="small">Vťrifie si le domaine de messagerie existe, si l'utilisateur est connu sur le serveur SMTP donnť, si le serveur SMTP (s) sont en ligne et valide, et si la boÓte aux lettres des utilisateurs est pleine. Ajoute ťgalement un deuxiŤme champ de courriel ŗ la page d'inscription pour vťrification.<br />Notez que ce paramŤtre nťcessite que Net :: DNS soit installť sur votre serveur.</span>~,
'zodiac' => q~Afficher les signes du zodiaque dans le profil s'affiche?~,
'no_imp_email_check' => qq~<br /><span class="important"> Amťlioration de la vťrification des courriels non disponible. Requiers Net::DNS~,
'p_ban' => q~Permanent~,
'expired' => q~Expirť~,
'expireon' => q~Expire le~,
);


%floodtxt = (
'1' => q~Centre de sťcuritť YaBB:~,
'2' => q~Activer le code de validation (CAPTCHA) lors de l'enregistrement et avoir oubliť le mot de passe?~,
'3' => q~Activer le code de validation (CAPTCHA) pour la publication d'un invitť, diffusion de message d'un invitť ŗ l'admin, message envoyť au modťrateur par un invitť, Invitť envoyant un sujet, Invitť ajoutant un ťvťnement au Calendrier ou membre envoyant des MP sans le nombre minimum de messages?~,
'5' => q~Nombre maximum de messages retournťs pour les publications rťcentes sur le forum et/ou par l'utilisateur?<br /><span class="small">- 1 dťsactivera les publications rťcentes.</span>~,
'5a' => q~Nombre maximum de messages retournťs pour les sujets rťcents sur le forum?<br /><span class="small">- 1 dťsactivera les sujets rťcents.</span>~,
'6' => q~Nombre maximum de messages retournťs pour une recherche?<br /><span class="small">- 1 dťsactivera la recherche.</span>~,
