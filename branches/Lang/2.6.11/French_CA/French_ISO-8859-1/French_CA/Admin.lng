%modulecheck = (
'1' => q~Vťrification du module~,
'2' => q~Vťrifie si tous les modules Perl utilisťs par YaBB sont correctement installťs.~,
'3' => q~Nom du module~,
'4' => q~Info~,
'5' => q~Informations fournies par le systŤme:~,
'6' => q~Installť~,
'7' => q~Certains modules ne sont pas installťs sur votre serveur.~,
'8' => qq~<strong>Si vous en avez vraiment besoin (lisez les infos), votre premier choix devrait Ítre de demander ŗ votre hŰte serveur d'installer les modules nťcessaires pour vous.</strong><br /><br />Si vous hťbergez votre propre serveur, ou si votre hŰte n'installera pas le module pour vous, voir <a href= "http://www.yabbforum.com/cgi-bin/codex/YaBB.pl?num=1225217016" target = "_ blank "> <strong>ce message dans le <em>Codex YaBB</em>pour de l'aide</strong></a>.</strong>~,
'Digest::MD5' => q~Utilisť pour le chiffrement de mot de passe.<br />Ce module est essentiel. Sans cela, YaBB ne fonctionnera pas.~,
'Time::HiRes' => q~Utilisť pour l'analyse comparative si le dťbogage est activť.<br />Si ce module n'est pas installť, l'heure de l'analyse comparative sera affichťe en secondes entiŤres et pas en secondes haute rťsolution. Sinon, vous n'avez pas besoin de ce module.~,
'Time::Local' => q~Utilisť pour convertir les chaÓnes de temps en horodatages.<br />Ce module est essentiel. Sans cela, YaBB ne fonctionnera pas toujours.~,
'File::Find' => q~Utilisť pour le tťlťchargement des avatars et des piŤces jointes.<br />Si ce module n'est pas installť et que ces fonctions sont activťes, vous recevrez un message d'erreur lorsque vous essaierez de tťlťcharger. Sinon, vous n'avez pas besoin de ce module.~,
'CGI' => q~Utilisť pour le chargement des avatars, piŤces jointes et diagnostiques~,
'Net::SMTP' => q~Utilisť pour envoyer des courriels via SMTP.<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriel via Net :: SMTP. Sinon, vous n'avez pas besoin de ce module.<br /><strong>Votre version</strong>:~,
'Net::SMTP::TLS' => q~Utilisť pour envoyer des courriel via SMTP :: TLS.<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriel via Net :: SMTP :: TLS . Sinon, vous n'avez pas besoin de ce module.~,
'Compress::Zlib' => q~Utilisť pour la fonction de sauvegarde et la compression de sortie du navigateur.<br />Ce module n'est nťcessaire que si vous n'avez pas d'autres mťthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de dťtails) et/ou Voulez-vous activer "Utiliser GZip-Compression?". Sinon, vous n'avez pas besoin de ce module.~,
'Compress::Bzip2' => q~Utilisť pour la fonction de sauvegarde.<br />Ce module n'est nťcessaire que si vous n'avez pas d'autres mťthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de dťtails). Sinon, vous n'avez pas besoin de ce module.~,
'Archive::Tar' => q~Utilisť pour la fonction de sauvegarde.<br />Ce module n'est nťcessaire que si vous n'avez pas d'autres mťthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de dťtails). Sinon, vous n'avez pas besoin de ce module.~,
'Archive::Zip' => q~Utilisť pour la fonction de sauvegarde.<br />Ce module n'est nťcessaire que si vous n'avez pas d'autres mťthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de dťtails). Sinon, vous n'avez pas besoin de ce module.~,
'MIME::Lite' => q~Utilisť pour envoyer des sauvegardes jointes ŗ un courriel.<br />Ce module n'est nťcessaire que si vous souhaitez obtenir le fichier de sauvegarde par courriel et non par tťlťchargement direct depuis le centre d'administration. . Sinon, vous n'avez pas besoin de ce module.~,
'LWP::UserAgent' => q~Utilisť par "GoogieSpell", notre vťrificateur d'orthographe.<br />Si ce module n'est pas installť, vous ne pouvez pas activer le vťrificateur d'orthographe. Sinon, vous n'avez pas besoin de ce module.~,
'HTTP::Request::Common' => q~Utilisť par "GoogieSpell", notre vťrificateur d'orthographe.<br />Si ce module n'est pas installť, vous ne pouvez pas activer le Vťrificateur d'orthographe. Sinon, vous n'avez pas besoin de ce module.~,
'Crypt::SSLeay' => q~Utilisť par "GoogieSpell", notre vťrificateur d'orthographe.<br />Si ce module n'est pas installť, vous ne pouvez pas activer le vťrificateur d'orthographe. Sinon, vous n'avez pas besoin de ce module.~,
'IO::Socket::INET' => q~Utilisť pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine" . Sinon, vous n'avez pas besoin de ce module.~,
'Digest::HMAC_MD5' => q~Utilisť pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
'Carp' => q~Utilisť pour envoyer des courriels via "YaBB SMTP Engine" et afficher des avertissements sťrieux sur le serveur.~,
'bytes' => q~Utilisť pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
'integer' => q~Utilisť pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nťcessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
'DateTime' =>
q~Requis par DateTime::TimeZone.<br />Ce module est requis seulement si vous dťsires avoir un fuseau horraire forum/utilisateur dans une zone autre que UTC.~,
'DateTime::TimeZone' => q~Utilisť pour obtenir les dťcalages de fuseau horaire de l'utilisateur et du forum en fonction du fuseau horaire rťel de l'utilisateur.<br />Ce module est nťcessaire si vous souhaitez que les fuseaux horaires du forum/utilisateur soient autres que UTC .<br /><span class="important"> Ce module doit Ítre tenu ŗ jour car il contient des donnťes de fuseau horaire sensibles au temps.~,
'DateTime::TimeZone2' => q~<br /><span class="important"> Ce module doit Ítre tenu ŗ jour car il contient des donnťes de fuseau horaire sensibles au temps. Vťrifiez avec votre hŰte serveur pour vous assurer que ce module est maintenu ŗ jour.</span><br /><b>Votre version</b>:~,
'URI::Escape' => qq~Utilisť par la fonction prťvisioner publication/message.<br />Ce module est essentiel. Sans cela, la fonction AperÁu ne fonctionnera pas.~,
'perlver' => q~Votre version Perl~,
'Net::DNS' => q~Utilisť par le vťrificateur de courrier ťlectronique amťliorť. Si ce module n'est pas installť, vous ne pouvez pas activer le vťrificateur de courrier ťlectronique amťliorť.~,
