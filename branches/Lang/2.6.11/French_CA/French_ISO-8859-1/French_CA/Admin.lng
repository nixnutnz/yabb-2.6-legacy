'9' => q~Transparence de l'image de validation?~,
'f' => q~Couleur du premier plan de l'image de validation (valeur hexadťcimale RVB)~,
's' => q~Couleur de l'image de validation (valeur hexadťcimale RVB)~,
'b' => q~Couleur de fond de l'image de validation (valeur hexadťcimale RVB)~,
'rnd' => q~Sťlectionnez si et comment vous voulez ajouter du bruit alťatoire ŗ votre fond d'image de validation~,
'style' => q~Sťlectionnez les caractŤres gťnťrťs dans le CAPTCHA<br /><span class="small">Gardez ŗ l'esprit que les majuscules et les minuscules peuvent rendre le CAPTCHA plus difficile ŗ lire.</span>~,
'lower' => q~Minuscules + Chiffres~,
'upper' => q~Majuscules + Chiffres~,
'all' => q~Majuscules et minuscules + Chiffres~,
'masterkey' => q~Dťfinir une clť de chiffrement<br /><span class="small">Une chaÓne de caractŤres alťatoire (&gt; 8 et &lt; 24 caractŤres de long)</span>~,
'rm0' => q~Aucun bruit alťatoire~,
'rm1' => q~En utilisant seulement la couleur de l'ombre~,
'rm2' => q~Utiliser uniquement la couleur de premier plan~,
'rm3' => q~Utilisation de la teinte et de la couleur de premier plan~,
'dis' => q~Niveau de l'assombrisage allťatoire du fond de CAPTCHA<br /><span class="small">Il est possible que le CAPTCHA devienne trŤs difficile ŗ lire dans certaines combinaisons de couleurs.</span>~,
'vpreview' => q~Prť visualisez votre code de validation<br /><span class="small">Cochez cette case aprŤs avoir cliquť sur "Enregistrer" pour appliquer les nouveaux paramŤtres</span>~,
'extra_chars_start' => q~Nombre de caractŤres supplťmentaires ŗ ajouter au dťbut du code de validation:~,
'extra_chars_end' => q~Nombre de caractŤres supplťmentaires ŗ ajouter ŗ la fin du code de validation:~,
'extra_chars_desc' => q~Cela ajoutera des caractŤres alťatoires qui n'ont pas besoin d'Ítre saisis par l'utilisateur et tromperont les spambots.<br />par exemple. XX<br /><span class="small">0 dťsactive</span>~,
);

