%admintxt = (
'1' => => q~Bienvenue dans votre centre d'administration "{yabb mbname}"~,
'2' => => q~Ceci est votre "Centre d'administration YaBB". Vous pouvez modifier vos prťfťrences de forum, modifier votre modŤle et effectuer des opťrations de maintenance sur votre forum ŗ partir d'ici. Soyez prudent avec ces fonctions.<br /><br />Veuillez lire le Quick-Guide ou reportez-vous aux informations dans la section Aide de votre forum avant de contacter toute forme de support. Si vous avez besoin d'aide, vous pouvez trouver des rťponses ŗ vos problŤmes sur le forum de soutien de YaBB ou sur le forum communautaire de chat et de support de YaBB.<br /><br />Merci d'utiliser YaBB.~,
'3' => => q~Informations de version~,
'4' => => q~Quoi de neuf chez YaBB?~,
'5' => => q~DerniŤres connexions:~,
'6' => => q~Crťdits~,
'7' => => q~Fichiers de configuration et de sauvegarde du convertisseur~,
'8' => => q~Lorsque vous avez testť votre forum et vťrifiť que tout a ťtť correctement converti, vous pouvez supprimer l'utilitaire de configuration et vos anciens fichiers de sauvegarde YaBB dans les dossiers du convertisseur (le cas ťchťant). Cela supprimera ťgalement les programmes de conversion afin qu'ils ne puissent plus Ítre exťcutťs.~,
'9' => => q~Supprimer les anciens fichiers de sauvegarde, l'installation et les utilitaires de conversion~,
'10' => => q~Anciens fichiers de sauvegarde supprimťs~,
'11' => => q~Vťrification dťtaillťe de la version~,
'15' => => q~Retour ŗ~,
'17' => => q~Afficher/Supprimer les membres~,
'17a' => => q~Ajouter un membre~,
'18' => => q~Modifier les groupes de membres~,
'18a' => => q~Modifier le groupe de membres~,
'18b' => => q~Ajouter un groupe de membres~,
'18c' => => q~Ajouter un groupe~,
'19' => => q~Envoyer vos membres par courriel~,
'20' => => q~Modifier les listes d'interdiction~,
'21' => => q~Dťfinir les noms rťservťs~,
'22' => => q~ContrŰles de maintenance~,
'23' => => q~Nettoyer le journal en ligne des utilisateurs~,
'24' => => q~Totaux de la table de recomptage~,
'25' => => q~Recompter les adhťsions~,
'26' => => q~Reconstruire la liste des membres~,
'27' => => q~Statistiques du forum~,
'28' => => q~Statistiques du forum~,
'29' => => q~Afficher le journal du forum~,
'32' => => q~Modifier un modŤle~,
'33' => => q~Retour au centre d'administration~,
'34' => => q~Le clic va s'effondrer~,
'35' => => q~Afficher les fichiers d'aide~,
'36' => => q~Visitez YaBBforum.com~,
