$contexthelplngver = 'YaBB 2.6.11 $Revision: 1002 $';

### Do not translate uppercase words in sharp brackets

%contextxt = (
'clicktip' => q~Clic droit pour l'aide~,
'url' => q~Insťrer un lien "URL":<br /><br />Sťlectionez l'URL: [SELECT]http://www.yabbforum.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [url]http://www.yabbforum.com[/url]<hr />insťrer un lien "Texte":<br /><br />sťlectionez l'URL <span class="under">et</span> le texte: [SELECT]http://www.yabbforum.com Forum YaBB[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [url=http://www.yabbforum.com]Forum YaBB[/url]<hr />La balise YaBBC [link] fonctionne de la mÍme maniŤre que la balise [url], a l'exception que la balise [link] ouvrira lorsque l'on clique sur un lien ce lien dans la fenÍtre actuelle, tandis que la balise [url] ouvrira ce lien dans une nouvelle fenÍtres. (il n'y a aucun bouton d'insertion pour la balise)~,
'ftp' => q~Insťrer un lien "FTP":<br /><br />Sťlectionez l'adresse FTP: [SELECT]ftp://ftpdom[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [ftp]ftp://ftpdom[/ftp]~,
'img' => q~Insťrer une Image:<br /><br />Sťlectionez le rťpertoire de l'image: [SELECT]http://repertoire/image.gif[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [img]http://imagedirectory/image.gif[/img]~,
'image' => q~Insťrer une Image:<br /><br />Sťlectionez le rťpertoire de l'image: [SELECT]http://repertoire/image.gif[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [img]http://imagedirectory/image.gif[/img]~,
'email2' => q~Insťrer un lien "Address courriel":<br /><br />Sťlectionez l'adresse courriel: [SELECT]monnom\@domaine.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [email]monnom\@domaine.com[/email]<hr />Insťrer un lien "texte" de courriel:<br /><br />Sťlectionez l'adresse courriel <span class="under">et</span> le texte: [SELECT]…crivez moi sur monnom\@domaine.com[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> …crivez voi sur [email=monnom\@domaine.com][/email]~,
'media' => q~Insťrer un fichier multimťdia:<br /><br />Sťlectionez l'URL du fichier multimťdia: [SELECT]http://www.votre-domaine.com/yabbchelp.swf[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [media]http://www.votre-domaine.com/yabbchelp.swf[/media]~,
'table' => q~Insťrer une table vide d'une cellule:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [table][tr][td][/td][/tr][/table]<hr />Incorporer un texte ou une image dans une cellule de table:<br /><br />Sťlectioner le texte ou une rťpertoire d'image: [SELECT]Bonjour le Monde[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [table][tr][td]Bonjour le Monde[/td][/tr][/table]~,
'tr' => q~Insťrer une rangťe d'une table:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [tr][/tr]~,
'td' => q~Insťrer une cellule d'une table::<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [td][/td]~,
'hr' => q~Insťrer une rŤgle horizontale:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [hr]~,
'tele' => q~Changer le texte ŗ tťlťtype:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [tt]Bonjour le monde[/tt] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <tt>Bonjour le monde</tt> bla bla~,
'teletype' => q~Changer le texte ŗ tťlťtype:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [tt]Bonjour le monde[/tt] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <tt>Bonjour le monde</tt> bla bla~,
'code' => q~Insťrer du code dans une boÓte:<br /><br />Sťlectionez le Code:<br /><br />[SELECT]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br /><br />[code]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/code]<br /><br /><strong>Rťsultat:</strong><br /><br /><strong>Code:</strong>[CODE]&lt\;table&gt\;<br />&nbsp\; &lt\;tr&gt\;&lt\;td&gt\;Bonjour le monde&lt\;/td&gt\;&lt\;/tr&gt\;<br />&lt\;/table&gt\;[/CODE]~,
'quote2' => q~Insťrer une citation dans une boÓte:<br /><br />Sťlectionez la citation: [SELECT] tre ou ne pas Ítre...[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [quote]To be or not to be...[/quote]<br /><br /><strong>Rťsultat:</strong><br /><br /><strong>Quote:</strong>[QUOTE]To be or not to be...[/QUOTE]~,
'edit' => q~Insťrer un message ťditť dans une boÓte:<br /><br />Sťlectionez le message ťditť: [SELECT]Attached new zip package.[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [edit]Attached new zip package.[/edit]<br /><br /><strong>Rťsultat:</strong><br /><br /><strong>Edited:</strong>[EDIT]Attached new zip package.[/EDIT]~,
'sup' => q~Changer le texte ŗ Exposant "Superscript":<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [sup]Bonjour le monde[/sup] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <sup>Bonjour le monde</sup> bla bla~,
'sub' => q~Changer le texte ŗ  indice "Subscript":<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [sub]Bonjour le monde[/sub] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <sub>Bonjour le monde</sub> bla bla~,
'list' => q~Insťrer une liste non ordonnťe avec un ťlťment:<br /><br />Sťlectionnez le texte de l'ťlťment de liste: [SELECT]Item 1[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br /><br />[list][*]Item 1<br />[/list]<br /><br />Pour ajouter plus d'ťlťments de liste, vous devez taper les balises ([*]) ŗ la main:<br /><br />[list][*]Item 1<br />[*]Item 2<br />[*]Item 3<br />[/list]<br /><br /><strong>Rťsultat:</strong><ul><li>Item 1</li><li>Item 2</li><li>Item 3</li></ul>Vous pouvez crťer deux ou trois listes de niveaux en incluant une liste dans une autre liste:<br /><br />[list][*]Item 1<br />[*]Item 2[list][*]Sous item 1<br />[*]Sous item 2<br />[/list][*]Item 3<br />[/list]<br /><br /><strong>Rťsultat:</strong><ul><li>Item 1</li><li>Item 2<ul><li>Sous item 1</li><li>Sous item 2</li></ul></li><li>Item 3</li></ul><hr />La balise YaBBC [olist][*][/olist] fonctionne de la mÍme maniŤre que la balise [list][*][/list]  mais crťera une liste ordonnťe avec des nombres au lieu de puces (il n'y a aucun bouton d'insertion pour les balises [olist]).~,
'me' => q~Insťrer votre nom (pseudonyme):<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> /me dits Bonjour le monde<br /><br /><strong>Rťsultat:</strong> [ME] dits Bonjour le monde<br />~,
'move' => q~Dťplacer un texte ou une image dans le message de droite ŗ gauche:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> Dťplacer les mots [move]Bonjour le monde[/move]<br /><br /><strong>Rťsultat:</strong><br />Dťplacer les mots [MOVE]Bonjour le monde[/MOVE]~,
'timestamp' => q~Insťrer un horodatage:<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> [timestamp=1121602762]<br /><br />Cette balise insťrera un horodatage dans le format des lecteurs (membres)\.~,
'bold' => q~Changer le texte en gras:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [b]Bonjour le monde[/b] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <strong>Bonjour le monde</strong> bla bla~,
'italicize' => q~Changer le texte en italique:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [i]Bonjour le monde[/i] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <em>Bonjour le monde</em> bla bla~,
'underline' => q~Souligner le texte:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [u]Bonjour le monde[/u] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <span class="under">Bonjour le monde</span> bla bla~,
'strike' => q~Barrť le texte:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [s]Bonjour le monde[/s] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla <s>Bonjour le monde</s> bla bla~,
'highlight' => q~Surligner le texte:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong> bla bla [highlight]Bonjour le monde[/highlight] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla [HIGHLIGHT]Bonjour le monde[/HIGHLIGHT] bla bla~,
'palette1' => q~Choisir la couleur du texte:<br /><br />Sťlectionez le texte: bla bla [SELECT]Bonjour le monde[/SELECT] bla bla<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]" et choisissez une des 228 couleurs prť ťtablies ou crťez votre propre balise de couleur\.<br /><br /><strong>Code YaBBC:</strong> bla bla [color=#ff0000]Bonjour le monde[/color] bla bla<br /><br /><strong>Rťsultat:</strong> bla bla [RED]Bonjour le monde[/RED] bla bla~,
'pre' => q~Insťrer du texte prťformatť:<br /><br />Sťlectionez le texte: [SELECT]Ce &nbsp\;texte est &nbsp\; &nbsp\;prťformatť[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong>[pre]This &nbsp\;text is &nbsp\; &nbsp\;preformatted[/pre]<br /><br /><strong>Rťsultat:</strong>[PRE]Ce  texte est    prťformattť[/PRE]~,
'left' => q~Alligner le texte par la gauche<br /><br />Sťlectionez le texte:<br />[SELECT]Ce texte<br />est alignť ŗ gauche[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[left]This text<br />is left aligned[/left]<br /><br /><strong>Rťsultat:</strong><br />[LEFT]Ce texte<br />est alignť ŗ gauche[/LEFT]~,
'center' => q~Centrer le texte:<br /><br />Sťlectionez le texte:<br />[SELECT]This text<br />est centrť[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[center]This text<br />is centered[/center]<br /><br /><strong>Rťsultat:</strong><br />[CENTER]Ce texte<br />est centrť[/CENTER]~,
'right' => q~Aligner le texte par la droite:<br /><br />Sťlectionez le texte:<br />[SELECT]Ce texte<br />est alignť ŗ droite[/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[right]This text<br />is right aligned[/right]<br /><br /><strong>Rťsultat:</strong><br />[RIGHT]Ce texte<br />est alignť ŗ droite[/RIGHT]~,
'noparse' => q~Ne pas interprťter:<br /><br />Sťlectionez le code YaBBC:<br />[SELECT][table][tr][td]Cette table n'est pas interprťtť[/td][/tr][/table][/SELECT]<br /><br />Cliquez sur le bouton [BUTTON] "[TITLE]":<br /><br /><strong>Code YaBBC:</strong><br />[noparse][table][tr][td]Cette table de seras pas interprťtťe[/td][/tr][/table][/noparse]<br /><br /><strong>Rťsultat:</strong><br />[table][tr][td]Cette table de seras pas interprťtťe[/td][/tr][/table]~,
);

1;
