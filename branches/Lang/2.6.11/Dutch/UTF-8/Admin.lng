%tsc_txt = (
'1' => q~Totale-Spam-Controle~,
'2' => q~SPAM Regel-Definitie~,
'3' => q~Formaat: [number][action];[spamrule]<br />[number] = aantal toegestane exemplaren.<br />[action]: \~ betekend gedeeltelijke match en = betekend volledige match.<br />[spamrule]: term of definitie van de tekst om naar te zoeken. Een Spamregel per regel, beperkte Perl regex toegestaan.<br /><br />Example: 0\~;www.p(.?)rn(.?).com~,
'4' => q~Filter instellingen op onderwerp en inhoud van forum berichten~,
'5' => q~Bewerk verplichte E_mail domeinen~,
);

%modulecheck = (
'1' => q~Module Check~,
'2' => q~Controleert, of alle Perl modules gebruikt door YaBB correct geïnstalleerd zijn.~,
'3' => q~Name of the Module~,
'4' => q~Info~,
'5' => q~Door hhet systeem verstrekte informatie:~,
'6' => q~Geïnstalleerd~,
'7' => q~Sommige modules zijn niet op uw server geïnstalleerd.~,
'8' => q~<b>Als een module installatie echt nodig ist (Lees de Info), moet uw eerste keuze zijn om uw server host te vragen de benodigde modules voor u te installeren.<br /><br />Als u uw eigen server host, of als uw host de module niet voor u wil installeren, zie <a href="http://www.yabbforum.com/cgi-bin/codex/YaBB.pl?num=1225217016" target="_blank"><b>deze post in de <i>YaBB Codex</i> voor hulp</b></a>.</b>~,
'Digest::MD5' => q~Gebruikt voor wachtwoord versleuteling.<br /> Deze module is essentieel, Zonder het, zal YaBB niet werken.~,
'Time::HiRes' => q~Gebruikt voor de benchmarking-tijd, als foutopsporing ingeschakeld is.<br />Als deze module niet geïnstalleerd is, wordt de benchmark-tijd niet weergegeven in hoge resolutie en volle seconden. Anders heeft u deze module niet nodig.~,
'Time::Local' => q~Gebruikte tijd tekenreeksen omzetten in tijdstempels.<br />Deze module is essentieel, zonder het zal YaBB niet altijd werken.~,
'File::Find' => q~Gebruikt voor het uploaden van avatar en bijlagen.<br />Als deze module niet geïnstalleerd is en deze functies zijn ingeschakeld, krijgt u een fout bericht wanneer u probeert te uploaden. Anders heeft u deze module niet nodig.~,
'CGI' => q~Gebruikt voor het uploaden avatar en bijlagen.<br />Als deze module niet geïnstalleerd is en deze functies zijn ingeschakeld, krijgt u een fout bericht wanneer u probeert te uploaden. Anders heeft u deze module niet nodig.~,
'Net::SMTP' => q~Gebruikt voor het verzenden van emails via SMTP.<br />Deze module is alleen nodig als u uw emails via Net::SMTP wilt verzenden. Anders heeft u deze module niet nodig.~,
'Net::SMTP::TLS' => q~Gebruikt voor het verzenden van emails via SMTP::TLS.<br />Deze module is alleen nodig als u uw emails via Net::SMTP wilt verzenden. Anders heeft u deze module niet nodig.~,
'Compress::Zlib' => q~Gebruikt voor de back-up functie en browser Output compressie.<br />Deze module is alleen nodig als u geen andere back-up methoden beschikbaar heeft (Zie de back-up functie voor meer informatie) en/of als u wilt inschakelen "Gebruik GZip-compressie". Anders heeft u deze module niet nodig.~,
'Compress::Bzip2' => q~Gebruikt voor de back-up functie.<br />Deze module is alleen nodig als u geen andere back-up methoden beschikbaar heeft (Zie de back-up functie voor meer informatie). Anders heeft u deze module niet nodig.~,
'Archive::Tar' => q~Gebruikt voor de back-up functie.<br />Deze module is alleen nodig als u geen andere back-up methoden beschikbaar heeft (Zie de back-up functie voor meer informatie). Anders heeft u deze module niet nodig.~,
'Archive::Zip' => q~Gebruikt voor de back-up functie.<br />Deze module is alleen nodig als u geen andere back-up methoden beschikbaar heeft (Zie de back-up functie voor meer informatie). Anders heeft u deze module niet nodig.~,
'MIME::Lite' => q~Gebruikt voor het verzenden van back-ups gekoppeld aan een e-mailbericht.<br />Deze module is alleen nodig als het back-up bestand per e-mail wilt krijgen en niet door directe download van het Admin Center. Anders heeft u deze module niet nodig.~,
'LWP::UserAgent' => q~Gebruikt door "GoogieSpell", onze Spelling Checker.<br />Als deze module niet is geïnstalleerd, kunt u de spellingcontrole niet inschakelen. Anders heeft u deze module niet nodig.~,
'HTTP::Request::Common' => q~Gebruikt door "GoogieSpell", onze Spelling Checker.<br />Als deze module niet is geïnstalleerd, kunt u de spellingcontrole niet inschakelen. Anders heeft u deze module niet nodig.~,
'Crypt::SSLeay' => q~Gebruikt door "GoogieSpell", onze Spelling Checker.<br />Als deze module niet is geïnstalleerd, kunt u de spellingcontrole niet inschakelen. Anders heeft u deze module niet nodig.~,
'IO::Socket::INET' => q~Gebruikt voor het verzenden van emails via "YaBB SMTP Engine".<br />Deze module is alleen nodig als u uw e-mails wilt verzenden via de \"YaBB SMTP Engine\". Anders heeft u deze module niet nodig.~,
'Digest::HMAC_MD5' => q~Gebruikt voor het verzenden van emails via "YaBB SMTP Engine".<br />Deze module is alleen nodig als u uw e-mails wilt verzenden via de \"YaBB SMTP Engine\". Anders heeft u deze module niet nodig.~,
'Carp' => q~Gebruikt voor het verzenden van e-mails via "YaBB SMTP Engine" en server ernstige waarschuwingen geeft.~,
'bytes' => q~Gebruikt voor het verzenden van e-mails via "YaBB SMTP Engine".<br />Deze module is alleen nodig als u uw e-mails wilt verzenden via de "YaBB SMTP Engine". Anders heeft u deze module niet nodig.~,
'integer' => q~Gebruikt voor het verzenden van e-mails via "YaBB SMTP Engine".<br />Deze module is alleen nodig als u uw e-mails wilt verzenden via de "YaBB SMTP Engine". Anders heeft u deze module niet nodig.~,
'DateTime' => q~Required by DateTime::TimeZone.<br />Deze module is nodig als u forum/gebruiker timezones ingesteld wilt hebben op iets anders dan UTC.~,
'DateTime::TimeZone' => q~Gebruikt om gebruikers en forum tijdzone verschuivingen gebasseerd op de gebruikers werkelijke tijdzone.<br />Deze module is nodig als u forum/gebruiker timezones ingesteld wilt hebben op iets anders dan UTC.<br /><span class="important">Deze Module moet worden bijgewerkt omdat het tijd gevoelige tijdzonegegevens bevat.~,
'DateTime::TimeZone2' => q~<br /><span class="important">Deze Module moet worden bijgewerkt omdat het tijd gevoelige tijdzonegegevens bevat. Controleer met uw server host om er zeker van te zijn dat deze module de huidige houdt.</span><br /><b>Uw versie</b>:~,
'URI::Escape' => q~Gebruikt door Post/Bericht Preview-functie.<br />Deze module is van essentieel belang. Zonder dat werkt de Preview-functie niet.~,
'perlver' => q~Uw Perl Versie~,
'Net::DNS' => q~Gebruikt door de verbeterde email-checker. Als deze module niet geïnstalleerd is, kunt u de verbeterde email-checker niet gebruiken.~,
'Mail::CheckUser' => q~Gebruikt door de verbeterde email-checker. Deze module wordt van YaBB geïnstalleerd.~,
);

