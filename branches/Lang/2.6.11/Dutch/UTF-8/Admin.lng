'697' => qq~Dit is een eenvoudig systeem, welke het logboekbestand analyseert. Het geeft een kort overzicht over verkeer, browser en besturingssysteem van $mbname bezoekers. De getallen tussen haakjes naast elk item zijn het aantal exemplaren van dat item in uw logboek.~,
'698' => qq~<br /><br />Het logboekbestand is in het moment op $ClickLogTime minuten ingesteld.~,
'698a' => q~<br /><br />U heeft momenteel het logboek systeem uitgeschakeld.~,
'699' => q~Gereserveerde namen verhinderen dat uw gebruikers deze naam als gebruikersnaam gebruiken of als schermnaam weergeven. Selecteer de gewenste opties onder, voordat u de instellingen opslaat.~,
'702' => q~Bij registratie willekeurig wachtwoord per E-mail verzenden?~,
'710' => q~Wachtwoord-sterktemeter zekerheidscontrole<br /><span class ="small">Hier kunt u instellen na hoeveel tekens de veiligheid lijn op het eerstvolgende hogere groepeerniveau springt. Standaard is <i>10,15,30,40</i>. <span style="color:red">Voeg alleen getallen en kommas in of u kunt in de problemen komen.</span><br />Ingesteld op <i>-1,-1,-1,-1</i> om de wachtwoord-sterkte-Meter-functie uit te schakelen. Dan wordt alleen weergegeven of het geselecteerde wachtwoord te kort of OK is.</span>~,
'711' => q~Wachtwoord-sterktemeter onveilige wachtwoorden <br /><span class ="small">Voer alle woorden of combinaties in die als "Onveilig wachtwoord" getoond zullen worden. De woorden moeten tussen "" staan en door komma's gescheiden worden. Voorbeeld:<br />"123456","abcdef","wachtwoord"</span>~,
'712' => q~Wachtwoord-sterktemeter minimum tekens <br /><span class ="small">Voer het minimum aantal tekens in die vereist zijn, zodat het wachtwoord niet als {te) kort beschouwd wordt.</span>~,
