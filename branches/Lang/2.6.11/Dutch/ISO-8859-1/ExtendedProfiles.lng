'hr_or_br' => 'Tussenstuk type',
'hr_or_br_description' => 'Selecteer als het tussenstuk getoond moet worden als &lt;hr&gt; or &lt;br&gt;',
'hr' => '&lt;hr&gt;',
'br' => '&lt;br&gt;',
'change_these_settings' => 'verander deze instellingen',
'page_admin' => 'Alleen de Admin kan bewerken, Toon het in \'Admin bewerkt\' pagina',
'page_edit' => 'Lid kan het bewerken, toon het in \'Profiel bewerken\' pagina',
'page_contact' => q~Lid kan het bewerken, toon het in 'Contact Informatie' pagina~,
'page_options' => q~Lid kan het bewerken, toon het in 'Opties' pagina~,
'page_im' => 'Lid kan het bewerken, toon het in \'IM Voorkeuren\' pagina',
'converter_title' => 'Oude uitgebreide profielvelden converteren',
'convlock' => 'Uitgebreide profiel Converter',
'convlock_desc' => qq~Het uitgebreide profielen conversieprogramma is al uitgevoerd. Proberen om het nog eens uit te voeren kan leiden tot schade aan uw bestanden.<br /><br />Om de uitgebreide profielen Converter nogmaals uit te voeren, verwijder het bestand "$vardir/Extended.lock," en bezoek deze pagina opnieuw.~,
'converter_description' => 'Hier kunt u uw oude \'uitgebreide profielen\' converteren naar YaBB 2.6.11. Voor u daar mee begint, overtuig u ervan dat de oude  \'Leden\' en \'Variables\ in de juiste converteer / mappen hebt. Vul de paden in de vakjes hieronder in. Druk vervolgens op de knop converteren. <b>Opmerking:</b> start converteren pas nadat uw normale ledengegevens reeds geconverteerd zijn. Deze converter zal de oude .ext-bestanden converteren naar de nieuwe Y2 bestandsindeling en het zal de oude informatie <i>extended_profiles_fields.txt</i> en <i>extended_profiles_order.txt</i> bestanden in Settings.pm.',
'converter_button' => 'Converteer Nu',
'cannot_open_file' => 'Kan bestand niet openen ',
'invalid_extension' => 'Uw afbeelding heeft een verboden extensie.',
'image' => 'Afbeelding',
'image_width' => 'Breedte',
'image_width_description' => 'Stel een waarde in als u de breedte van de afbeelding op een specifieke waarde wilt beperken. Laat leeg om limiet uit te schakelen.',
'image_height' => 'Hoogte',
'image_height_description' => 'Stel een waarde in als u de hoogte van de afbeelding op een specifieke waarde wilt beperken. Laat leeg om limiet uit te schakelen.',
'allowed_extensions' => 'Toegestane extensies',
'allowed_extensions_description' => 'Beperk dit veld voor specifieke bestandsextensies door het invoeren van een lijst van extensies gescheiden door spaties. E.g. \"jpg jpeg gif png bmp\". Laat leeg om limiet uit te schakelen.',
'converter_missing_vars' => 'Kan de Convert/variabelen-map die u heeft opgegeven niet openen. Zorg ervoor dat uw input correct is en dat de rechten juist zijn ingesteld (755 voor de mappen en 644 voor alle bestanden).',
'converter_missing_fields' => 'Bestand \'extended_profiles_fields.txt\' bestaat niet in de map die u hebt opgegeven',
'converter_missing_order' => 'Bestand \'extended_profiles_order.txt\' bestaat niet in de map die u hebt opgegeven',
'converter_succeeded' => 'Converteren geslaagd.',
'path_old_members_folder' => 'Pad naar uw oude \'leden\ map',
'path_old_variables_folder' => 'Pad naar uw oude \'variabelen\' map',
