$suomibackuplngver = 'YaBB 2.7.00 $Revision$';
@suomibackuplngmods = ();
if(@suomibackuplngmods){
    $suomibackuplngmods = 1;
}
if ( $action eq 'detailedversion' ) { return 1; }

$script_root = $ENV{'SCRIPT_FILENAME'};
if( ! $script_root ) {
    $script_root = $ENV{'PATH_TRANSLATED'};
}
($support_env_path = $script_root) =~ s~/\w+\.pl~~;

%backup_txt = (
'1' => 'YaBB varmuuskopio',
'2' => 'Et ole tallentanut varmuuskopiointiasetuksiasi! Sinun tulee tehdä tämä ennen kuin voit varmuuskopioida foorumiasi.',
'3' => 'Valitse varmuuskopioitavat hakemistot. Huomio: YaBB-hakemistojen sijainti tarkistetaan Paths.pl-tiedostosta.',
'4' => 'YaBB-hakemistot',
'5' => 'Valitse/Poista valinta kaikista',
'6' => 'Jos valitset kaikki, koko foorumisi varmuuskopioidaan (suositus).<br />Tämä voi aiheuttaa palautusongelmia todella suurilla foorumeilla. Tällöin on järkevämpää varmuuskopioida kaikki enemmän tai vähemmän staattiset (muuttumattomat) hakemistot erikseen ja Boards-, Members- ja Messages-hakemistot erikseen!',
'path1' => 'Tar- ja Zip-ohjelmien polku:',
'path2' => 'gzip- ja bzip2-ohjelmien polku (asettaa myös polun gzip-ohjelmalle Laajennetuissa asetuksissa):',
'path3' => 'Täytä polut <b>vain</b> jos YaBB ei automaattisesti löydä Tar-, Zip-, gzip-, ja bzip2-ohjelmia. Muuten jätä ylläolevat kohdat tyhjiksi.',

# Begin description of directories
# We don't translate directory names like Boards/.
