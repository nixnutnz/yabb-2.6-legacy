our $VERSION = '2.7.00';
$suomibookmarkslngbase = 1964;
##  Based on English Rev 1964 ##

$suomibookmarkslngver  = 'YaBB 2.7.00 $Revision$';
@suomibookmarkslngmods = ();
if (@suomibookmarkslngmods) {
    $suomibookmarkslngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

