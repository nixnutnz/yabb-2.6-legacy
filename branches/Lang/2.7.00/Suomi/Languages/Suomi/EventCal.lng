    '59'          => q~Lisää tapahtumakuvake~,
    '60'          => q~Poista tapahtumakuvake~,
    'error_image' => q~Ole hyvä ja valitse kuva tälle tapahtumakuvakkeelle.~,
    'error_desc'  => q~Ole hyvä ja anna kuvaus tälle tapahtumakuvakkeelle.~,
    'del'         => q~Poista vanhat tapahtumat~,
