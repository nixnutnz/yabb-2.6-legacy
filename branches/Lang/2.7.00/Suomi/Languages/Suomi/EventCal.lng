our $VERSION = '2.7.00';

$suomieventcallngver  = 'YaBB 2.7.00 $Revision: 1890 $';
@suomieventcallngmods = ();
if (@suomieventcallngmods) {
    $suomieventcallngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

