### Event Calendar Settings ###

%event_cal = (
    '1' => q~Tapahtumakalenterin Asetukset~,
    '3' => q~Näytä tapahtumakalenteri:~,
    '4' => q~Näytä &#39;Tapahtumakalenteri&#39;-painike YaBB-valikossa:~,
    '5' => q~Näytä syntymäpäivät kalenterissa/tapahtumat:~,
    '6' => q~Määritä kirjainten pituus jokaisesta tapahtumasta?~,
    '7' =>
q~Näyttää &#39;LUE LISÄÄ&#39;-linkin kirjoitetuissa tapahtumissa<br />(0 = ei käytössä)~,
    '8'  => q~Korosta nykyinen päivä tällä värillä minikalenterissa~,
    '9'  => q~Ota käyttöön &#39;Tapahtuma-vieritys&#39;-toiminto~,
    '10' => q~Erittäin hyödyllinen, jos sinulla on useita tapahtumia.~,
    '11' => q~Pois päältä~,
    '12' => q~Automaattinen vieritys~,
    '13' => q~Manuaalinen vieritys~,
    '14' => q~Valitse mitkä käyttäjäryhmät voivat lisää/muokata tapahtumia:~,
    '15' =>
q~Jos ET tee mitään valintaa, sallit kaikkien ryhmien, käyttäjien ja vieraiden lisätä/muokata tapahtumia<br /><br />{yabb admin_txt14}~,
    '16' => q~Salli näiden käyttäjien lisätä tapahtumia~,
    '17' =>
q~Luettele useat käyttäjät pilkulla erottaen &#39;käyttäjä1,käyttäjä2&#39;.~,
    '18' => q~Salli käyttäjien lisätä &#39;Yksityisiä tapahtumia&#39;?~,
    '19' =>
q~Jos ei valittu, vain yleiset valvojat ja ylläpitäjä voivat lisätä &#39;Yksityisiä tapahtumia&#39;~,
    '20' =>
q~Ota käyttöön näytä &#39;Tapahtumat&#39; (Tapahtuma-vieritys) alueluettelosivulla?~,
    '21' => q~Yleiset Asetukset~,
    '22' => q~Tapahtuma-asetukset~,
    '23' => q~Pääsyasetukset~,
    '24' => q~Näytä "Poista käytöstä käyttäjänimi-linkki"-valintaruutu:~,
    '26' => q~Kalenterin tapahtumakuvakeasetukset~,
    '27' => q~Valitse kuva~,
    '28' => q~Kuvaus~,
    '29' => q~Kuva~,
    '30' => q~Lisää uusia kalenterin tapahtumakuvakkeita täällä~,
    '31' => q~Tallenna tapahtumakalenterin asetukset~,
    '32' => q~Tallenna tapahtumakuvakeasetukset~,
    '33' =>
q~Tämä osa sallii yksilöidä kalenterisi tapahtumat käyttämällä sinun omia kuvakkeita.<br />Kuvat näyttävät parhaimmilta, jos ne eivät ole isompia kuin 25x25 pikseliä.<br />Sallitut tiedostotyypit: png jpg jpeg gif<br />Suurin tiedostokoko: 100kt~,
    '34' =>
      q~Luettele tulevat tapahtumat __ päivälle tapahtumakalenterin vieressä~,
    '35'  => q~(0 = Kaikki tapahtumat nykyiselle kuukaudelle)~,
    '36'  => q~Ensimmäinen päivä viikossa (minikalenteri)?~,
    '37'  => q~(ei valittu = maanantai / valittu = sunnuntai)~,
    '42'  => q~Näytä luettelo käyttäjien syntymäpäivistä:~,
    '42a' => q~Näytä horoskooppimerkit syntymäpäiväluettelossa?~,
    '43'  => q~Älä näytä &#39;Tapahtumakuvakkeita&#39; minikalenterissa?~,
    '44'  => q~Käytä ryhmän värejä näyttäessä käyttäjien linkkejä?~,
    '44a' =>
      q~Apply group colors when displaying member links in the Birthday List?~,
    '45' => q~Valitsemalla tämän valinnan käyttää enemmän foorumin resursseja.~,
    '48' => q~Näytä &#39;Syntymäpäiväluettelo&#39;-painike YaBB-valikossa:~,
    '49' => q~Syntymäpäiväluettelon asetukset~,
    '50' => q~Näytä syntymäpäivät:~,
    '52' =>
q~Poista vanhat tapahtumat<br /><span class="small">Valitse poistaaksesi vanhemmat tapahtumat kuin nykyinen päivä, kun uusi tapahtuma lisätään.</span>~,
