##  Based on English Rev 1920 ##
our $VERSION = '2.7.00';

$suomierrorlngver  = 'YaBB 2.7.00 $Revision$';
@suomierrorlngmods = ();
if (@suomierrorlngmods) {
    $suomierrorlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%error_txt = (
## General Errors ##
    'error_occurred'  => q~Tapahtui virhe!~,
    'untrapped'       => q~Selvittämätön virhe~,
    'cannot_open'     => q~Ei voi avata~,
    'bad data'        => q~File with bad data~,
    'cannot_open_dir' => q~Ei voi avata hakemistoa~,
    'cannot_open_language' =>
      q~Tarvittavaa kielitiedostoa ei löydy. Ota yhteys ylläpitäjään.~,
    'cannot_delete' => q~Ei voi poistaa~,
    'not_completed' =>
      q~Tapahtui virhe eikä toimintoa voi suorittaa loppuun. Pahoittelemme.~,
    'not_logged_in' =>
q~Suorittaaksesi tämän toiminnon, on sinun oltava kirjautuneena. Mikäli sinulla ei ole käyttäjätunnusta, rekisteröidy.~,
    'logged_in_already' => q~Olet jo kirjautunut käyttäjätunnuksella: ~,
    'no_access'         => q~Käyttöoikeus puuttuu.~,
    'not_found'         => q~Tavoittelemaasi tietoa ei löydy.~,
    'not_allowed'       => q~Et voi suorittaa tätä toimintoa~,
    'only_numbers_allowed' =>
      q~Tähän kenttään voi syöttää ainoastaan numeroita~,
    'user_not_exist' => q~Käyttäjää ei ole.~,
    'members_only' =>
q~Pahoittelemme, vain rekisteröityneillä käyttäjillä on tarvittava käyttöoikeus!~,
    'email_no_access' =>
      q~Tavoittelemasi sähköposti on käyttöoikeuksiesi ulkopuolella!~,
    'no_subject'        => q~Viestisi tarvitsee otsikon.~,
    'no_message'        => q~Viestisi on tyhjä.~,
    'no_recipient'      => q~Vastaanottajaa ei ole määritetty.~,
    'no_email'          => q~Sähköpostiosoitetta ei ole määritetty.~,
    'no_name'           => q~Nimi- kenttä on tyhjä.~,
    'no_ip'             => q~IP-osoitetta ei löytynyt, muuta {yabb user_ip}~,
    'no_username'       => q~Käyttäjätunnusta ei ole määritetty.~,
    'no_password'       => q~Salasanakenttä on tyhjä~,
    'no_action'         => q~Toimintoa ei määritetty mutta~,
    'no_info'           => q~Kyseinen osoite on tyhjä~,
    'password_mismatch' => q~Salasanat eivät täsmää!~,
    'bad_credentials' =>
q~Käyttäjätunnus ja salasana eivät täsmää<br />Joko antamasi käyttäjätunnus tai salasana on väärä.~,
    'invalid_character' => q~Epäkelpo merkki havaittu~,
    'invalid_email'     => q~Anna oikea sähköpostiosoite.~,
    'invalid_picture'   => q~Aihealueen kuvakekenttä sisältää väärää tietoa.~,
    'no_secret_answer'  => q~Sinun on annettava kysymykseen sopiva vastaus.~,
    'no_verification_code' => q~Varmistuskoodia ei syötetty.~,
    'wrong_verification_code' =>
q~Syöttämäsi varmistuskoodi ei täsmää kuvan kanssa. Ole hyvä ja palaa takaisin ja päivitä näkymä (F5 useimmilla selaimilla) ja yritä uudelleen.~,
    'invalid_verification_code' =>
q~Varmistuskoodi sisältää kiellettyä merkkejä. Vain kirjaimet a-z ja numerot 0-9 ovat sallittuja.~,
    'form_spoofing' =>
      q~<b>VAROITUS!!</b> Lomakkeen väärennysyritys havaittu IP-osoitteesta:~,
    'post_flooding' =>
      q~Viimeisimmän POST komennon käyttö tuli IP-osoitteestasi aiemmin kuin~,
    'denial_of_service' => q~Viimeisin POST komento aiheutti virheen: ~,
    'speed_alert' =>
q~Varoitus, näin nopea viestien lähettäminen tulkitaan roskaviestien lähettämiseksi!<br />Sinulla on <b>{yabb spam_hits_left_count}</b> lähetysyritystä jäljellä, joiden jälkeen foorumin käyttö estetään sinulta!~,
    'tsc_alert' =>
q~Varoitus, jokin käyttämäsi lomakkeen kentiestä sisältää roskaviestiksi tulkittavaa tekstiä!<br />Sinulla on <b>{yabb spam_hits_left_count}</b> lähetysyritystä jäljellä, joiden jälkeen foorumin käyttö estetään sinulta!~,
    'speedpostban' =>
q~Viestin lähettäminen on toistaiseksi estetty sinulta!<br />Esto poistuu seuraavan ajan kuluessa <b>{yabb detention_left}</b> sekuntia!~,
    'truncation_error' =>
q~Varmista että "Tiedoston katkaisu" on käytössä foorumisi asetuksissa.<br />\$faketruncation = 1;<br />Tiedostoa ei voitu katkaista.~,
    'referer_violation' =>
q~Pyydettyä toimintoa ei voi suorittaa foorumin domainin ulkopuolelta! <br />Toiminto oli: ~,
    'egg' => q~Itsetuhon ajastus käynnistetty!<br />~,
    'domain_not_allowed' =>
q~Käyttämäsi domain ei ole sallittu rekisteröitymiseen, vieraana viestin lähettämiseen eikä sitä voi käyttää myöhemmin profiilissa:~,
    'module_missing' =>
      q~Tarvittava moduuli tai ominaisuus ei ole palvelimella saatavilla!~,
    'low_diskspace' =>
q~Tarvittava levytila on alle {yabb low_disk_alert} bytes. Foorumi siirtyi automaattisesti huoltotilaan jotta sen tiedostot säilyisivät. Ole hyvä ja ilmoita ylläpitäjälle asiasta.!~,
    'invalid_key' =>
q~Avain ei toimi!<br />Sen tulee olla merkkijono, jossa on merkkejä 8-24 kpl!~,
    'wrong_pass' => q~Syöttämäsi salasana ei ole oikea~,
    'corrupt_member_file' =>
q~Jäsentietotiedosto on korruptoitunut. Ole yhteydessä ylläpitäjään tästä virheestä!~,
    'no_admin_passwrd' =>
q~Sinun täytyy täyttää oikea ylläpitäjän salasana päästääksesi ylläpitokeskukseen.~,
    'default_password' =>
qq~Käytät vielä YaBB-asennuksen oletussalasanaa. Ole hyvä ja kirjaudu <a href="$scripturl?action=myprofile;username=$username">Käyttäjäprofiiliin</a> ja muuta salasanasi turvallisemmaksi.~,
    'missingvars' =>
q~Jotain pahaa tapahtui. Ota yhteys foorumin ylläpitoon ja kerro mitä olit tekemässä kun tämä virhe tapahtui.~,

## BoardIndex ##
    'collapse_no_member' =>
q~Voidaksesi käyttää kategorian supistus- tai laajennustoimintoa, sinun tulee olla kirjautuneena sisään!~,
    'collapse_invalid_state' =>
q~Antamasi tapahtuma on väärä, ole hyvä ja palaa takaisin yrittääksesi uudelleen.~,
    'collapse_no_usercat' =>
q~Käyttäjän omaa kategoria- tiedostoa ei löydy. Ole hyvä ja palaa takaisin yrittääksesi uudelleen päivittämällä näkymä.<br/>Mikäli saat tämän virheilmoituksen uudelleen, ota yhteyttä ylläpitäjään.~,

## Guardian ##
    'proxy_reason' =>
      q~Yhteydenotto foorumiin välityspalvelimen kautta kielletty!~,
    'referer_reason' => q~Pääsy foorumille äskeisestä osoitteesta on estetty!~,
    'harvester_reason' => q~Tältä kerääjältä on foorumille pääsy kielletty!~,
    'request_reason' => q~Haluamasi Request Methodin käyttö ei ole sallittua!~,
    'string_reason'  => q~Käyttämäsi osoite sisältää kiellettyjä sanoja!~,
    'clike_reason' =>
      q~CLIKEn käyttäminen on turhaa, koska foorumi ei käytä MySQL:ää!~,
    'union_reason' =>
      q~UNIONin käyttäminen on turhaa, koska foorumi ei käytä MySQL:ää!~,
    'script_reason' =>
q~Käyttämässäsi URLissa tai lomakkeessa havaittiin skriptin osa, tämä on kiellettyä!~,

## InstantMessage ##
    'im_deleted' => q~Vastaanottaja on jo lukenut viestin eikä sitä poistettu!~,
    'im_deleted_multi' =>
q~Vähintään yksi vastaanottaja on jo lukenut viestin joten sitä ei poistettu!~,
    'im_members_only' =>
      q~Yksityisviestien käyttö on tarkoitettu rekisteröityneille käyttäjille~,
    'im_low_postcount' =>
q~Yksityisviestien käyttäminen on sallittu vasta kun foorumin viestiesi määrä on suurempi kuin {yabb numposts}!~,
    'im_spam_alert' =>
q~Et voi lähettää viestiä noin monelle käyttäjälle yhtäaikaa. Se voidaan tulkita roskaviestien lähettämiseksi.~,
    'im_bad_users' =>
q~Viestin lähettäminen kaikille vastaanottajille ei onnistunut.<br />Antamasi käyttäjätunnus on joko virheellinen tai he ovat estäneet viestien lähettämisen sinulta: ~,
    'cannot_find_draftmess' => q~Luonnosta ei löydy.~,
    'im_folder_exists'      => q~Tämän niminen hakemisto on jo olemassa.~,

## LogInOut ##
    'not_activated' =>
q~Tunnustasi ei ole vielä aktivoitu<br />Ole hyvä ja aktivoi se napsauttamalla linkkiä, joka löytyy saamastasi sähköpostista!~,
    'time_out' =>
q~Et aktivoinut tunnustasi {yabb preregspan} tunnin kuluessa!<br />Ennakkorekisteröintisi on näin ollen epäonnistunut!<br />Ole hyvä ja yritä uudelleen!~,
    'wrong_code' => q~Aktivointitunnisteesi on väärä!~,
    'admin_login_only' =>
q~Vain ylläpitäjä voi lisätä käyttäjiä, koska foorumimme on huoltotilassa.<br />Ole hyvä ja yritä myöhemmin uudelleen. Kiitos!~,
    'wrong_id' => q~Väärä tunnus, ole hyvä ja yritä uudelleen.~,

## Mailer ##
    'net_fatal'    => q~Vakava Net::SMTP virhe~,
    'smtp_error'   => q~SMTP virhe~,
    'smtp_unavail' => q~SMTP yhteyttä ei voida muodostaa~,

## Post/ModifyMessage/Poll ##
    'topic_locked' =>
      q~Tämä aihe on lukittu etkä voi muokata tai lisätä viestejä.~,
    'time_locked' => q~Foorumin ylläpitäjä on asettanut tämän aikarajan ~,
    'change_not_allowed' => q~Et voi muokata tätä viestiä~,
    'delete_not_allowed' => q~Et voi poistaa tätä viestiä!~,
    'split_splice_not_allowed' =>
q~Et voi jakaa tai liittää tätä viestiä. Vain ylläpitäjä tai valvoja voi tehdä sen.~,
    'no_perm_post'   => q~Et voi lisätä viestejä tälle alueelle~,
    'no_perm_reply'  => q~Et voi vastata viesteihin tällä alueella~,
    'no_perm_poll'   => q~Et voi lisätä äänestyksiä tällä alueella~,
    'no_perm_att'    => q~Et voi liittää tiedostoja viesteihn tällä alueella~,
    'no_board_slash' => q~/ merkin käyttö ei ole mahdollista~,
    'no_cat_slash'   => q~/ merkin käyttö ei ole mahdollista~,
    'no_board_backslash' => q~\ merkin käyttö ei ole mahdollista~,
    'no_cat_backslash'   => q~\ merkin käyttö ei ole mahdollista~,
    'no_board_topic'     => q~Tätä aihetta ei ole tällä alueella.~,
    'bad_postnumber'     => q~Virheellinen viestin tunnistenumero~,
    'file_overwrite' =>
q~Tällä nimellä oleva tiedosto löytyy jo. Ole hyvä ja nimeä tiedostosi uudelleen.~,
    'file_not_open' =>
q~Ei voi avata uutta tiedostoa, ole hyvä ja tarkista että sinulla on oikeat polut ja CHMODit.~,
    'invalid_format' => q~Virheellinen tiedostomuoto. Sallittuja ovat~,
    'file_too_big'   => q~Liitteesi on liian suuri. Ylitys on noin ~,
    'dir_full' =>
      q~Tämä liite aiheuttaa liitehakemiston maksimikoon ylittymisen noin ~,
    'file_not_uploaded' => q~Tiedostoa ei voi ladata~,
    'useless_post' =>
q~Pelkkien välilyöntien ja rivinvaihtojen käyttäminen viestissä ei ole mahdollista!~,
    'no_question'           => q~Ole hyvä ja lisää äänestyksesi kysymys.~,
    'no_options'            => q~Anna vähintään kaksi vastausvaihtoehtoa.~,
    'poll_not_found'        => q~Äänestystä ei löytynyt.~,
    'no_vote_option'        => q~Unohdit valita vastausvaihtoehdon!~,
    'locked_poll_no_delete' => q~Äänestys on lukittu, ääntäsi ei voi poistaa.~,
    'locked_poll_no_count' =>
      q~Äänestys on lukittu, ääntäsi ei lasketa mukaan tuloksiin.~,
    'ip_guest_used' =>
      q~Tästä IP-osoitteesta on jo osallistuttu tähän äänestykseen.~,
    'ip_member_used' =>
      q~Tästä IP-osoitteesta on jo osallistuttu tähän äänestykseen~,
    'voted_already' => q~Olet jo osallistunut tähän äänestykseen~,
    'guest_taken' =>
q~Käyttäjätunnus tai sähköpostiosoite on jo käytössä.<br />Kyseessä oleva tunnus tai sähköpostiosoite on: ~,
    'quote_too_long' =>
q~Viesti jota yritit tallentaa, on liian pitkä. Ole hyvä ja lyhennä sitä.~,
    'no_links_allowed' =>
q~Pahoittelemme, mutta et voi tallentaa viestejä joissa on linkkejä tai kuvia ennen kuin kokonaisviestimääräsi on vähintään {yabb minlinkpost}.~,
    'no_glinks_allowed' =>
q~Sorry, guests are not allowed to post messages containing active links to websites or images.~,
    'no_siglinks_allowed' =>
q~Pahoittelemme, mutta et voi luoda allekirjoitusta, jossa on linkkejä sivustoihin tai kuvia ennen kuin kokonaisviestimääräsi on vähintään {yabb minlinksig}.~,
    'attach_name_blocked' =>
      q~Liitteesi nimi sisältää sanan, jota ei sallita tällä foorumilla.~,
    'attach_file_blocked' =>
      q~Pahoittelemme, et voi lähettää liitettä tällä nimellä.~,
    'rename' =>
q~Sorry but this file needs to be renamed with ASCII characters before it can be uploaded.~,

