$yabbtags{'newmemberemail'} = q~displayname username userip useremail~;
$emaildesc{'newmemberemail'} =
  q~Uudesta käyttäjästä ylläpitoa muistuttava viesti~;
$newmemberemail = q~Uusi käyttäjä on rekisteröitynyt foorumille!

Käyttäjätunnus: {yabb displayname}
Käyttäjänimi: {yabb username}
IP-osoite: {yabb userip}
Sähköpostiosoite: {yabb useremail}

Uuden käyttäjän rekisteröinnin tarkastamiseksi kirjaudu foorumille ja napauta alla olevaa linkkiä.
{yabb adminurl}?action=view_reglog

Jos linkki ei toimi (tai käytät selainpohjaista sähköpostiohjelmaa) kopioi linkki osoiteriville itse.

Tarkastaaksesi uuden käyttäjän profiilin, kirjaudu foorumille.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'passwordreminderemail'} =
  q~displayname mbname remindercode cryptusername~;
$emaildesc{'passwordreminderemail'} = q~Salasanan palautusviesti~;
$passwordreminderemail = q~Hei, {yabb displayname},

Tätä toimintoa käytettiin seuraavalla foorumilla: {yabb mbname}. Mikäli sen teki joku muu, ole hyvä äläkä välitä tästä viestistä.

Jos pyysit uutta salasanaa, ole hyvä ja siirry osoitteeseen <a href="{yabb scripturl}?action=resetpass&ID={yabb remindercode}&user={yabb cryptusername}">{yabb scripturl}?action=resetpass&ID={yabb remindercode}&user={yabb cryptusername}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'boardnewtopicnotificationemail'} = q~num subject tmessage tauthor~;
$emaildesc{'boardnewtopicnotificationemail'} =
  q~Ilmoitus uudesta aiheesta (aihealuetason ilmoitukset)~;
$boardnewtopicnotificationemail =
q~Uusi aihe, "{yabb subject}", jonka kirjoitti {yabb tauthor}, on luettavissa aihealueella josta olet tilannut ilmoitukset.

########################################

{yabb tmessage}

########################################

Tarkista aihe osoitteessa <a href="{yabb scripturl}?num={yabb num}">{yabb scripturl}?num={yabb num}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'boardnotificationemail'} = q~num start subject tmessage tauthor~;
$emaildesc{'boardnotificationemail'} =
q~Ilmoitus uudesta viestistä olemassa olevassa aiheessa (aihealuetason ilmoitukset)~;
$boardnotificationemail =
q~Aiheeseen, "{yabb subject}", joka sijaitsee seuraamallasi aihealueella, on vastannut käyttäjä {yabb tauthor}.

########################################

{yabb tmessage}

########################################

Tarkista uusi viesti osoitteessa <a href="{yabb scripturl}?num={yabb num}/{yabb start}">{yabb scripturl}?num={yabb num}/{yabb start}</a>

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'topicnotificationemail'} = q~num subject start tmessage tauthor~;
$emaildesc{'topicnotificationemail'} =
  q~Ilmoitus vanhan aiheen uudesta viestistä~;
$topicnotificationemail =
q~Seuraamaasi aiheeseen, "{yabb subject}", on vastannut käyttäjä {yabb tauthor}.

########################################

{yabb tmessage}

########################################

Tarkista uusi viesti osoitteessa <a href="{yabb scripturl}?num={yabb num}/{yabb start}">{yabb scripturl}?num={yabb num}/{yabb start}</a>

Saat seuraavan ilmoituksen uudesta viestistä vasta kun olet käynyt tarkistamassa aiheen.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'profilenewpasswordemail'}  = q~displayname password~;
$emaildesc{'profilenewpasswordemail'} = q~Ilmoitus salasanan muuttamisesta~;
$profilenewpasswordemail              = q~Hei, {yabb displayname},

Salasanasi on vaihdettu. Uusi salasanasi on {yabb password}.

Voit vaihtaa sen uudelleen oman käyttäjäprofiilisi kautta.

Terveisin,
Ylläpito
{yabb mbname}~;

$yabbtags{'sendtopicemail'}  = q~toname subject displayname num~;
$emaildesc{'sendtopicemail'} = q~Aiheen ilmoittamisesta kaverille~;
$sendtopicemail              = q~Hei {yabb toname},

Luulen että haluaisit nähdä tämän aiheen, "{yabb subject}", löydät sen täältä: {yabb mbname}. 
Nähdäksesi aiheen, ole hyvä ja napsauta allaolevaa linkkiä:

<a href="{yabb scripturl}?num={yabb num}">{yabb scripturl}?num={yabb num}</a>

Terveisin,
{yabb displayname}~;

$yabbtags{'privatemessagenotificationemail'} = q~sender subject message~;
$emaildesc{'privatemessagenotificationemail'} =
  q~The Personal Message Notification Email~;
$privatemessagenotificationemail =
  q~{yabb sender} lähetti sinulle yksityisviestin.

Aihe: {yabb subject}
Viesti: {yabb message}
{yabb attachments}

Löydät viestin omien yksityisviestiesi saapuneet-kansiosta {yabb mbname}\: <a href="{yabb scripturl}">{yabb scripturl}</a>~;

## for online alert pms.
%online_alert = (
    newnotify   => q~Uusi viesti!~,
    replynotify => q~Uusi vastaus!~,
);

$yabbtags{'replyguestmail'} = q~sender email sendto date subject message~;
$emaildesc{'replyguestmail'} =
  q~Vieraiden ylläpidolle lähettämän viestin sähköpostitekstit~;
$replyguestmail = q~Hyvä {yabb sender},

Terveisin,
Ylläpito
{yabb mbname}
<a href="{yabb scripturl}">{yabb scripturl}</a>

-----------------------------
----- Original Message -----
From: "{yabb sender}" <{yabb email}>
To: "{yabb sendto}", <{yabb scripturl}>
Sent: {yabb date}
Subject: {yabb subject}

{yabb message}
~;

$yabbtags{'deleteduseremail'}  = q~displayname~;
$emaildesc{'deleteduseremail'} = q~Ilmoitus tunnuksen poistamisesta~;
$deletedusersybject            = q~Tunnuksesi on poistettu~;
$deleteduseremail              = q~Hei, {yabb displayname}!

{yabb mbname} käyttäjätunnuksesi on nyt poistettu eikä sitä voi enää käyttää!

Terveisin,
Ylläpito
{yabb mbname}
<a href="{yabb scripturl}">{yabb scripturl}</a>
~;

$yabbtags{'banneduseremail'}  = q~displayname~;
$emaildesc{'banneduseremail'} = q~The Banned User Notification E-mail~;
$bannedusersybject            = q~Your account banned on~;
$banneduseremail              = q~Hello, {yabb displayname}:

You have been banned from {yabb mbname} {yabb ban_time} by {yabb banner}{yabb ban_reason}.

Regards,
The {yabb mbname} team
<a href="{yabb scripturl}">{yabb scripturl}</a>
~;

$yabbtags{'suspendeduseremail'}  = q~displayname~;
$emaildesc{'suspendeduseremail'} = q~The Suspended User Notification E-mail~;
$suspendusersybject              = q~Your account suspended on~;
$suspendeduseremail              = q~Hello, {yabb displayname}:

Your account on {yabb mbname} has been suspended {yabb ban_time} by {yabb banner}{yabb ban_reason}.

Regards,
The {yabb mbname} team
<a href="{yabb scripturl}">{yabb scripturl}</a>
~;

1;
