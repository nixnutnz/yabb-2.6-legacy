'wrong_char' => 'Tämä merkki ei ole sallittu salasanassa',
'nodebug' => 'Älä käytä debuggausta',
'alldebug' => 'Käytä debuggausta - kaikki käyttäjät näkevät tiedot',
'admindebug' => 'Käytä debuggausta - vain ylläpitäjät näkevät tiedot',
'loadtime' => 'Näytä vain sivun latausaika - kaikki näkevät tiedon',
'show_ip_admin' => 'Näytä foorumin etusivulla kaikkien käyttäjien IP-osoite vain ylläpitäjille',
'show_ip_gmod' => 'Näytä foorumin etusivulla kaikkien käyttäjien IP-osoite yleisille valvojille',
'show_ip_fmod' => 'Näytä IP-osoite alueindeksin linjoilla-luettelossa kaikille linjoilla oleville jäsenille ja vieraille foorumin moderaattoreille?',
'guestmedia' => 'Piilota media-tiedostot ja linkit vierailta?',
'guestlang' => 'Salli vieraiden valita haluamansa käyttökieli?',
'checkspace' => q~Ottamala käyttöön tämän sallii sinun asettaa useita rajoja vapaan tilan tarkistukseen. Vapaan tilan tarkistus on ensisijaisesti Linux-toiminto eikä välttämättä toimi oikein Windows/IIS-palvelimilla. Vapaa tila -toiminto voi palauttaa virheellisiä tietoja, jos käytetään jaettu palvelin -palveluissa.~,
'checkspace2' => q~ (Jos Vapaa levytilatoiminto -työkalusivu ei lataannu, palvemimesi <b>ei tue niitä toimintoja</b>.)~,
'checkspclabel' => q~Lisäasetukset - Vapaa levytila -toiminnot~,
'quota' => '<i>quota</i>: Tämä kayttaa linux-konsolin \'quota\'-komentoa vapaan tilan tarkistukseen. Tämä on suositeltu tapa tarkistaa tila. Valintaruutu on pois käytössä mikäli palvelimella ei tätä tue.<br /><span class="small">Mikäli vapaana oleva levytila putoaa alle 100&thinsp;000 tavuun (100 KB), foorumi siirtyy automaattisesti huoltotilaan jotta tietoja ei häviäisi.<br />Muistutus: Vain ylläpitäjät voivat päästä foorumiin huoltotilan aikana.</span>',
'quota_value' => '<i>quota</i>: Valitse tiedostojärjestemä jossa foorumisi sijaitsee:<br /><span class="small">Oikea tiedostojärjestelmä pitäisi olla esivalittuna jos \'quota\' ei ollut aiemmin käytössä.</span>',
'quotahostuser' => '<i>quota</i>: Käyttäjätunnuksesi palvelimelle:<br /><span class="small">Pitäisi olla esitäytettynä. Käytettävissä, mikäli ylläoleva on valittu.</span>',
'findtime' => '<i>find</i>: Aika Linuxin komentotulkin \'find\' tiedostokoko tarkistusten välillä kansioissa, jotka syötät alle ja sen alikansioissa. Tämä ja seuraavat kaksi kenttää eivät ole käytössä, jos komentoa ei tueta palvelimella.<br />Aseta 0, jos haluat käyttää muuta tarkistustapaa kuten \'quota\' tai vapaan tilan tarkistus.<br /><span class="small">Koska tämä voi kestää kauan, sinun pitäisi asettaa kohtailaisen suuri arvo kuten 300 (viisi tuntia) tai 1440 (yksi päivä). Kun vapaa tila on tarkistettu jokaisen \'find\'-haun jälkeen, tämä toiminto ei rasita palvelinta.</span>',
'findroot' => '<i>find</i>: Polku käyttäjätilisi juurikansioon monikäyttäjäjärjestelmässä.<br /><span class="small">Polun täytyy olla <b>järjestelmän juuresta käyttäjän juureen</b>. Esimerkiksi:<br />/var/www/your_domain_name/<br />/var/www/web1234/<br /><br />Voit myös antaa polun foorumisi tai sen alikansioon ja määrittää kokorajan sille ja \'find\' käyttää sitä rajaa käyttäjätilin rajan sijaan. Esimerkiksi:<br />/var/www/your_domain_name/cgi-bin/yabb2/<br />/var/www/your_domain_name/public_html/yabbfiles/Attachments/</span>',
'findmax' => '<i>find</i>: Vapaa tila, jota saat käyttää ylläolevassa kansiossa (megatavuissa).<br /><span class="small">Tämän pitäisi olla sama arvo kuin palvelinpalvelusi mainostaa.<br />Koska sinun kuuluisi asettaa \'find\' tarkistamaan vapaa tila palvelimella vain X tunnin välein tai kerran päivässä, sinun kuuluisi asettaa tämä arvo alemmaksi kuin palvelun arvo, jotta tila ei lopu kesken yllättävän tilankäytön takia, esimerkiksi liitetiedostojen tai muiden isojen viestien takia.<br />Ottaaksesi käyttöön \'find\' vapaan tilan tarkistuksen tämä arvo täytyy olla suurempi kuin 0. Jos käytetty tila ylläolevassa kansiossa on suurempi kuin tämä arvo, foorumi menee automattisesti huoltotilaan estääkseen levytilan loppumisen ja tietojen katoamisen.<br />Muistutukset:<br />Vain ylläpitäjä pääsee foorumille huoltotilassa.<br />Siinä tapauksessa, jos et muista: 1 Gt = 1024 Mt</span>',
'diskspacecheck' => 'Ota levytilan tarkastus käyttöön?<br /><span class="small">Tämä tarkistaa saatavilla olevan todellisen levytilan Windows- ja Linux-palvelimilla. Huomioi, että kaikki tarjolla oleva levytila ei välttämättä ole foorumin käytössä. Luku voi olla suurempi, kuin sinulle tarjottu palvelusopimus tarjoaa!<br />Mikäli vapaana oleva levytila putoaa alle 100&thinsp;000 tavuun (100 KB), foorumi siirtyy automaattisesti huoltotilaan jotta tietoja ei häviäisi.<br />Muistutus: Vain ylläpitäjät voivat päästä foorumiin huoltotilan aikana.</span>',
'getreversedns' => q~Enable Reverse DNS Lookup.~,
'minlinkpost' => 'Viestien vähemmäismäärä jolloin käyttäjä voi lisätä viesteihin linkkejä ja kuvia.',
'minlinkpost_exp' => 'Tämä estää roskapostibotteja lähettämästä roskapostia rekisteröitymisen jälkeen.',
'minlinksig' => 'Viestien minimimäärä ennen kuin käyttäjä voi lisätä linkkeja ja kuvia allekirjoitukseen',
'minlinksig_exp' => 'Tämä estää spam-bottien luomasta spam-allekirjoituksia heti rekisteröinnin jälkeen',
'minlinkweb' => 'Viestien minimimäärä ennen kuin käyttäjä voi lisätä linkin sivustoon profiilissaan',
'minlinkweb_exp' => 'Tämä estää roskapostittajien lisäämästä linkkejä sivustoihin heti rekisteröinnin jälkeen',
'stealth' => 'Salli "piiloutuminen" ylläpitäjille ja yleisille valvojille:<br /><span class="small">Tämä näyttää käyttäjän olevan poissa foorumilta aina</span>',
'mlview' => 'Kuka saa katsella käyttäjälistaa?',
'buddylist' => 'Salli kaverilistan käyttö?',
'regreason' => 'Enimmäismäärä merkkejä rekisteröitysmislomakkeen "Rekisteröitymissyy"- kohdassa',
'showall' => 'Näytä "Näytä kaikki"- painike sivun valitsimissa ja aiheen yhteenvedossa?',
'imageinquote' => 'Valitse, mikäli haluat kuvien näkyvän lainauksissa.<br /><span class="small">Ei valittuna kuvat lainauksissa näkyvät linkkeinä kuvaan.</span>',
'extendedprofiles' => 'Käytä laajennettuja profiileja?<br /><span class="small">Valittuna ylimääräinen "Profiilin kentät"-osio tulee näkyviin vasemmalle. Siellä voit lisätä toiminnallisuuksia käyttäjien profiiliin. <br />Jätä valitsematta jos et käytä tätä ominaisuutta. Ominaisuuden käyttö lisää palvelinkuormitusta!</span>',
'forumnumbformat' => 'Valitse oletusnumeromuoto:',
'nospammer' => 'Lähetä oletussähköposti hylätyille käyttäjille vaikka syytä ei olisi annettu kun rekisteröinti on ylläpidon hyväksynnällä. Valittuna &#39;kyllä&#39;',
'honeypot' => qq~Ota käyttöön Honeypot Spambot-kiinniottaja. Valittuna &#39;kyllä&#39; (<a href="$boardurl/AdminIndex.$yyaext?action=honeypot">Muokkaa Honeypot</a>)~,
'spamfruits' => 'Ota käyttöön SpamFruits Spambot-kiinniottaja. Valittuna &#39;kyllä&#39;',
'eventcal_set' => 'Tapahtumakalenterin asetukset',
'eventcal_set1' => 'Muokkaa tapahtumakalenterin asetuksia',
'calsplit' => 'Yhdellä sivulla näytettävien syntymäpäivien maksimimäärä.<br /><span class="small">Sivu katkaistaan yksittäisiksi kuukausiksi. Jätä tyhjäksi tai aseta 0 poistaaksesi käytöstä.</span>',
'addtab_on' => 'Näytä Lisää- ja Muokka-välilehdet foorumilla?',
'rules' => 'Alueen säännöt',
'rules1' => 'Ota käyttöön alueen säännöt',
'rules2' => 'Sääntöjen otsikko',
'rules3' => 'Säännöt',
'rules4' => 'Voit käyttää HTML-koodia täällä.',
'iplookup' => 'Ota käyttöön IP Lookup?<br /><span class="small">Valitsemalla tämän toiminnon voit muuntaa IP-osoitteet aktiivisiksi linkeiksi, joilla voit hakea niitä Whois-palvelimella.</span>',
'iplookup_urls' => 'IP Lookup Whois-palvelimet:<br /><span class="small">Täällä voit lisätä tai poistaa Whois-palvelimia IP Lookup-sivulla.<br />Käytä {ip} URL:issa korvataksesi oikean IP-osoitteen, ja eroita otsikko ja URL putki-symbolilla \'|\'.<br />Yksi URL per rivi.<br />Esimerkki: MyLookupSite|mylookupsite.com?ip={ip}</span>',
'iplookup_protocols' => '. Sallitut protokollat ovat http ja https.',
'show_user_age' => 'Näytä käyttäjän ikä viestinäkymässä?',
'show_reg_date' => 'Näytä käyttäjän rekisteröintipäiväys viestinäkymässä?',
'edit_gender_limit' => 'Aseta raja kuinka monta kertaa käyttäjä voi muuttaa sukupuoltaan:<br /><span class="small">1 = Ei voi muokata asettamisen jälkeen.<br />0 = Ei rajaa.</span>',
'edit_age_limit' => 'Aseta raja kuinka monta kertaa käyttäjä voi muuttaa syntymäaikaansa:<br /><span class="small">1 = Ei voi muokata asettamisen jälkeen.<br />0 = Ei rajaa.</span>',
'min_reg_time' => 'Minimiaika, joka täytyy viettää rekisteröintisivulla:<br /><span class="small">Tämä estää spambotit, jotka automaattisesti täyttävät kentät ajassa, joka on ihmisille mahdoton.<br />Aseta 0 poistaaksesi käytöstä.</span>',
'ipblock' => 'Estä IP Guardian:issa',
'ipblock2' => 'Estä IP .htaccess-tiedostossa',
'ipblock_confirm' => 'Oletko varma, että haluat asettaa eston tälle IP-osoitteelle?\n\n',
'ipban_confirm' => 'Oletko varma, että haluat asettaa eston tälle IP-osoitteelle?\n\n',
'userpicml' => 'Näytä käyttäjän avatar käyttäjäluettelossa?',
'group_stars_ml' => 'Näytä ryhmätähdet käyttäjäluettelossa?',
'default_avatar' => 'Näytä oletusavatar, jos käyttäjä ei ole asettanut kuvaa?',
'default_userpic' => 'Oletus avatarkuva:<br /><span class="small">Sallitut tiedostomuodot: png jpg jpeg gif<br />Suurin tiedostokoko: 250kt</span>',
'edit' => 'Muokkaa',
'delete' => 'Poista',
'cancel' => 'Peruuta',
'enable_guest_view_limit' => 'Ota käyttöön vieraiden aihekatseluraja?<br /><span class="small">Valitsemalla otiminnon asettaa keksin, joka rajoittaa aiheiden määrää, jonka vieraat voivat katsella ennen kuin heitä kehoitetaan rekisteröitymään. Voit asettaa rajan aiheiden katseluille ja miten haluat sen käyttäytyvän.</span>',
'guest_view_limit' => 'Vieraiden aihekatseluraja:<br /><span class="small">Asera aiheiden määrä, jonka vieraat voivat katsella ennen kuin heitä kehoitetaan rekisteröitymään.</span>',
'guest_view_limit_block' => 'Estä vieraita katselemasta aiheita kun raja katselulle on täyttynyt?<br /><span class="small">Valitsemalla tämän estät vieraita katselemasta yhtään enempää aiheita kun raja on täyttynyt.<br />Jättämällä valitsematta näyttää ystävällisen viestin viestinäkymän yläreunassa.</span>',
'topichover' => 'Ota käyttöön Topic Hover viesti-indeksissä',
'staff_reason' => q~Ota käyttöön 'Syy muokkaukselle' henkilökunnalle~,
'user_reason' => q~Ota käyttöön 'Syy muokkaukselle' jäsenille~,
'brdrss1' => 'RSS',
'brdrss2' => 'Valitse näyttääksesi RSS-syöte tälle kategorialle alueindeksissä.<br /><b>Huomio:</b> Vain, jos RSS on käytössä.',
'brdrss3' => 'Valitse näyttääksesi RSS-syöte tälle alueelle alueindeksissä.<br /><b>Huomi:</b> Vain, jos RSS on käytössä ja alue ei ole ulkoinen linkki.',
'actions' => 'Toiminnot',
'remove_file' => 'Poista tiedosto',
'current_img' => 'Nykyinen kuva',
'remove_img' => 'Poista kuva',
'for_template' => 'Foorumipohjalle',
'setsettings' => q~Asetukset muutettu~,
'maxadminlog' => q~Suurin tietueiden määrä ylläpitolokissa.~,
'imp_email_check' => 'Ota käyttöön parannettu sähköpostiosoitteen tarkistus?<br /><span class="small">Tarkistaa, että sähköpostidomain on olemassa, ja käyttäjä tunnetaan annetulla SMTP-palvelimella, että SMTP-palvelimet ovat linjoilla ja kelvolliset, ja onko käyttäjän postilaatikko täynnä. Lisää myös toisen sähköpostiosoitekentän rekisteröintisivulle varmistukseksi.<br />Huomaa, että tämä asetus vaatii, että Net::DNS on asennettu palvelimellesi.</span>',
'zodiac' => 'Näytä horoskooppimerkit profiileissa?',
'no_imp_email_check' => q~<br /><span class="important">Parannettu sähköpostiosoitteen tarkistus ei ole saatavilla. Vaatíi Net::DNS</span>~,
'error_spd'=> q~ErrorLog speed banning. Minimum number of seconds between multiple error log entries from the same IP address. <br /><span class="small">Violators are banned through .htaccess if allowed. Set to '0' to disable</span>~,
'profile_int'=> q~Redirect guest clicks on member name links to a 'Register or Login' page. Uncheck to disable member name links for guests.~,
'ban_res' => q~You may add a short reason for the ban by using a '|' symbol to separate the IP address, e-mail address, or user ID and the reason for banning.~,
'p_ban' => q~Permanent~,
'expired' => q~Expired~,
'expireon' => q~Expires on~,
'close_box' => q~Close~,
'dupbrd' => q~<span class="important">Warning: There are duplicate Boards: </span>~,
