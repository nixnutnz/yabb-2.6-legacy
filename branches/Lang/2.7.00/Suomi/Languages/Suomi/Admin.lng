'subbrd' => q~Sub-Board~,
'inbrd' => q~in Board~,
'incat' => q~in Category~,
'fixinstruct' => q~Select the <strong>incorrect</strong> board(s). You may need to reorganize the position of boards in their categories/boards when finished.<br /><span class="important">Be very careful with your selections to make sure you do not remove the copy of the board you want to keep.</span>~,
'usercp' => q~USER's CP~,
'ppostperms' => q~Print Post Permissions<br /><span class="small">Disable Print Post or set it to "All Members" if you have spambot problems with this function.</span>~,
'ptopicperms' => q~Print Thread Permissions<br /><span class="small">Disable Print Thread or set it to "All Members" if you have spambot problems with this function.</span>~,
'813a' => 'Enable Style Switcher Dropdown Field?<br /><span class="small">If enabled, selected groups have the have the option to quickly select and change the forum layout, assuming other templates or css stylesheets are available.</span>',
