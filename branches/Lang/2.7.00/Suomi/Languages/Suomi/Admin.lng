'472' => 'Avatar-kuvan leveys (0 = ei rajaa)',
'473' => 'Avatar-kuvan korkeus(0 = ei rajaa)',
'473x' => 'Poista kuvakoon muuttaja Avatar-kuvista?<br /><span class="small">Valittuna poistaa kuvakoon muuttajan käytöstä. Kuva skaalataan asetettujen arvojen mukaan. Tämä <i>voi</i> vääristää kuvaa. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'473a' => 'Avatar käyttäjäluettelossa, kuvan leveys (0 = ei rajaa)',
'473b' => 'Avatar käyttäjäluettelossa, kuvan korkeus (0 = ei rajaa)',
'473c' => 'Poista käytöstä viisas kuvan skaalaus avatareille käyttäjäluettelossa?<br /><span class="small">Jos valittuna, viisas skaalaus ei ole käytössä ja kuva skaalataan tasan ylläoleviin arvoihin. Tämä <i>voi aiheuttaa</i> kuvan epämuotoisuutta. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'474' => 'Viestien kuvan leveys (0 = ei rajaa)',
'475' => 'Viestien kuvan korkeus (0 = ei rajaa)',
'475x' => 'Poista kuvakoon muuttaja viesteistä?<br /><span class="small">Valittuna poistaa kuvakoon muuttajan käytöstä. Kuva skaalataan asetettujen arvojen mukaan. Tämä <i>voi</i> vääristää kuvaa. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'476' => 'Allekirjoituksen kuvan leveys (0 = ei rajaa)',
'477' => 'Allekirjoituksen kuvan korkeus (0 = ei rajaa)', 
'477x' => 'Poista kuvakoon muuttaja allekirjoituksista?<br /><span class="small">Valittuna poistaa kuvakoon muuttajan käytöstä. Kuva skaalataan asetettujen arvojen mukaan. Tämä <i>voi</i> vääristää kuvaa. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'478' => 'Liitekuvan leveys (0 = ei rajaa)',
'479' => 'Liitekuvan korkeus (0 = ei rajaa)',
'479x' => 'Poista kuvakoon muuttaja liitteistä?<br /><span class="small">Valittuna poistaa kuvakoon muuttajan käytöstä. Kuva skaalataan asetettujen arvojen mukaan. Tämä <i>voi</i> vääristää kuvaa. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'brd_pic_w' => 'Alueen kuvan leveys (0 = ei rajaa)',
'brd_pic_h' => 'Alueen kuvan korkeus (0 = ei rajaa)',
'brd_pic' => 'Poista kuvakoon muuttaja alueiden kuvista?<br /><span class="small">Valittuna poistaa kuvakoon muuttajan käytöstä. Kuva skaalataan asetettujen arvojen mukaan, Tämä <i>voi</i> vääristää kuvaa. Mikäli toinen arvo on 0 kuva näytetään alkuperäisessä suhteessa asetettuun arvoon nähden. Jos kummatkin arvot ovat 0 kuvaa ei skaalata.</span>',
'ext_pic_w' => q~Extended Profile Picture display width (0 = no limit set)~,
'ext_pic_h' => q~Extended Profile Picture image display height (0 = no limit set)~,
'ext_pic' => q~Disable the Smart Image Resize feature for Extended Profile Pictures?<br /><span class="small">If checked, the smart image resize feature is disabled and the image size is set exactly to the values above. This <em>can</em> deform the images. If one of the values is 0, the image is proportionately scaled to the other value. If both are 0, the image is shown at its original size without any resizing.</span>~,
'479a' => 'Aktivoi "greybox"-toimintoa kuville?<br /><span class="small">Aktivoituna liitteiden ja viestien kuvat esitetään läpikuultavalla pinnalla. Samalla sivulla olevat liitekuvat voidaan näyttää myös peräkkäin yksi toisensa jälkeen. <br />Ei aktivoituna liitekuvat näytetään uudessa ikkunassa ja viestikuvat viestien mukana.</span>',
'479b' => 'Poista "greybox"-toiminto käytöstä',
