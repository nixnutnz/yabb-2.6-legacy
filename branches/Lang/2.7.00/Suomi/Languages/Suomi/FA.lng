our $VERSION = '2.7.00';
$suomifalngbase = 1938;
##  Based on English Rev 1938 ##

$suomifalngver  = 'YaBB 2.7.00 $Revision$';
@suomifalngmods = ();
if (@suomifalngmods) {
    $suomifalngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%fatxt = (
    '1'  => q~Liite poistettu~,
    '2'  => q~Sallitut tiedostomuodot:~,
    '3'  => q~Suurin sallittu liitteen koko:~,
    '4'  => q~Kaikki tiedostomuodot.~,
    '5'  => q~Ei rajoitusta.~,
    '6'  => q~Liite~,
    '6a' => q~Säilytä vanha liite~,
    '6b' => q~Liitä uusi liite~,
    '6c' => q~Poista liite~,
    '6d' => q~Uudelleenlähetä tiedosto~,
    '6e' => q~Älä uudelleenlähetä tiedostoa~,
    '6f' => q~Säilytä tiedosto~,
    '7' =>
q~HUOM: Jos viestissäsi oli liite, on se valittava uudestaan turvallisuussyistä.~,
    '7a' =>
q~HUOM: Jos viestissäsi oli liite, on se valittava uudestaan turvallisuussyistä.~,
    '9'   => q~Liitetoiminnot~,
    '10'  => q~Liitehakemisto~,
    '10a' => q~Yksityisviestien Liitehakemisto~,
    '11'  => q~Liitteiden URL~,
    '11a' => q~Yksityisviestien Liitteiden URL~,
    '12' =>
q~Tiedostokoon rajoitus kullekin liitteelle:<br /><span class="small">Aseta 0 poistaaksesi rajoituksen (ei suositeltavaa) tai jotain järjellistä, esim. 500 KB.</span>~,
    '12a' =>
q~Tiedostokoon rajoitus kullekin yksityisviestin liitteelle:<br /><span class ="small">Aseta 0 poistaaksesi rajoituksen (ei suositeltavaa) tai jotain järjellistä, esim. 500 KB.</span>~,
    '13' =>
q~Liitetiedostohakemiston koko:<br /><span class ="small">Aseta 0 poistaaksesi rajoituksen (ei suositeltavaa).</span>~,
    '13a' =>
q~Yksityisviestien Liitetiedostohakemiston koko:<br /><span class ="small">Aseta 0 poistaaksesi rajoituksen (ei suositeltavaa).</span>~,
    '14' => q~Sallitut tiedostomuodot liitteille (esim: \'jpg gif bmp\')~,
    '14a' =>
q~Sallitut tiedostomuodot yksityisviestien liitteille (esim. &#39;jpg gif bmp&#39;)~,
    '15' =>
q~Salli tiedostomuodon tarkistus? (Poiskytkeminen sallii kaikki tiedostomuodot)<br /><span class ="small" style="color: red;">On suositeltavaa että pidät tarkistuksen AINA päällä. Poiskytkeminen saattaa mahdollistaa haitallisen koodin ajamisen!</span>~,
    '16'  => q~Näytä kuvaliitteet viesteissä?~,
    '16a' => q~Näytä kuvaliitteet yksityisviesteissä?~,
    '17' =>
q~Liitetiedostojen lukumäärä viesteissä:<br /><span class ="small">Aseta 0 estääksesi liitteet.</span><div class ="small" style="color: red;"><u>Caution:</u> Liian monien liitteiden salliminen voi hidastaa foorumia. Kun säädät tätä, pidä mielessä myös asetukset maksimitiedostokoosta ja liitetiedostohakemiston koko.</div>~,
    '17a' =>
q~Liitetiedostojen lukumäärä yksityisviesteissä:<br /><span class ="small">Aseta 0 estääksesi liitteet.<br /><span class="important">Kun säädät tätä, pidä mielessä myös asetukset maksimitiedostokoosta ja liitetiedostohakemiston koko.</span></span>~,
    '17b' =>
q~Määritä käyttäjäryhmät, jotka voivat liittää liitetiedostoja yksityisviesteihin:<br /><span class ="small">Jos käyttäjäryhmiä ei ole valittuna, kaikki käyttäjäryhmät sallitaan.<br />Käytä Ctrl- tai Shift-näppäimiä valitaksesi/poistaaksesi valinnan useammalta käyttäjäryhmältä.</span>~,
    '18' => q~Salli Vieraiden liittää tiedostoja viesteihinsä?~,
    '19' => q~Ei pysty avaamaan~,
    '20' =>
q~<= Tiedostomuoto ei ole sallittu! Sallittuja ovat seuraavat tiedostomuodot:~,
    '20a' => q~&lt;= Kielletty koodi kuvatiedoston sisällä.~,
    '21'  => q~Tiedosto~,
    '21b' => q~on liian suuri. Suurin sallittu koko on kilotavuissa:~,
    '22'  => q~Tämän tiedoston kanssa~,
    '22b' => q~ylität suurimman sallitun liitetiedostohakemiston koon.~,
    '23'  => q~Ylärajaa liitetiedostohakemiston koolle ei ole asetettu.~,
    '23a' =>
q~Ylärajaa yksityisviestien liitetiedostohakemiston koolle ei ole asetettu.~,
    '24' => q~Ylläpidä liitetiedostoja~,
    '25' =>
q~Täältä pystyt hallinnoimaan viestien liitteitä. Voit poistaa liitteitä koon tai päivämäärän mukaan. Liitteisiin liittyvät tilastot näet alla.~,
    '26'  => q~Liitteiden tilastot~,
    '27'  => q~Yhteensä~,
    '28'  => q~Liitteitä yhteensä:~,
    '28a' => q~Yksityisviestien liitteitä yhteensä:~,
    '29'  => q~Liitetiedostohakemiston koko:~,
    '29a' => q~Yksityisviestien liitetiedostohakemiston koko:~,
    '30'  => q~Tilaa jäljellä hakemistossa:~,
    '30a' => q~Tilaa jäljellä hakemistossa:~,
    '31'  => q~Liitteiden toiminnot~,
    '31a' => q~Tarkastele liitetiedostolokia~,
    '31b' => q~Yksityisviestien liitteiden toiminnot~,
    '31c' => q~Tarkastele yksityisviestien liitetiedostolokia~,
    '32'  => q~Poista liitteet, jotka ovat vanhempia kuin~,
    '32a' => q~Poista yksityisviestien liitteet, jotka ovat vanhempia kuin~,
    '33'  => q~Poista liitteet, jotka ovat suurempia kuin~,
    '33a' => q~Poista yksityisviestien liitteet, jotka ovat suurempia kuin~,
    '34'  => q~Poista liitteet, jotka ovat vanhempia kuin (päivää):~,
    '35'  => q~Poista liitteet, jotka ovat suurempia kuin~,
    '35a' => q~Poista yksityisviestien liitteet, jotka ovat suurempia kuin~,
    '36'  => q~Hallinnoi liitteitä~,
    '37'  => q~Hallinnoi liitteitä : Katso lokia~,
    '37a' => q~Hallinnoi yksityisviestien liitteitä : Katso lokia~,
    '38' =>
q~Liitetiedostoloki näyttää tietoja foorumin liitteistä. Voit ladata ja poistaa liitteitä, tai mennä viestiketjuun johon ne on liitetty.~,
    '38a' =>
q~Yksityisviestien liitetiedostoloki näyttää tietoja foorumin liiteistä. Voit ladata ja poistaa liitteitä.~,
    '39'  => q~Liitetiedostoloki~,
    '39a' => q~Yksityisviestien liitetiedostoloki~,
    '40'  => q~Liitteen nimi~,
    '40a' => q~Tyyppi~,
    '41'  => q~Tiedostokoko~,
    '41a' => q~Lataukset~,
