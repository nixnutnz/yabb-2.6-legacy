    '44'  => q~Viestin otsikko~,
    '45'  => q~Poista~,
    '46'  => q~Haluatko varmasti poistaa kaikki liitteet?~,
    '46a' => q~Haluatko varmasti poistaa kaikki valitut liitteet?~,
    '47'  => q~Palvelimen tyyppi~,
    '48'  => q~Tällä hetkellä liitteitä ei ole~,
    '48a' => q~Tällä hetkellä yksityisviestien liitteitä ei ole.~,
    '49'  => q~Ei oikeutta liittää tiedostoa.~,
