q~Tämä liitetiedostoloki näyttää tietoja kaikista liitteistä ketjussa jonka otsikko on~,
    '76' =>
q~Voit ladata liitteitä täältä,<br />mennä viestiin jossa liitteet on tai<br />viestiketjun alkuun.~,
    '80'    => q~Liitteet~,
    '80a'   => q~Enemmän liitteitä~,
    '80s'   => q~Vähemmän liitteitä~,
    '81'    => q~Poista tiedosto~,
    'actf'  => q~Files in Attachments folder~,
    'acts'  => q~Total Size in Attachments folder~,
    'larg'  => q~Largest File: ~,
    'old'   => q~Oldest File: ~,
    'pactf' => q~Files in PMAttachments folder~,
