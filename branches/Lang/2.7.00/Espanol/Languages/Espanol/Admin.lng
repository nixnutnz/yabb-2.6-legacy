%modulecheck = (
    '1' => q~Comprobación de Módulo~,
    '2' => q~Comprueba si todos los módulos usados por YaBB están instalados.~,
    '3' => q~Nombre del Módulo~,
    '4' => q~Info~,
    '5' => q~Información facilitada por el sistema:~,
    '6' => q~Instalado~,
    '7' => q~Algunos módulos no están instalados en tu servidor.~,
    '8' =>
q~<b>Si realmente los necesitas (lee la Info), tu primera opción debe ser pedir a quien hospede tu servidor que instale los módulos necesarios!<br /><br />Si hospedas tu propio servidor, o si la empresa que te da hospedaje no te instala el módulo, entonces mira <a href="http://codex.yabbforum.com/YaBB.pl?num=1225217016" target="_blank"><b>este mensaje es el <i>YaBB Codex</i> para ayuda</b></a>.</b>~,
    'Digest::MD5' =>
q~Usado para la encriptación de la contraseña.<br />¡Este módulo es esencial! Sin él, el foro no funcionará.~,
    'Time::HiRes' =>
q~Usado por el tiempo de chequeo si el depurador de errores está habilitado.<br />Si este módulo no está instalado el tiempo de ejecución se mostrará en segundos y sin alta resolución. Si no es importante para tí, no necesitas este módulo.~,
    'Time::Local' =>
q~Usado para convertir cadenas de tiempo en marcas de tiempo.<br />¡Este módulo es imprescindible! ¡Sin él, el foro no funcionará!~,
    'File::Find' =>
q~Usado para subir ficheros adjuntos y avatares al servidor.<br />Si este módulo no está instalado y estas opciones están habilitadas aparecerá un mensaje de error cuando intentemos subir estos archivos al servidor. Si no usas estas características no necesitas este módulo.~,
    'CGI' =>
q~Usado para subir ficheros adjuntos y avatares al servidor.<br />Si este módulo no está instalado y estas opciones están habilitadas aparecerá un mensaje de error cuando intentemos subir estos archivos al servidor. Si no usas estas características no necesitas este módulo.~,
    'CGI2' => q~<strong>Your version</strong>:~,
    'Net::SMTP' =>
q~Usado para mandar emails por SMTP.<br />Este módulo sólo es necesario si quieres mandar tus emails por Net::SMTP. Si no mandas emails por NET::SMTP, no necesitas este módulo.~,
    'Net::SMTPS' =>
q~Used to send e-mails via SMTPS.<br />This module is only needed if you want to send your e-mails via Net::SMTPS (usually if you need to use an external mail server such as Gmail). Otherwise you do not need this module.~,
    'Compress::Zlib' =>
q~Usado para la opción de Backup y para comprimir el tamaño del código HTML enviado por el YaBB al navegador.<br />Este módulo sólo es necesario si no tienes otros métodos de backup disponibles (mira la página de opciones de backup para más detalles) y/o si quieres habilitar "¿Usar Compresión-Gzip?". De lo contrario, no necesitas este módulo.~,
    'Compress::Bzip2' =>
q~Usado para la opción de Backup.<br />Este módulo sólo es necesario si no tienes otros métodos de backup disponibles (mira la página de opciones de backup para más detalles). De lo contrario no necesitas este módulo.~,
    'Archive::Tar' =>
q~Usado para la opción de Backup.<br />Este módulo sólo es necesario si no tienes otros métodos de backup disponibles (mira la página de opciones de backup para más detalles). De lo contrario no necesitas este módulo.~,
    'Archive::Zip' =>
q~Usado para la opción de Backup.<br />Este módulo sólo es necesario si no tienes otros métodos de backup disponibles (mira la página de opciones de backup para más detalles). De lo contrario no necesitas este módulo.~,
    'MIME::Lite' =>
q~Usado para mandar Backups adjuntados a un emaila.<br />Este módulo sólo es necesario si quieres que se te mande el Backup por email y no a través de descarga directa desde el Centro de Administración.~,
    'IO::Socket::INET' =>
q~Usado para mandar emails por el "Motor SMTP de YaBB".<br />Este módulo sólo es necesario si quieres mandar tus emails por el "Motor SMTP de YaBB". De lo contrario no necesitas este módulo.~,
    'Digest::HMAC_MD5' =>
q~Usado para mandar emails por el "Motor SMTP de YaBB".<br />Este módulo sólo es necesario si quieres mandar tus emails por el "Motor SMTP de YaBB". De lo contrario no necesitas este módulo.~,
    'Carp' =>
q~Usado para mandar emails por el "Motor SMTP de YaBB".<br />Este módulo sólo es necesario si quieres mandar tus emails por el "Motor SMTP de YaBB". De lo contrario no necesitas este módulo.~,
    'bytes' =>
q~Usado para mandar emails por el "Motor SMTP de YaBB".<br />Este módulo sólo es necesario si quieres mandar tus emails por el "Motor SMTP de YaBB". De lo contrario no necesitas este módulo.~,
    'integer' =>
q~Usado para mandar emails por el "Motor SMTP de YaBB".<br />Este módulo sólo es necesario si quieres mandar tus emails por el "Motor SMTP de YaBB". De lo contrario no necesitas este módulo.~,
    'DateTime' =>
q~Required by DateTime::TimeZone.<br />This module is needed if you want to have forum/user timezones set to anything other than UTC.~,
    'DateTime::TimeZone' =>
q~Used to get user and forum Time Zone offsets based on the user's actual time zone.<br />This module is needed if you want to have forum/user timezones set to anything other than UTC.<br /><span class="important">This Module needs to be kept current as it contains time sensitive Time Zone data.~,
    'DateTime::TimeZone2' =>
q~<br /><span class="important">This Module needs to be kept current as it contains time sensitive Time Zone data. Check with your server host to make sure this Module is being kept current.</span><br /><b>Your version</b>:~,
    'URI::Escape' =>
q~Used by Post/Message Preview function.<br />This module is essential. Without it, the Preview function will not work.~,
    'perlver' => q~Your Perl Version~,
    'Net::DNS' =>
q~Used by the improved e-mail checker. If this module is not installed, you cannot enable the improved e-mail checker.~,
    'Mail::CheckUser' =>
q~Used by the improved e-mail checker. This module should have been installed with YaBB.~,
    'Module::Load' =>
q~Used by Advanced Backup.<br />This module is essential. Without it, the Backup functions will not work.~,
    'server' => q~Your Server~,
    'LWP::Simple' =>
q~Used by YaBMod.<br />If this module is not installed, you will be unable to use YaBMod. Otherwise you do not need this module.~,
    'noserver'          => q~no server information available~,
    'mod_access_compat' => q~No Mod Access~,
);

