    '432b' =>
q~Permitir a los miembros iniciar sesión con su nombre de pantalla, así como su dirección de ID de usuario o correo electrónico?~,
    '462' => q~¡IR!~,
    '470' => q~N/A~,
    '471' =>
q~Redimensionamiento inteligente de la imagen<br />(redimensiona la imagen a los siguientes valores si la imagen los excede)~,
    '472' => q~Ancho del Avatar (0 = sin límite)~,
    '473' => q~Alto del Avatar (0 = sin límite)~,
    '473x' =>
q~¿Desactivar la opción de redimensionamiento de imágenes para el Avatar?<br /><span class="small">Si se marca esta opción, se desactivará la función de redimensionamiento de la imagen y la imagen se fijará exactamente con los valores presentados encima. Esto <i>puede</i> deformar las imágenes. Si uno de los valores de encima es cero, la imagen se mostrará en sus proporciones al otro valor. Si los dos son cero, la imagen se mostrará con sus proporciones originales sin ningún redimensionamiento.</span>~,
    '473a' =>
q~Avatar de Miembros ancho de visualización de la imagen (0 = sin límite)~,
    '473b' =>
q~Avatar de Miembros altura de visualización de imágenes (0 = sin límite)~,
    '473c' =>
q~Desactivar el Smart tamaño de imagen característica para los Avatares en miembro? <br /> Lista <span class ="small"> Si se marca, la imagen inteligente redimensionar función está desactivada y el tamaño de la imagen se ajusta exactamente a los valores anteriores. Esta <i> puede </ i> deformar las imágenes. Si uno de los valores es cero, la imagen se proporcionalmente a escala en el otro valor. Si ambos son cero, la imagen se muestra en su tamaño original sin ningún tipo de cambio de tamaño. </span>~,
    '474' => q~Ancho de la imagen en Post(0 = sin límite)~,
    '475' => q~Alto de la imagen en Post (0 = sin límite)~,
    '475x' =>
q~Desactivar la opción de redimensionamiento de imágenes en los Posts?<br /><span class="small">Si se marca esta opción, se desactivará la función de redimensionamiento de la imagen y la imagen se fijará exactamente con los valores presentados encima. Esto <i>puede</i> deformar las imágenes. Si uno de los valores de encima es cero, la imagen se mostrará en sus proporciones al otro valor. Si los dos son cero, la imagen se mostrará con sus proporciones originales sin ningún redimensionamiento.</span>~,
    '476' => q~Anchura de la imagen de la firma (0 = sin límite)~,
    '477' => q~Altura de la imagen de la firma (0 = sin límite)~,
    '477x' =>
q~¿Desactivar la función de redimensionamiento de la imagen en las Firmas?<br /><span class="small">Si se marca esta opción, se desactivará la función de redimensionamiento de la imagen y la imagen se fijará exactamente con los valores presentados encima. Esto <i>puede</i> deformar las imágenes. Si uno de los valores de encima es cero, la imagen se mostrará en sus proporciones al otro valor. Si los dos son cero, la imagen se mostrará con sus proporciones originales sin ningún redimensionamiento.</span>~,
    '478' => q~Ancho de la imagen de Adjuntos (0 = sin límte)~,
    '479' => q~Alto de la imagen de Adjuntos (0 = sin límite)~,
    '479x' =>
q~¿Desactivar la opción de redimensionamiento automático para Adjuntos?<br /><span class="small">Si se marca esta opción, se desactivará la función de redimensionamiento de la imagen y la imagen se fijará exactamente con los valores presentados encima. Esto <i>puede</i> deformar las imágenes. Si uno de los valores de encima es cero, la imagen se mostrará en sus proporciones al otro valor. Si los dos son cero, la imagen se mostrará con sus proporciones originales sin ningún redimensionamiento.</span>~,
    '479a' =>
q~¿Usar el "greybox" para imágenes?<br /><span class="small">Si se activa esta opcióp, las imágenes adjuntas aparecerán con una superfie translúcida de color gris si se clicka sobre ellas. Para imágenes adjuntas tienes una segunda opción: Mostrar todas las imágenes adjuntas de esa página una detrás de otra.<br />Si se desactiva las imágenes adjuntas se mostrarán en una nueva ventana y las imágenes posteadas se dejarán en el área de texto.</span>~,
    '479b' => q~Desactivar "greybox"~,
    '479c' => q~Activar "greybox" para una imagen en cada casilla~,
    '479d' =>
      q~Activar "greybox" para todas las imágenes en una casilla (Adjuntos)~,
    'brd_pic_w' => q~Junta Imagen ancho de la pantalla (0 = sin límte)~,
    'brd_pic_h' =>
      q~Junta Imagen altura de visualización de imágenes (0 = sin límte)~,
    'brd_pic' =>
q~Desactivar el Smart tamaño de imagen característica de Fotos de la Junta? <span class ="small"> <br /> Si se marca, la imagen inteligente redimensionar función está desactivada y el tamaño de la imagen se ajusta exactamente a los valores anteriores. Esta <i> puede </ i> deformar las imágenes. Si uno de los valores es 0, la imagen se proporcionalmente a escala en el otro valor. Si ambos son 0, la imagen se muestra en su tamaño original sin ningún tipo de cambio de tamaño. </span>~,
    'ext_pic_w' => q~Extended Profile Picture display width (0 = no limit set)~,
    'ext_pic_h' =>
      q~Extended Profile Picture image display height (0 = no limit set)~,
    'ext_pic' =>
q~Disable the Smart Image Resize feature for Extended Profile Pictures?<br /><span class="small">If checked, the smart image resize feature is disabled and the image size is set exactly to the values above. This <em>can</em> deform the images. If one of the values is 0, the image is proportionately scaled to the other value. If both are 0, the image is shown at its original size without any resizing.</span>~,
