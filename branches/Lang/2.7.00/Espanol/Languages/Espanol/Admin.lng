%floodtxt = (
    '1' => q~Centro de Seguridad YaBB:~,
    '2' =>
q~Activar código de validación al registrarse, olvido de contraseña y enviar tema~,
    '3' =>
q~Activar código de validación para el posteo de visitantes, contactar con admin con Mensaje de Broadcast por parte de visitantes y envío de mensaje de Alerta al Moderador~,
    '5' =>
q~¿Número Máximo de mensajes devueltos en Post Recientes por Foro y por Usuario?<br /> <span class="small">-1 desactivará Mensajes Recientes</span>~,
    '5a' =>
q~Maximum number of messages returned for Recent Topics on forum?<br /> <span class="small">-1 will disable Recent Topics</span>~,
    '6' =>
q~¿Número Máximo de mensajes devueltos en una búsqueda?<br /> <span class="small">-1 desactivará Búsqueda</span>~,
    '7' => q~Longitud máxima del Código de Validación (max 15)~,
    '9' => q~Fondo de la Imagen de Validación Transparente~,
    'f' => q~Color de Primer Plano de Imagen de Validación (RGB valor hex)~,
    's' => q~Color de Sombreado de Imagen de Validación (RGB valor hex)~,
    'b' => q~Color de Fondo de la Imagen de Validación (RGB valor hex)~,
    'rnd' =>
q~Selecciona si y cómo quieres añadir ruido aleatorio al fondo de tu imagen de validación~,
    'style' =>
q~Seleccionar qué caracteres son generados en el CAPTCHA<br /><span class="small">Recuerda que tanto mayúsculas como minúsculas hace que el CAPTCHA sea más difícil de leer</span>~,
    'lower' => q~Caracteres en Minúscula + Dígitos~,
    'upper' => q~Caracteres en Mayúscula + Dígitos~,
    'all'   => q~Caracteres en mayúscula y minúscula + Dígitos~,
    'masterkey' =>
q~Define una llave maestra para la encriptación<br /><span class="small">Una cadena de texto aleatoria (> 8 y < 24 caracteres de longitud)</span>~,
    'rm0' => q~No Ruido Aleatorio~,
    'rm1' => q~Usar sólo el color de sombra~,
    'rm2' => q~Usar sólo el color de primer plano~,
    'rm3' => q~Usar ambos (color de sombra y de primer plano)~,
    'dis' =>
q~Fondo de CAPTCHA para sombrear el color randomizer level<br /><span class="small">¡¡Puede hacer el captcha muy difícil de leer en ciertas combinaciones de colores!!</span>~,
    'vpreview' =>
q~Vista previa del Código de Validación<br /><span class="small">Selecciona esta opción después de  \'Grabar\' nuevas configuraciones</span>~,
    'extra_chars_start' =>
      q~Add extra characters to the start of the validation code:~,
    'extra_chars_end' =>
      q~Add extra characters to the end of the validation code:~,
    'extra_chars_desc' =>
q~This will add characters which do not need to be entered by the user and will fool spambots.~,
    'casewarning' =>
q~Please type the characters that appear in the image. The characters must be typed in the same order, and they are case-sensitive.~,
    'casewarning_1' =>
      q~Please type the characters exactly as they appear in the image,~,
    'casewarning_2' =>
      q~<br /><span style="font-weight: bold;">without the first~,
    'casewarning_3' =>
      q~<br /><span style="font-weight: bold;">without the last~,
    'casewarning_4' => q~and last~,
    'casewarning_5' =>
q~characters.</span><br />The characters must be typed in the same order,<br />and they are case-sensitive.~,
);

