    'show_ip_admin' =>
q~Enseñar a los administradores las IPs de todos los miembros e invitados en la lista de usuarios en línea del foro~,
    'show_ip_gmod' =>
q~Enseñar a los moderadores globales las IPs de todos los miembros e invitados en la lista de usuario en línea del foro~,
