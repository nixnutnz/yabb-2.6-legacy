our $VERSION = '2.7.00';
$espanolsearchlngbase = 1938;
##  Based on English Rev 1938 ##

$espanolsearchlngver  = 'YaBB 2.7.00 $Revision$';
@espanolsearchlngmods = ();
if (@espanolsearchlngmods) {
    $espanolsearchlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%search_txt = (
