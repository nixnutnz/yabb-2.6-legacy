%pmboxes_txt = (
    'in'     => q~Entrada~,
    'inbox'  => q~Bandeja de Entrada~,
    'out'    => q~Salida~,
    'outbox' => q~Enviados~,
    'store'  => q~Almacenar en carpeta~,
