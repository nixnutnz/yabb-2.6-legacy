q~This section allows you to customize your Calendar Events by using your own Event Icons.<br />Images look best being no larger than 25x25px.<br />Allowed file types: png jpg jpeg gif<br />Max. file size: 100KB~,
    '34'  => q~List upcoming events for __ days next to the Event Calendar~,
    '35'  => q~(0 = All events for current month)~,
    '36'  => q~First day of week (mini calendar)?~,
    '37'  => q~(unchecked = Monday / checked = Sunday)~,
    '42'  => q~Show Member Birthdays List to:~,
    '42a' => q~Show Zodiac Signs in Birthday List?~,
    '43'  => q~Don&#39;t show &#39;Event-Icons&#39; in mini calendar?~,
