### Event Calendar Settings ###

%event_cal = (
    '1' => q~Event Calendar Settings~,
    '3' => q~Show Event Calendar to:~,
    '4' => q~Show &#39;Event Calendar&#39; Button on YaBB menu to:~,
    '5' => q~Show Birthdays in Calendar/Events to:~,
    '6' => q~Determine length of characters from each event(s)?~,
    '7' =>
q~Shows a &#39;READ MORE&#39; link to posted event<br />(0 = deactivated)~,
    '8'  => q~Emphasize current date with this color in the mini calendar~,
    '9'  => q~Enable &#39;Event-Scroll&#39; function~,
    '10' => q~Very useful if you have many events.~,
    '11' => q~Off~,
    '12' => q~Auto-Scroll~,
    '13' => q~Manual-Scroll~,
    '14' => q~Select which member groups are allowed to add/edit events:~,
    '15' =>
q~Making NO selection allows all Groups, Users and Guests to add/edit events.<br /><br />{yabb admin_txt14}~,
    '16' => q~Allow these members to add Events~,
    '17' => q~List multiple members as &#39;username1,username2&#39;.~,
    '18' => q~Allow members to add &#39;Private Events&#39;?~,
    '19' =>
q~If unchecked only Global Moderators and Administrators can add &#39;Private Events&#39;~,
    '20' => q~Enable show &#39;Events&#39; (Event-Scroll) on BoardIndex?~,
    '21' => q~Standard Settings~,
    '22' => q~Event Settings~,
    '23' => q~Access Settings~,
    '24' => q~Show "Disable username-link" checkbox to:~,
    '26' => q~Calendar Event-Icon Settings~,
    '27' => q~Select Image~,
    '28' => q~Description~,
    '29' => q~Image~,
    '30' => q~Add new Calendar Event-Icons here~,
    '31' => q~Save Event Calendar Settings~,
    '32' => q~Save Event-Icon Settings~,
