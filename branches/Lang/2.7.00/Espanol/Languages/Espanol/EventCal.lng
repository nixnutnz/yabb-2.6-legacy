##  Based on English Rev 1925 ##
our $VERSION = '2.7.00';

$espanoleventcallngver  = 'YaBB 2.7.00 $Revision$';
@espanoleventcallngmods = ();
if (@espanoleventcallngmods) {
    $espanoleventcallngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

