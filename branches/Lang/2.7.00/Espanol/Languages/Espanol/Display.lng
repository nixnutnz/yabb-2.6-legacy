our $VERSION = '2.7.00';

$espanoldisplaylngver  = 'YaBB 2.7.00 $Revision$';
@espanoldisplaylngmods = ();
if (@espanoldisplaylngmods) {
    $espanoldisplaylngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

