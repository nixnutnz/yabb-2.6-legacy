### Event Calendar Settings ###

%event_cal = (
    '1' => q~Event-Kalender Einstellungen~,
    '3' => q~Event-Kalender im BoardIndex anzeigen für~,
    '4' => q~'Event-Kalender'-Button im YaBB-Menü anzeigen für~,
    '5' => q~Geburtstage im Kalender/Events anzeigen für~,
    '6' => q~Länge der Events im BoardIndex und KalenderIndex?~,
    '7' =>
q~Wieviele Zeichen sollen pro Event angezeigt werden?<br />Zeigt einen 'MEHR LESEN' Link zum Eventeintrag<br />(0 = deaktiviert)~,
    '8'  => q~In welcher Farbe soll der heutige Tag angezeigt werden?~,
    '9'  => q~'Event-Scroll' Funktion aktivieren?~,
    '10' => q~Sehr nützlich, wenn Du viele Events hast.~,
    '11' => q~Aus~,
    '12' => q~Auto Scroll~,
    '13' => q~Manuel Scroll~,
    '14' =>
      q~Welche Mitgliedergruppen dürfen Events hinzufügen oder editieren?~,
    '15' =>
q~Wenn Sie keine Auswahl treffen, können alle Gruppen, Benutzer und Gäste Ereignisse hinzufügen/editieren.<br /><br />{yabb admin_txt14}~,
    '16' => q~Welche Mitglieder dürfen Events hinzufügen?~,
    '17' =>
q~Mehrere Mitglieder können mit 'username1,username2' angegeben werden (die Namen müssen die internen YaBB-Namen sein)~,
    '18' => q~Dürfen Mitglieder 'Privat Events' hinzufügen?~,
    '19' =>
q~Deaktiviert = nur die Global-Moderatoren oder Administratoren dürfen 'Private Events' hinzufügen~,
    '20' => q~Events (Event-Scroll) im BoardIndex anzeigen?~,
    '21' => q~Standardeinstellungen~,
    '22' => q~Eventeinstellungen~,
    '23' => q~Eventberechtigungen~,
    '24' => q~Zeige die Checkbox "Username-Link nicht anzeigen" für~,
    '26' => q~Kalender Event-Icon Einstellungen~,
    '27' => q~Bild auswählen~,
    '28' => q~Beschreibung~,
    '29' => q~Bild~,
    '30' => q~Neue Event-Icons hier hinzufügen~,
    '31' => q~Kalender-Einstellungen speichern~,
    '32' => q~Event-Icon-Einstellungen speichern~,
    '33' =>
q~In diesem Abschnitt können Sie Ihre Kalender Ereignisse bearbeiten, indem Sie Ihre eigenen Event-Icons anpassen.<br />Bilder sehen am besten aus, wenn sie nicht grösser sind als 25x25px.<br />Erlaubte Dateinamen sind: png jpg jpeg gif<br />Max. Dateigrösse: 100KB~,
    '34'  => q~Angezeigte Event(s)-Tage im Board-Kalender-Index?~,
    '35'  => q~(0 = Alle Events für den aktuellen Monat)~,
    '36'  => q~Erster Tag der Woche (Mini Kalender)?~,
    '37'  => q~(nicht gewählt = Montag / gewählt = Sonntag)~,
