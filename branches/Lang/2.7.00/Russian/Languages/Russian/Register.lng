%mail_check = (
    'address' => q~Введенный e-mail почты:~,
    'invalid' => q~является недействительным.~,
    'reason'  => q~Ошибка:~,
    '0'       => q~Проверить успешно.~,
    '1'       => q~Плохой синтаксис адрес электронной почты.~,
    '2' => q~Почтовый домен упоминается в адрес электронной почты неизвестно.~,
    '3' => q~Тайм-аут произошло во время DNS проверок.~,
    '4' => q~Пользователь неизвестно на SMTP-сервер.~,
    '5' => q~Тайм-аут произошло во время SMTP проверок.~,
    '6' =>
q~Все SMTP-серверы для домена электронной почты были найдены во время недоступен SMTP проверок.~,
    '7' =>
q~Почта временно полном объеме, но, вероятно, действительное имя пользователя.~,
);

1;
