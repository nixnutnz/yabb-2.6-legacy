%floodtxt = (
'1' => 'Центр Безопасности Форума:',
'2' => 'Требовать ввод верификационного кода при регистрации, напоминании пароля, отправке сообщений',
'3' => 'Требовать ввод верификационного кода для сообщений от Гостей, при отправке от Гостей Общих Сообщений Администратору и предупреждений Модераторам',
'5' => 'Максимальное число сообщений отображаемых в панели "Последние сообщения" Форума и Пользователя<br /> <span class="small">-1 отключит слежение за последними сообщениями</span>',
'5a' => 'Maximum number of messages returned for Recent Topics on forum?<br /> <span class="small">-1 will disable Recent Topics</span>',
'6' => 'Максимальное число сообщений в результатах поиска<br /> <span class="small">-1 отключит поиск</span>',
'7' => 'Длина верификационного кода (максимум 15)',
'9' => 'Прозрачный фон картинки с верификационным кодом',
'f' => 'Цвет переднего фона изображения с верификационного кодом (RGB hex)',
's' => 'Цвет тени изображения с верификационным кодом (RGB hex)',
'b' => 'Цвет фона изображения с верификационного кодом (RGB hex)',
'rnd' => 'Выберите способ добавления случайного шума на картинку с кодом',
'style' => 'Выбор набора символов для генерации картинки с кодом<br /><span class="small">Помните, что одновременное использование прописных и строчных символов может существенно осложнить прочтение верификационного кода</span>',
'lower' => 'Строчные символы + Числа',
