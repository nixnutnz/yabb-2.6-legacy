    'age'           => q~Возраст~,
    'regdate'       => q~Зарегистрирован: ~,
    'mylastposts'   => q~Просмотреть мои последние 5 сообщений~,
    'lastposts'     => q~Просмотреть последние 5 сообщения от ~,
