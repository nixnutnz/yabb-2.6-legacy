##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$russianxbackuplngver  = 'YaBB 2.7.00 $Revision$';
@russianxbackuplngmods = ();
if (@russianxbackuplngmods) {
    $russianxbackuplngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

$script_root = $ENV{'SCRIPT_FILENAME'};
if ( !$script_root ) {
    $script_root = $ENV{'PATH_TRANSLATED'};
}
( $support_env_path = $script_root ) =~ s/\/\w+[.][pl|cgi]//xsm;

%backup_txt = (
    '1' => q~Резервное копирование~,
    '2' =>
q~Вы не сохранили настройки функции Резервного копирования данных форума! Вы должны сделать это перед тем как архивировать данные форума.~,
    '3' =>
q~Выберите директорию для хранения резервных копий.<br /><span class="small">Примечание: YaBB будет использовать актуальные пути, прописанные в файле &quot;Paths.pl&quot;.</span>~,
    '4' => q~Директории YaBB~,
    '5' => q~Выбрать все/Сбросить все~,
    '6' =>
q~<span class="small">Если Вы выберите все доступные пункты, Вы получите полную копию Вашего форума (рекомендуется).</span>~,
    'path1' => q~Path to Tar and Zip:~,
    'path2' =>
      q~Path to gzip and bzip2 (also sets path to gzip in Advanced Settings):~,
    'path3' =>
q~Fill in the paths <b>only</b> if YaBB cannot automatically find Tar, Zip, gzip, and bzip2. Otherwise, leave the above spaces blank.~,

    # Begin description of directories
    # We don't translate directory names like Boards/.
    '7'   => q~(содержит список всех Категорий и Разделов форума)~,
    '8'   => q~(содержит все сообщения и все темы)~,
    '9'   => q~(содержит все профили участников)~,
    '10'  => q~и стили оформления~,
    '10a' => q~(содержит все шаблоны оформления форума за исключением графики)~,
    '11'  => q~(содержат все языковые файлы форума)~,
    '12'  => q~(содержит настройки форума)~,
    'and' => q~и~,   # Odd name, yes, but could be useful in more than one place
    '13' =>
q~и другие файлы с исходными кодами (содержит файлы исходных кодов движка YaBB)~,
    '14'  => q~(содержит изображения и стилевые настройки Вашего форума)~,
    '14a' => q~-- (contains user-uploaded files: attachments and avatars)~,

    # Begin the backup method selection
    '15' => q~Способ создания резервной копии~,

    # Don't translate command names (such as /bin/tar) or 'tar'.
    '16' =>
q~Лучший метод для создания архива это Tar (с компрессией) или Zip.<br />Используйте Archive::Tar (с Compress::Zlib или Compress::Bzip2) или Archive::Zip методы лишь в крайнем случае.<br />Методы архивирования bzip2 или Bzip2 дают наименьший размер файла, но работают слишком долго.<br /><span style="color: red;"><b>Примечание:</b><br /></span>Некоторые серверы не поддерживают работу с большими архивами. В этом случае Вы можете увидеть ошибку типа "Internal server error" или просто пустую страницу. Выберите другой метод архивирования и попробуйте снова. Если это не помогает, уменьшите количесво директорий YaBB для архивирования.~,
    '17'  => q~Файл tar без сжатия~,
    '18'  => q~(сжатие Tar)~,
    '19'  => q~Директория для хранения Резервных копий~,
    '19a' => q~Предупреждать об устаревании Резервных копий~,
    '19b' => q~Предупредить меня об устаревании Резервных копий через~,
    '19c' => q~дней. (0 - для отключения предупреждения).~,
    '19d' => q~days. Enter zero or leave blank to disable reminder.~,
    '19e' => q~Max Process Time~,
    '19f' => q~Max Process Time is currently set for~,
    '19g' => q~seconds - adjust this up or down to prevent server timeouts~,
    '20'  => q~Сохранить настройки~,

    # Begin run backup area
    '21' => q~Создание Резервной копии~,
    '22' =>
q~Нажмите на кнопку ниже для запуска процесса создания Резерной копии форума. Она будет создана в директории~,
    '23' => q~, которая была определена Вами ранее.~,
    '24' =>
q~Во время создания Резервной копии Ваш форум будет переведен в режим Технического Обслуживания.<br /><br />Если Вы создаете Резервную копию для больших форумов, то это может привести к большому времени ожидания ответа от сервера! Подождите около 5 минут. Если ничего не происходит, следуйте советам, изложенным в Примечании в пункте &quot;Способ создания резервной копии&quot;.<br /><br />После создания первой Резервной копии данных Вы можете выбрать какой метод архивирования использовать далее. Вы можете снова создать полную резервную копию или заархивировать только те файлы, которые были изменены с момента последней архивации. После повторного сохранения настроек Резервного копирования будет создаваться полная копия архива. Проверка файлов, измененных с момента создания последней резервной копии происходит за <i>секунды</i> для Tar, Archive::Tar и Archive::Zip и за <i>дни</i> для Zip.~,
    '25'  => q~Создать Резервную копию~,
    '25a' => q~Создать Резервную копию только для файлов, измененных после~,

    # Not used
    # '26' => q~', #not used

    # Text used for the actual backup output
    '27' => q~Заархивировано~,

    # Text used in the support subroutines
    '28' => q~Не могу загрузить модуль~,
    '29' => q~Невозможно протестировать метод архивирования~,
    '30' => q~Невозможно найти метод архивирования~,
    '31' => q~не может быть использовано~,
    '32' => q~Код ошибки:~,

    # Text used for timing the backup
    '33' => q~Резервная копия создана за~,
    '34' => q~секунд~,

    # Begin manage backups area
    '35' => q~Управление Резервными копиями~,
    '36' => q~Резервные копии форума доступны в ~,
    '37' =>
q~Вы можете:<ul><li>Загрузить резервную копию (ЗАГРУЗИТЬ)</li><li>Отправить Резервную копию по E-mail на адрес~,
    '37a' =>
q~ (E-MAIL)</li><li>Сделать архив Резевной копии (АРХИВ)</li><li>Сделать архив Резевной копии содержащий изменения произошедшие в файлах с момента создания архива (НОВЫЕ)</li><li>Восстановить форум из Резервной копии (ВОССТАНОВИТЬ)</li><li>Удалить Резервную копию (УДАЛИТЬ)</li></ul>~,
    '38' => q~Резервные копии не найдены~,

    '39' => q~Модуль~,
    '40' => q~Команда~,
    '41' => q~не доступна на этом сервере.~,
    '42' => q~Невозможно произвести запись в~,
    '43' => q~Проверьте правильность установки пути и прав доступа.~,

    '44'  => q~Невозможно изменить директории на~,
    '45'  => q~Файл резервной копии поврежден!~,
    '46'  => q~Невозможно прочитать из~,
    '47'  => q~Вы уверены, что хотите удалить~,
    '48'  => q~? Это действие не может быть отменено.~,
    '49'  => q~Да, я уверен(-а)~,
    '50'  => q~Нет, не удалять~,
    '51'  => q~Невозможно удалить~,
    '52'  => q~E-MAIL~,
    '53'  => q~УДАЛИТЬ~,
    '54'  => q~Вы уверены, что хотите отправить по E-mail~,
    '55'  => q~Размер вложенного файла будет~,
    '56'  => q~Да, отправить вложение на~,
    '57'  => q~Нет, не отправлять вложение, но прислать ссылку на файл.~,
    '58'  => q~Нет, не отправлять. Загрузить файл.~,
    '59'  => q~Нет, не отправлять.~,
    '60'  => q~ЗАГРУЗИТЬ~,
    '61'  => q~АРХИВ~,
    '62'  => q~НОВЫЕ~,
    '62a' => q~INC~,
    '63'  => q~ВОССТАНОВИТЬ~,

    '70' => q~Дата сохранения~,
    '71' => q~Размер~,
    '72' => q~Содержимое архива (сохраненные директории)~,
    '73' => q~Тип~,
    '74' => q~Функции~,

    # Loop stuff to prevent running into server time out
    '90' =>
q~Если Вы хотите остановить процесс создания резервной копии дерните за <a href="javascript:stoptick();">СТОП-КРАН</a>.~,
    '91' =>
q~Создается Резевная копия данных форума - подождите пожалуйста!<br />Если Вы хотите остановить этот процесс, нажмите на надпись СТОП-КРАН до момента появления предупредительного сообщения на следующей странице.~,

    # Recover stuff
    '100' => q~Recover Backup~,
    '101' =>
q~<b>The automated recovery feature is recommended ONLY for the following directories:<br /><i>Boards</i>, <i>Members</i>, <i>Messages</i>, <i>Variables</i>, and <i>yabbfiles/Attachments and yabbfiles/avatars/UserAvatars</i>.<br /><br />Recovered files may not have proper ownership or permissions, and you may therefore experience file access problems. If this occurs, you should recover all other files by downloading the archive file from the previous page, then uploading the backed up files via FTP from your computer.</b><br /><br />Are you sure that you want to recover the following directory(s)?~,
    '102' => q~from the archive file:~,
    '103' => q~from~,
    '104' => q~If yes, then~,
    '105' =>
qq~If checked, files from the archive will be restored directly to their original (live) directories. This will overwrite the existing files in these directories and restore deleted files, if necessary. However, files created after the backup date (which are therefore not part of the archive) will not be deleted or modified. Directories that you want to recover must be set to CHMOD X[2|3|6|7]X before recovery, i.e. they must have at least 'group' write permission. Examples: CHMOD 775 or 765. If you have moved any directories from their previous locations since this backup archive was created, this method will probably fail - if this is the case, leave this box unchecked.<br />If unchecked, files recovered from the archive will be stored in a new \"recovered\" directory within your Archive Destination Directory, with the actual timestamp appended; for example:<br /><tt>$backupdir/recovered_$date</tt>  -- (the timestamp is merely an example).~,
    '106' =>
q~You must set the permissions for the recovered files in the following directories. Depending on your server configuration, the recovered files may be owned by the server daemon user. If that is the case, you may not be able to change the permissions afterwards. To ensure that you can modify and/or delete your files after recovery, the "group" permissions must be 6 or 7; do not use a lower number. The owners permissions must also be 6 or 7.<br /><br />If you are uncertain about any of the above, do not use this automated recovery feature, and instead download the archive file manually (from the previous page) and restore the files via FTP from your computer.~,
    '107' => q~Files and Directories~,
    '108' => q~Permissions<br />(CHMOD)<br />Owner|Group|All~,
    '110' => q~This permission cannot be set below~,    # Used in JavaScript!
    '111' =>
      q~This permission cannot be set higher than 7.~,    # Used in JavaScript!
    '112' => q~Only numbers are allowed.~,                # Used in JavaScript!
    '114' => q~(all files)~,
    '115' => q~All~,
    '116' => q~files~,
    '120' => q~If new directories are created, set them to~,
    '125' => q~No, return to the YaBB Backup page~,
    '126' => q~Yes, I'm ready - Recover Now.~,
    '130' =>
q~<b><u>Output:</u><br /><br />If the CHMOD was successful, the first character will be <i>1</i>; if it is <i>0</i>, the CHMOD failed.</b><br />If the CHMOD failed, the most common problem is that one or more directories were not set to <i>group</i> write permission.~,
    '131' =>
q~<b>Now check the CHMODs again with your FTP program, just to be sure &nbsp; ;-)</b>~,
    '132' => q~Back to YaBB Backup main page~,

    # Begin e-mail stuff.
    'mailsubject' => q~YaBB 2 Backup from {yabb mbname}~,
    'mailfrom'    => q~"YaBB 2 Backup Mailer" <{yabb webmaster_email}>~
    ,    # do NOT modify anything left and right from *YaBB 2 Backup Mailer*!
    'mailsuccess' => q~Sent e-mail successfully.~,
    'mailfail' =>
q~Sending e-mail failed. See the error message in the info e-mail you will receive.~,
    'no_perm'   => q~You do not have permission to change the above settings.~,
    'no_dnload' => q~DOWNLOAD not permitted.~,
    'no_delete' => q~DELETE not permitted.~,
    '542'       => q~If nothing happens in 5 seconds~,
    '543'       => q~click here to continue~,
);

    # The actual messages are here.
    # Don't translate WORDS IN ALL CAPITALS from here to the end of the file
$backup_txt{'mailmessage1'} = q~Доброго времени суток, USERNAME

Резервная копия данных форума FILENAME должна быть прикреплена к этому письму.

Если это не так, посетите следующую ссылку, чтобы загрузить файл вручную:
LINK

Спасибо за использование форума на движке YaBB!~;

$backup_txt{'mailmessage2'} = q~
Приветствую Вас, USERNAME

Посетите следующую ссылку, чтобы загрузить файл FILENAME с резервной копией данных форума вручную:
LINK.

Спасибо за использование форума на движке YaBB!~;

$backup_txt{'mailmessage3'} = q~Hi USERNAME!

Sending the e-mail with the attached backup failed.

But, you can visit LINK to manually download the backup FILENAME.

The system provided the following info related to the sending error:
"SYSTEMINFO"

You must have MIME::Lite installed on your server to get backups by e-mail; you may also need other modules (see the info above). Ask your server administrator to install the module(s) on your server.  You can find further help on installing modules at: http://codex.yabbforum.com/YaBB.pl?num=1225217016

Thanks for using YaBB!~;

1;
