%mycenter_profile_txt = (
    'siddescript' =>
q~Из соображений безопасности Вы должны подтвердить свой пароль для доступа к настройкам.~,
    'timeoutdescript' =>
q~Время, отведенное на сессию для работы с профилем закончилось. Пожалуйста, идентифицируйтесь заново.~,
);

%profile_display_options = (
    'hide_avatars'    => q~Скрыть члены аватары в потоках?~,
