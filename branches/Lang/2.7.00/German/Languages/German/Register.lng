%prereg_txt = (
'1' => q~Ihr Account wurde noch nicht aktiviert!<br />Bitte aktivieren Sie ihn innerhalb von {yabb preregspan} Stunden, indem Sie auf den Link klicken, der Ihnen per eMail zugeschickt wurde.~,
