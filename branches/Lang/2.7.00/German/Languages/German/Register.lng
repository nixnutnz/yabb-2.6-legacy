'213' => q~Passwörter sind nicht identisch.~,
'241' => q{Feld. Gültige Zeichen sind Buchstaben (A-Z, a-z), Zahlen (0-9), Leerzeichen und ( _ ! @ # $ % ^ & * ( ) + | ` ~ - = \ : ; ' " , . / ? [ ] { } )},
'241r' => q~Feld. Gültige Zeichen sind Buchstaben (A-Z, a-z), Zahlen (0-9), Leerzeichen und ( + - . @ _ )~,
'241re' => q~Feld. Gültige Zeichen sind Buchstaben, Zahlen, Leerzeichen und ( [ ] # % + , - | . : = ? @ ^ _ )~,
'241e' => q~Feld. Gültige Zeichen sind Buchstaben (A-Z, a-z), Zahlen (0-9), und ( + - _ . @ )~,
'241ea' => q~<br />Gültige Zeichen sind Buchstaben (A-Z, a-z), Zahlen (0-9), and ( + - _ . @ )~,
'241n' => q~kann nicht alles Zahlen sein.~,
'241a' => q~Feld!~,
'245' => q~Registrierung war erfolgreich~,
'430' => q~, Sie sind in diesem Forum gebannt~,
