'error_sender_email' => q~Sie müssen ihre eMail-Adresse eingeben.~,
'error_recipient_name' => q~Sie müssen den Namen des Empfängers eingeben.~,
'error_recipient_email' => q~Sie müssen die eMail-Adresse des Empfängers eingeben.~,
