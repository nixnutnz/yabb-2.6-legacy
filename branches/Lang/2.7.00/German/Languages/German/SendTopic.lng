%floodtxt = (
'1' => q~Ihr Validierungscode lautet~,
'3' => q~Validierungscode~,
'casewarning' => q~Geben Sie bitte den Text genau so ein, wie auf dem Bild dargestellt. Beachten Sie dabei bitte die Groß- und Kleinschreibung.~,
'casewarning_1' => q~Geben Sie bitte den Text genau so ein, wie auf dem Bild dargestellt,~,
'casewarning_2' => q~<br /><span style="font-weight: bold;">ohne die ersten~,
'casewarning_3' => q~<br /><span style="font-weight: bold;">ohne die letzten~,
