$germanfalngver = 'YaBB 2.7.00 $Revision$';
@germanfalngmods = ();
if (@germanfalngmods) {
    $germanfalngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%fatxt = (
'1' => q~Anhang gelöscht~,
'2' => q~Erlaubte Dateitypen:~,
'3' => q~Max. Größe der Datei:~,
'4' => q~Alle Typen.~,
'5' => q~Kein Limit.~,
'6' => q~Anhang~,
'6a' => q~Angehängte Datei beibehalten~,
'6b' => q~Neue Datei anhängen~,
'6c' => q~Angehängte Datei löschen~,
'6d' => q~Datei vorwärts~,
'6e' => q~Datei nicht vorwärts~,
'6f' => q~Datei beibehalten~,
'7' => q~ACHTUNG: Wenn Sie bereits einen Dateianhang an Ihrem Beitrag hatten, müssen Sie diesen aus Sicherheitsgründen erneut anhängen.~,
'7a' => q~ACHTUNG: Wenn Sie bereits einen Dateianhang in Ihrer Nachricht hatten, müssen Sie diesen aus Sicherheitsgründen erneut anhängen.~,
'9' => q~Dateianhangsfunktionen~,
'10' => q~Ordner für Anhänge~,
'10a' => q~PN-Ordner für Anhänge~,
'11' => q~URL für Anhänge~,
'11a' => q~URL für PN-Anhänge~,
'12' => q~Größenlimit für Dateianhänge:<br /><span class ="small">Setzen Sie den Wert 0 zum deaktivieren der Prüfung (nicht empfohlen) oder einen Wert in der Größe von beispielsweise 500 KB.</span>~,
'12a' => q~Größenlimit für PN-Dateianhänge:<br /><span class ="small">Setzen Sie den Wert 0 zum deaktivieren der Prüfung (nicht empfohlen) oder einen Wert in der Größe von beispielsweise 500 KB.</span>~,
'13' => q~Größenlimit des Verzeichnisses für Dateianhänge:<br /><span class ="small">Setzen Sie den Wert 0 zum deativieren der Prüfung (nicht empfohlen).</span>~,
'13a' => q~Größenlimit des Verzeichnisses für PN-Dateianhänge:<br /><span class ="small">Setzen Sie den Wert 0 zum deativieren der Prüfung (nicht empfohlen).</span>~,
'14' => q~Erlaubte Dateitypen für Anhänge (z.B.: 'jpg gif bmp')~,
'14a' => q~Erlaubte Dateitypen für PN-Anhänge (z.B.: 'jpg gif bmp')~,
'15' => q~Dateitypen prüfen? (ohne Prüfung werden alle Typen akzeptiert)<br /><span class ="small" style="color: red;">Es wird empfohlen, die Dateitypen Prüfung IMMER aktiviert zu haben! Wird diese Option deaktiviert, haben potenzielle Hacker die Möglichkeit, Ihr Forum durch Einschleusen von schädlichem Script Code unbrauchbar zu machen!</span>~,
'16' => q~Angehängte Bilddateien unter dem Beitrag anzeigen?~,
'16a' => q~Angehängte Bilddateien unter der PN anzeigen?~,
'17' => q~<label for="allowattach">Erlaubte Anzahl von Dateianhängen in Beiträgen:<br /><span class ="small">Setzen Sie den Wert 0 zum deaktivieren von Dateianhängen.</span></label><div class ="small" style="color: red;"><label for="allowattach"><span class="under">Achtung:</span> Wenn Sie die Möglichkeit zur Verfügung stellen, viele Dateianhänge hochzuladen, kann die Ladegeschwindigkeit des Forum beeinflusst werden. Berücksichtigen Sie bei der Festlegung dieser Einstellungen auch die Werte für das Größenlimit von Dateianhängen und den zur Verfügung stehenden Speicherplatz des Verzeichnisses für Dateianhänge.</label></div>~,
'17a' => q~Anzahl von Dateianhängen in persönlichen Nachrichten erlaubt:<br /><span class ="small">Setzen Sie den Wert 0 zum deaktivieren von PN-Anhängen.<br /><span style="color: #FF0000;">Wenn Sie die Möglichkeit zur Verfügung stellen, viele PN-Dateianhänge hochzuladen, kann die Ladegeschwindigkeit des Forum beeinflusst werden. Berücksichtigen Sie bei der Festlegung dieser Einstellungen auch die Werte für das Größenlimit von PN-Dateianhängen und den zur Verfügung stehenden Speicherplatz des Verzeichnisses für PN-Dateianhänge.</span></span>~,
'17b' => q~Geben Sie die Mitglieder-Gruppen an, denen es erlaubt ist, PN-Anhänge hochzuladen:<br /><span class ="small">Wenn keine Mitgliedergruppe ausgewählt ist, werden alle Mitgliedergruppen aktiviert.<br />Verwenden Sie Strg oder Umschalt zum aktivieren / deaktivieren mehrerer Gruppen.</span>~,
'18' => q~Dürfen Gäste Dateien anhängen?~,
'19' => q~Kann nicht geöffnet werden:~,
'20' => q~<= Dateiendung ist nicht erlaubt! Erlaubt ist nur die Verwendung folgender Dateiendungen:~,
'20a' => q~<= Ungültiger Code in der Bild-Datei!~,
'21' => q~Die Datei~,
'21b' => q~ist zu groß. Die maximal erlaubte Dateigröße in KB beträgt:~,
'22' => q~Mit dieser Datei~,
'22b' => q~wird das erlaubte Größenlimit des Verzeichnisses für Dateianhänge überschritten.~,
'23' => q~Kein Größenlimit für den Anhangsordner festgelegt.~,
'23a' => q~Keine Größenlimit für den PN-Anhangsordner festgelegt.~,
'24' => q~Dateianhänge verwalten~,
'25' => q~Von hier aus können Sie die an Beiträgen angehängten Dateien in Ihrem YaBB verwalten. Sie können nach Größe oder Datum von Ihrem System gelöscht werden. Eine Statistik der Anhänge ist ebenfalls vorhanden.~,
'26' => q~Statistik der Anhänge~,
'27' => q~Übersicht~,
'28' => q~Anhänge insgesamt:~,
'28a' => q~PN-Anhänge insgesamt:~,
'29' => q~Größe des Anhangsordners insgesamt:~,
'29a' => q~Größe des PN-Anhangsordners insgesamt:~,
'30' => q~Verfügbarer Platz im Anhangsverzeichnis insgesamt:~,
'30a' => q~Verfügbarer Platz im PN-Anhangsverzeichnis insgesamt:~,
'31' => q~Optionen der Dateianhänge~,
'31a' => q~Dateianhangslog zeigen~,
'31b' => q~Optionen für PN-Dateianhänge~,
'31c' => q~Zeige Log-Datei für PN-Dateianhänge~,
'32' => q~Anhänge löschen, wenn älter als~,
'32a' => q~PN-Anhänge löschen, wenn älter als~,
'33' => q~Anhänge löschen, wenn größer als~,
'33a' => q~PN-Anhänge löschen, wenn älter als~,
'34' => q~Anhänge löschen, wenn älter als _ Tage:~,
