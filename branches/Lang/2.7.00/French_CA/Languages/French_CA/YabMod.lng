    '36' => q~Extraire le(s) fichier(s) de BoardMod:~,
    '37' => q~<strong>Succès!</strong> Tous les fichiers Mods sont sur le serveur.~,
    '38' => q~Désinstaller Mod~,
    '39' => q~Ouverture du fichier mod~,
    '40' => q~Traitement du fichier mod...~,
    '41' => q~Modifier le fichier~,
    '42' => q~Sauvegarde~,
    '43' => q~dans~,
    '44' => q~Sauvegarde~,
    '45' => q~Étape~,
