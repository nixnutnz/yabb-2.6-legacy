    '13' => q~Auteur~,
    '14' => q~page d'accueil~,
    '15' => q~Info Mods~,                        # Nom de la balise
    '16' => q~Retour à la liste des Mods~,
    '17' => q~Traitement Mods~,
    '18' => q~Erreur~,
    '21' => q~Test~,
