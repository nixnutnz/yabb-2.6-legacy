    # Uninstall Install Error
    'no'     => q~Non~,
    'tag'    => q~balise correspond à~,
    'no_tag' => q~balise trouvée à la ligne~,
    'no_s_string' => q~Aucune chaîne de recherche n'a été trouvée!<br /><br /><span class="under">Chaîne de recherche</span>:<br />~,
    'no_file'  => q~Fichier introuvable!<br />~,
    'no_write' => q~Impossible d'écrire le fichier:<br />~,
    'no_open'  => q~Impossible d'ouvrir:<br />~,
    'recall' => q~<strong>Rappelle tous les fichiers de sauvegarde modifiés...</strong><br />~,
