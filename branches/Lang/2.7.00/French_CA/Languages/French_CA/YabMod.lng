##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$french_cayabmodlngver  = 'YaBB 2.7.00 $Revision$';
@french_cayabmodlngmods = ();
if (@french_cayabmodlngmods) {
    $french_cayabmodlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%yabmtxt = (
    '1' => q~Liste des Mods~,
    '2' => q~Cliquez sur le nom du fichier pour voir les détails et tester, installer et désinstaller des Mods.~,
