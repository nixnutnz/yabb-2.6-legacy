    'n_install' => q~n'a pas été installé!~,

    # .bak cleanup
    'cleanbak' => q~Fichiers Mod .bak~,
    'cleanbak2' => q~Pour économiser de l'espace, une fois vos Mods installés, vous pouvez supprimer les fichiers de sauvegarde de Mod. <strong>Note</strong>: cela ne supprime pas les fichiers dans les dossiers Mods.~,
    'cleansub' => q~Supprime les anciens fichiers *.bak.~,
