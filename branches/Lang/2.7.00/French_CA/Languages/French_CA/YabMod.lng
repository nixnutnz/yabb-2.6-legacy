    '52' => q~Supprimer les dossiers Mods utilisés...~,
    '53' => q~Supprimer le fichier Mod~,
    '54' => q~<strong>Succès!</strong> Tous les fichiers Mod ont été supprimés.~,
    '55' => q~<strong>Succès!</strong> Installation Mod  Tout a été fait!~,
    '56' => q~<strong>Succès</strong>Modtest! Tout a été fait!~,
    '57' => q~Supprimer le fichier Mod~,
    '58' => q~<strong>Succès!</strong> Tous les fichiers Mod ont été supprimés.~,
    '59' => q~Obtenir un fichier Mod dr répertoire~,
    '60' => q~Obtenir un fichier Mod de l'URL~,
