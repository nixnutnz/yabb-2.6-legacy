%errorlog = (
    '1'  => q~Journal des erreurs~,
    '2'  => q~Afficher les erreurs~,
    '3'  => q~Affichage des erreurs~,
    '4'  => q~Erreurs totales~,
    '5'  => q~Date~,
    '6'  => q~IP~,
    '7'  => q~Message d'erreur~,
    '8'  => q~URL~,
    '9'  => q~Nombre de messages~,
    '10' => q~Forum~,
    '11' => q~Identifiant~,
    '12' => q~Mot de passe~,
    '13' => q~Del~,
    '14' => q~Supprimer la (les) erreur (s)~,
    '15' => q~Êtes-vous sûr de vouloir supprimer les erreurs sélectionnées?~,
    '16' => q~Tout voir~,
    '17' => q~Erreurs~,
    '18' =>
q~Cette page vous donnera un résumé de toutes les erreurs qui se sont produites, de la plus petite erreur comme un mauvais mot de passe, à toutes les tentatives pour contourner, déjouer ou casser les fonctions de sécurité YaBB.<br /><br />Ci-dessous vous verrez des informations détaillées sur l'erreur, y compris le moment où l'erreur est survenue, l'utilisateur qui a causé l'erreur, l'adresse (URL) de l'erreur et l'erreur elle-même, ainsi que la possibilité de rechercher une adresse IP de l'utilisateur si nécessaire.~,
    '19' =>
q~Il n'y a pas de nouvelles erreurs depuis la dernière fois que vous avez nettoyé le journal des erreurs.~,
    '20' => q~Nettoyer le journal des erreurs~,
    '21' => q~Erreur #~,
    '22' => q~Activer la journalisation des erreurs? (Coché = Oui)~,
    '23' =>
q~Autoriser la rotation du journal?<br /><span class="small">(Les anciennes entrées du journal des erreurs seront supprimées lorsque de nouvelles entrées seront ajoutées lorsque le nombre total d'entrées atteint le nombre défini)</span>~,
