    '53'  => q~Éditer~,
    '54'  => q~enlever~,
    '55'  => q~Forum supprimé avec succès Id:~,
    '57' => q~Modifiez les informations, paramètres et autorisations de votre forum ici.~,
    '58'  => q~Forum~,
    '59'  => q~Information requise~,
    '60'  => q~(Cela doit être rempli complètement)~,
    '61'  => q~Id du Forum:~,
    '61a' => q~Id de la catégorie:~,
    '61b' => q~<span class="small">entrez n'importe quel nom alphanumérique sans espaces</span>~,
    '62' => q~Description~,
    '62a' => q~Si cela doit être un lien de forum externe, la première ligne de la description doit être le titre du nom du lien, ou si vous utilisez une image comme lien, la première ligne doit utiliser la balise HTML &lt;img&gt;. Exemple. &lt;img src="http://votresite.com/votre_image.jpg" alt="Le titre de votre image" &gt;~,
    '63'  => q~Modérateur~,
    '63d' => q~Modérateur du forum~,
    '63a' => q~Copier~,
    '63b' => q~Coller~,
