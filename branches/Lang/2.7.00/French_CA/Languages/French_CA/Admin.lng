    '52' =>
q~Protection contre le Spam - Entrez le pourcentage<br /><span class="small">(Lire l'aide de l'administrateur - <a href="{yabb scripturl}?action=help;section=admin#Spam_Protect_-_Enter_Percent">Protection contre le spam - Entrez le pourcentage</a> pour Info, 0 pour désactiver)</span>~,

    '75' => q~Nombre de messages requis pour envoyer des messages personnels?~,
