    '410' => q~NFSLock File-Locking (Unix uniquement)~,
    '425' => q~Votre version/Version actuelle~,
    '432' => q~Durée de vie par défaut des cookies de connexion.<br /><span class="small">Si cochée, la durée de vie par défaut est 'forever', sinon les cookies de connexion expireront lorsque l'utilisateur fermera son navigateur./span>~,
    '432b' => q~Autoriser les membres à se connecter avec leur pseudo ainsi que leur identifiant ou leur adresse courriel?~,
