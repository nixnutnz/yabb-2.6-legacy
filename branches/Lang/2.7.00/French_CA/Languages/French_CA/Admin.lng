    '362' => q~Répertoire des langues~,
    '363' => q~Répertoire de modèles~,
    '364' => q~Fichier d'aide~,
    '366' => q~Paramètres pour le courriel de notification d'un nouveau membre~,
    '367' => q~Courriel de notification pour un nouveau membre?<br /><span class="small">Si coché, une notification concernant l'enregistrement d'un nouveau membre sera envoyée à l'adresse courriel ci-dessous.</span>~,
    '368' => q~Adresse courriel de notification:<br /><span class='small'>Si elle est vide, le courriel sera envoyé à: {yabb webmaster_email}</span>~,
    '371' => q~Heure actuelle du forum~,
    '371d' => q~Sélectionnez le fuseau horaire du forum:<br /><span class="small">Choisissez le pays et la ville qui représente votre fuseau horaire préféré par défaut.<br />Si les seuls choix sont "UTC" et "local", vous n'avez pas les modules nécessaires pour utiliser les fuseaux horaires basés sur le pays/la ville. Dans ce cas, utilisez "local" et définissez manuellement votre décalage horaire pour définir la différence de temps de votre forum par rapport à l'heure UTC ou choisissez UTC.</span>~,
'371a' => q~Activer le choix du fuseau horaire pour les utilisateurs:<br /><span class="small">Si le module Perl <strong>DateTime :: TimeZone</strong> nécessaire n'est pas installé, les utilisateurs ne seront pas capable de choisir "UTC". Si le fuseau horaire par défaut du forum est "local", les utilisateurs disposeront également du "décalage horaire par défaut du forum".</span>~,
    'local' => q~local~,
'371e' => q~Activez DST en utilisant le fuseau horaire du forum "local" et le décalage horaire du forum (ci-dessus).<br /><span class="small">Ce paramètre suppose que votre serveur d'hébergement est dans un fuseau horaire utilisant le Les mêmes dates pour l'heure d'été que vous voulez pour votre forum et est configuré pour reconnaître son heure locale avec DST. Sinon, choisissez UTC comme fuseau horaire ou ajustez manuellement l'heure d'été dans votre fuseau horaire à l'aide de l'option "Définir le décalage horaire du forum".</span>~,
    '371f' => q~Définir le décalage horaire du forum:<br /><span class="small">Ajustez la différence de temps de votre forum de l'UTC ici.</span>~,
    '371b' => q~Activer l'horloge dynamique en haut de la page?~,
    '371c' => q~Correction du temps serveur (en secondes +/-)~,
    '372'  => q~Nombre de meilleurs publieurs pour la liste des membres~,
    '373'  => q~Nombre de membres affichés par page dans la liste des membres~,
    '374' =>       q~Nombre maximal de sujets affichés par page dans l'index des messages~,
    '375' => q~Nombre maximum de messages affichés par page d'un sujet~,
    '376' => q~Nombre de jours pour qu'une publication ne s'affiche plus en tant que "nouvelle" dans l'affichage du forum ou Message.~,
    '378'  => q~Activer le code du forum?~,
    '378a' => q~Activer les citations dans les forums?~,
    '379'  => q~Activer les nouvelles?~,
    '380'  => q~Activer les publications des invités?~,
    '381' => q~Autoriser les utilisateurs à activer les notifications par courriel pour les forums/discussions listés dans "Mes notifications" lorsqu'un nouveau message est publié?~,
    '382'  => q~Afficher l'index du dernier membre sur le forum?~,
    '383'  => q~Afficher la date de modification sur les messages modifiés?~,
    '384'  => q~Afficher l'avatar de l'utilisateur dans la vue des messages?~,
    '385'  => q~Afficher le texte de l'utilisateur dans la vue des messages?~,
    '385a' => q~Texte utilisateur par défaut (sous l'avatar de l'utilisateur)~,
    '385b' => q~Enveloppe de texte utilisateur (nombre de caractères par ligne pour le texte utilisateur sous l'avatar de l'utilisateur)~,
    '386' => q~Afficher l'image de genre dans la vue des messages?~,
    '386a' => q~Autoriser l'utilisateur à masquer l'âge dans le profil et le message Afficher et masquer l'âge et l'année de naissance dans le calendrier?~,
    '387' => q~Activer l'atténuateur de nouvelles?~,
    '388' => q~Millisecondes de délai entre les messages dans le fader de nouvelles~,
    '389'  => q~Couleur du texte du curseur de News~,
    '389a' => q~Couleur d'arrière-plan du nouveau curseur~,
    '391'  => q~Utiliser le verrouillage de fichier?~,
    '392'  => q~Verrouiller EX~,
    '393'  => q~Verrouiller UN~,
    '394'  => q~Montrer Qui regarde le sujet maintenant?~,
    '395'  => q~Montrer Qui répond à un sujet?~,
    '396' => q~<span class="small">Administrateurs, modérateurs globaux, modérateurs de forum et modérateurs de forum uniquement.</span>~,
    '401' => q~Aucun verrouillage de fichier~,
    '402' => q~Verrouillage de fichier Unix/Linux et Win/NT~,
    '404' => q~Envoyer des courriels en utilisant~,
    '407' => q~Serveur SMTP<br /><span class="small">Pour Net::SMTP ou Net::SMTPS, spécifiez le numéro de port avec ":&lt;portnumber&gt;" à la fin. Exemple: smtp.gmail.com<em>:587</em></span>~,
    '408' => q~Temps minimum entre deux soumissions de la même adresse IP (en secondes)~,
