%gztxt = (
    '1' =>
q~Utiliser la compression de sortie?<br /><span class="small">La compression de sortie réduit la bande passante utilisée pour communiquer avec le navigateur d'un utilisateur.<br />Option (s) sont disponibles uniquement si le serveur les soutient. Vous pouvez définir le chemin d'accès à l'utilitaire gzip de votre serveur dans <a href="{yabb adminurl}?action=backupsettings"> Utilitaire de sauvegarde</a></span>~,
    '2' =>
q~Envoyer Sortie toujours compressée?<br /><span class="small">Vérifié = YaBB ne vérifie pas si le navigateur supporte la compression, et compresse toujours la sortie. ** Cela pourrait rendre votre forum inutilisable pour les anciens navigateurs. **<br />Non vérifié = YaBB vérifie si le navigateur prend en charge la compression et utilise la compression (si sélectionnée ci-dessus) uniquement lorsqu'elle est prise en charge par le navigateur.</span>~,
    '3' => q~Pas de compression de sortie~,
    '4' => q~Compression avec programme GZip externe~,
    '5' => q~Compression avec Compress :: Module Zlib~,
);

