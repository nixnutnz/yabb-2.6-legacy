);

%tsc_txt = (
    '1' => q~Contrôle total du spam~,
    '2' => q~Définition de la règle du SPAM~,
    '3' =>
q{Format: [number][action];[spamrule]<br />[number] = nombre d'occurrences autorisé.<br />[action]: ~ signifie correspondance partielle et = signifie correspondance exacte. < br /> [spamrule]: terme ou définition du texte à rechercher. Une règle par ligne et une regex Perl limitée est autorisée.<br /><br />Exemple: 0~;www.p(.?)rn(.?).com},
    '4' =>
q~Filtrer les paramètres sur le sujet et le contenu des messages du forum~,
    '5' => q~Modifier les domaines de messagerie obligatoires~,
);

%modulecheck = (
    '1' => q~Vérification du module~,
    '2' =>
q~Vérifie si tous les modules Perl utilisés par YaBB sont correctement installés.~,
    '3' => q~Nom du module~,
    '4' => q~Info~,
    '5' => q~Informations fournies par le système:~,
    '6' => q~Installé~,
    '7' => q~Certains modules ne sont pas installés sur votre serveur.~,
    '8' =>
q~<strong>Si vous en avez vraiment besoin (lisez les infos), votre premier choix devrait être de demander à votre hôte serveur d'installer les modules nécessaires pour vous.</strong><br /><br />Si vous hébergez votre propre serveur, ou si votre hôte n'installera pas le module pour vous, voir <a href= "http://www.yabbforum.com/cgi-bin/codex/YaBB.pl?num=1225217016" target="_ blank"> <strong>ce message dans le <em>Codex YaBB</em>pour de l'aide</strong></a>.</strong>~,
    'Digest::MD5' =>
q~Utilisé pour le chiffrement de mot de passe.<br />Ce module est essentiel. Sans cela, YaBB ne fonctionnera pas.~,
    'Time::HiRes' =>
q~Utilisé pour l'analyse comparative si le débogage est activé.<br />Si ce module n'est pas installé, l'heure de l'analyse comparative sera affichée en secondes entières et pas en secondes haute résolution. Sinon, vous n'avez pas besoin de ce module.~,
    'Time::Local' =>
q~Utilisé pour convertir les chaînes de temps en horodatages.<br />Ce module est essentiel. Sans cela, YaBB ne fonctionnera pas toujours.~,
    'File::Find' =>
q~Utilisé pour le téléchargement des avatars et des pièces jointes.<br />Si ce module n'est pas installé et que ces fonctions sont activées, vous recevrez un message d'erreur lorsque vous essaierez de télécharger. Sinon, vous n'avez pas besoin de ce module.~,
    'CGI' =>
q~Utilisé pour le chargement des avatars, pièces jointes et diagnostiques~,
    'CGI2' => q~<strong>Votre version</strong>:~,
    'Net::SMTP' =>
q~Utilisé pour envoyer des courriels via SMTP.<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriel via Net :: SMTP. Sinon, vous n'avez pas besoin de ce module.<br /><strong>Votre version</strong>:~,
    'Net::SMTPS' =>
q~Utilisé pour envoyer des courriels via SMTPS.<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriel via Net :: SMTPS . Sinon, vous n'avez pas besoin de ce module.~,
    'Compress::Zlib' =>
q~Utilisé pour la fonction de sauvegarde et la compression de sortie du navigateur.<br />Ce module n'est nécessaire que si vous n'avez pas d'autres méthodes de sauvegarde disponibles (voir la <a href="{yabb adminurl}?action=backup">fonction Sauvegarde</a> pour plus de détails) et/ou Voulez-vous activer "Utiliser GZip-Compression?". Sinon, vous n'avez pas besoin de ce module.~,
    'Compress::Bzip2' =>
q~Utilisé pour la fonction de sauvegarde.<br />Ce module n'est nécessaire que si vous n'avez pas d'autres méthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de détails). Sinon, vous n'avez pas besoin de ce module.~,
    'Archive::Tar' =>
q~Utilisé pour la fonction de sauvegarde.<br />Ce module n'est nécessaire que si vous n'avez pas d'autres méthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de détails). Sinon, vous n'avez pas besoin de ce module.~,
    'Archive::Zip' =>
q~Utilisé pour la fonction de sauvegarde.<br />Ce module n'est nécessaire que si vous n'avez pas d'autres méthodes de sauvegarde disponibles (voir la fonction Sauvegarde pour plus de détails). Sinon, vous n'avez pas besoin de ce module.~,
    'MIME::Lite' =>
q~Utilisé pour envoyer des sauvegardes jointes à un courriel.<br />Ce module n'est nécessaire que si vous souhaitez obtenir le fichier de sauvegarde par courriel et non par téléchargement direct depuis le centre d'administration. . Sinon, vous n'avez pas besoin de ce module.~,
    'IO::Socket::INET' =>
q~Utilisé pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine" . Sinon, vous n'avez pas besoin de ce module.~,
    'Digest::HMAC_MD5' =>
q~Utilisé pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
    'Carp' =>
q~Utilisé pour envoyer des courriels via "YaBB SMTP Engine" et afficher des avertissements sérieux sur le serveur.~,
    'bytes' =>
q~Utilisé pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
    'integer' =>
q~Utilisé pour envoyer des courriels via "YaBB SMTP Engine".<br />Ce module n'est nécessaire que si vous voulez envoyer vos courriels via le "YaBB SMTP Engine". Sinon, vous n'avez pas besoin de ce module.~,
    'DateTime::TimeZone' =>
q~Utilisé pour obtenir les décalages de fuseau horaire de l'utilisateur et du forum en fonction du fuseau horaire réel de l'utilisateur.<br />Ce module est nécessaire si vous souhaitez que les fuseaux horaires du forum/utilisateur soient autres que UTC .<br /><span class="important"> Ce module doit être tenu à jour car il contient des données de fuseau horaire sensibles au temps.~,
    'DateTime::TimeZone2' =>
q~<br /><span class="important"> Ce module doit être tenu à jour car il contient des données de fuseau horaire sensibles au temps. Vérifiez avec votre hôte serveur pour vous assurer que ce module est maintenu à jour.</span><br /><b>Votre version</b>:~,
    'URI::Escape' =>
q~Utilisé par la fonction prévisioner publication/message.<br />Ce module est essentiel. Sans cela, la fonction Aperçu ne fonctionnera pas.~,
    'perlver' => q~Votre version Perl~,
    'Net::DNS' =>
q~Utilisé par le vérificateur de courrier électronique amélioré. Si ce module n'est pas installé, vous ne pouvez pas activer le vérificateur de courrier électronique amélioré.~,
    'Mail::CheckUser' =>
q~Utilisé par le vérificateur de courrier électronique amélioré. Ce module devrait avoir été installé avec YaBB.~,
    'server' => q~Votre Serveur~,
    'LWP::Simple' =>
q~Utilisé par YaBMod.<br />Si ce module n'est pas installé, vous ne pourez pas utiliser YaBMod. Sinon vous n'avez pas besoin de ce module.~,
    'noserver'          => q~aucune information serveur de disponible~,
    'mod_access_compat' => q~Aucun acces au Mods~,
    'DateTime' =>
q~Requis par DateTime::TimeZone.<br />Ce module est requis seulement si vous désires avoir un fuseau horraire forum/utilisateur dans une zone autre que UTC.~,
    'Module::Load' =>
q~Utilisé par la Sauvegarde avancée.<br />Ce module est essentiel. Sans ce module, les fonctions de sauvegarde ne fonctionneront pas.~,
);

