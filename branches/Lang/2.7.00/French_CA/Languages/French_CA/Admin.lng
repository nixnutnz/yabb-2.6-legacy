    'show_ip_admin' =>
q~Afficher l'IP dans la liste des membres en ligne de l'index du forum pour tous les membres/invités en ligne aux administrateurs?~,
    'show_ip_gmod' =>
q~Afficher l'IP dans la liste des membres en ligne de l'index du forum pour tous les membres/invités en ligne sur les modérateurs globaux?~,
    'show_ip_fmod' =>
q~Montrer l'IP dans la liste en ligne de l'index du forum pour tous les membres/invités en ligne des modérateurs du forum?~,
    'guestmedia' =>
q~Empêcher les invités de voir ldes fichiers multimédias ou d'avoir des liens auto-cliquables dans les publications?~,
    'guestlang' => q~Activer la sélection de la langue pour les invités?~,
    'checkspace' =>
q~L'activation de cette fonction vous permettra de définir les différents contrôles de l'espace disque libre. La vérification de l'espace disque libre est principalement une fonction Linux et peut ne pas fonctionner correctement sur les serveurs Windows/IIS. Les fonctions d'espace disque libre peuvent renvoyer des valeurs incorrectes lorsqu'elles sont utilisées sur des services d'hébergement partagé.~,
    'checkspace2' =>
q~(Si la page de l'utilitaire Fonction Espace disque libre ne parvient pas à se charger cela signifie que votre serveur <strong>ne supporte pas cette fonction</strong>.)~,
    'checkspclabel' =>
      q~Paramètres avancés - Fonctions de l'espace disque libre~,
    'quota' =>
q~<em>quota</em>: En activant cette fonction, vous utiliser la commande shell "quota" de Linux pour vérifier l'espace disque disponible. Il s'agit de la méthode à utiliser la plus utilisée. La case à cocher sera désactivée si cette commande n'est pas disponible sur votre serveur.<br /><span class="small">Si votre espace disque disponible est inférieur à 100 octets (100 Ko), le forum passera automatiquement en mode maintenance pour éviter de manquer d'espace et de perdre des données.<br /><strong>Rappel</strong>:seuls les administrateurs peuvent accéder au forum en mode maintenance.</span>~,
    'quota_value' =>
q~<em>quota</em>: Sélectionnez le système de fichiers sur lequel votre forum est:<br /><span class="small">Le bon système de fichiers doit être sélectionné si "quota" a été sauvegardé <em>désactivé</em>auparavant.</span>~,
    'quotahostuser' =>
q~<em>quota</em>: Votre nom d'utilisateur sur votre serveur hôte:<br /><span class="small">Doit être préenregistré. Disponible si ce qui précède est coché.</span>~,
    'findtime' =>
q~<em>find</em>: Temps entre la commande shell "find" de Linux pour vérifier la taille des fichiers dans le répertoire que vous devez insérer ci-dessous et ses sous-répertoires. Ce champ et les deux suivants seront désactivés si cette commande n'est pas disponible sur votre serveur.<br />Mettre à 0 pour pouvoir choisir une autre méthode de vérification comme "quota" ou la vérification de l'espace disque libre.<br /><span class="small">Comme ce travail peut être très long, vous devriez insérer une valeur élevée raisonnable, par exemple 300 (cinq heures) ou 1440 (un jour). Une fois que l'espace libre est obtenu du serveur après chaque "find". Cette méthode utilise beaucoups moins de ressource du serveur.</span>~,
    'findroot' =>
q~<em>find</em>: Chemin d'accès du répertoire racine de votre compte utilisateur sur un système hôte à plusieurs utilisateurs.<br /><span class="small">Le chemin doit être<strong> de la racine du système à la racine de l'utilisateur</strong>. Exemple:<br />/var/www/votre_nom_domaine/<br />/var/www/web1234/<br /><br />Vous pouvez également spécifier un chemin vers votre forum ou un répertoire dans votre forum et spécifier un Le nombre maximum d'espace en tant que limite pour cela "find" utilisera cette limite au lieu des limites de votre compte d'hôte. Exemple:<br />/var/www/votre_nom_domaine/cgi-bin/yabb2/<br />/var/www/v/your_domain_name/public_html/yabbfiles/Attachments/</span>~,
    'findmax' =>
q~<em>find</em>: Espace disponible que vous êtes autorisé à utiliser dans le répertoire ci-dessus (en mégaoctets).<br /><span class="small">Cela devrait être la même quantité de Comme vous devez définir "find" pour vérifier l'espace hôte disponible uniquement toutes les X heures ou une fois par jour, vous devez définir cette valeur plus bas que l'espace que votre hôte vous fournit, évitez de manquer d'espace en raison d'une augmentation soudaine de l'utilisation du disque, par exemple par des pièces jointes ou d'autres publications volumineuses.<br />Pour activer la recherche de l'espace hôte libre, To enable "find" for free host space checking this value must be &gt; 0. If the used space within the above directory is higher than this value, the forum will automatically go into Maintenance Mode to prevent running out of space and losing data.<br /><strong>Reminder</strong>: Only Admins can access the forum when in Maintenance Mode.<br />Just in case you don't remember: 1 GB = 1024 MB</span>~,
    'diskspacecheck' =>
q~Activer la vérification de l'espace disque libre?<br /><span class="small">Ceci vérifie l'espace disque physique disponible sur le serveur Linux ou Windows. Sachez que tout cet espace disque ne peut pas être utilisé par vous. Il peut afficher un nombre supérieur à celui autorisé par votre plan d'hébergement personnel.<br />Si votre espace disque disponible tombe en dessous de 100 000 octets (100 Ko), le forum passera automatiquement en mode maintenance pour éviter de manquer d'espace et de perdre data.<br />Rappel: seuls les administrateurs peuvent accéder au forum en mode maintenance.</span>', Mode.</span>~,
    'getreversedns' => q~Activer la recherche DNS inversée.~,
    'minlinkpost' =>
q~Nombre minimum de publications qu'un membre doit avoir avant que les liens et les images puissent être publiés~,
    'minlinkpost_exp' =>
q~Cela empêche les spammeurs de spammer directement après l'enregistrement~,
    'minlinksig' =>
q~Nombre de publications qu'un membre doit avoir avant que les liens et les images puissent être créés dans la signature~,
    'minlinksig_exp' =>
q~Cela évite que les spambots ne créent des signatures de spams directement après l'enregistrement~,
    'minlinkweb' =>
q~Nombre de publications qu'un membre doit posséder avant de pouvoir accéder à un site Web dans son profil~,
    'minlinkweb_exp' =>
q~Ceci empêche les spammeurs de se connecter à un site directement après l'enregistrement~,
    'stealth' =>
q~Activer le mode' Stealth 'pour les administrateurs et les mods globaux?<br /><span class="small">Si vous cochez cette case, les administrateurs et les mods globaux auront la possibilité de ne pas apparaître "en ligne" Groupes ou invités.<br />Il doit être activé dans le profil utilisateur CP - Profil - Coordonnées.</span>~,
    'mlview' =>
q~Sélectionnez les groupes de membres autorisés à voir la liste des membres?~,
    'buddylist' => q~Activer la liste de contacts?~,
    'regreason' =>
q~Nombre maximal de caractères autorisés dans les "Raisons pour l'enregistrement" de l'utilisateur,~,
    'showall' =>
      q~Afficher "Tous" sur les sélecteurs de page et le résumé de sujet?~,
    'imageinquote' =>
q~Si coché, les images incorporées dans les articles apparaîtront entre guillemets.<br /><span class="small">Si désactivé, les images des articles cités seront montrées comme des liens vers les images.</span>~,
    'extendedprofiles' =>
q~Utiliser les profils étendus?<br /><span class="small">Si activé, un élément supplémentaire appelé "Champs du profil" sera affiché dans la barre latérale à gauche. Là, vous pouvez ajouter des fonctions aux profils des utilisateurs.<br />Laissez cette case décochée si vous n'utilisez pas cette fonction pour sauvegarder la charge du serveur.</span>~,
    'forumnumbformat' => q~Sélectionnez le format des nombres par défaut:~,
    'nospammer' =>
q~Envoyer un courriel par défaut aux utilisateurs rejetés même si aucune raison n'est donnée lors de l'enregistrement par l'approbation de l'administrateur. Vérifiez pour 'oui~,
    'honeypot' =>
q~Activer l'attrapeur de spam robot "Honeypot Spambot catcher". Cocher "oui" (<a href="{yabb adminurl}?action=honeypot"> Modifier le Honeypot</a>)~,
    'spamfruits'   => q~Activer SpamFruits Spambot catcher. Vérifiez pour 'oui~,
    'eventcal_set' => q~Paramètres du calendrier des événements~,
    'eventcal_set1' =>
      q~Modifier les paramètres de votre calendrier d'événements~,
    'calsplit' =>
q~Nombre maximal d'anniversaires indiqué sur la page.<br /><span class="small">La page sera divisée en plusieurs affichages mensuels. Laissez vide ou mettre à 0 pour désactiver.</span>~,
    'addtab_on' => q~Afficher Ajouter et éditer des onglets sur le forum?~,
    'rules'     => q~Règles du forum~,
    'rules1'    => q~Activer les règles du forum~,
    'rules2'    => q~Titre des règles~,
    'rules3'    => q~Règles~,
    'rules4'    => q~Vous pouvez utiliser HTML ici.~,
    'iplookup' =>
q~Activer la recherche IP?<br /><span class="small">Cocher cette option transformera les adresses IP en liens actifs vous permettant de les rechercher sur un serveur Whois.</span>~,
    'iplookup_urls' =>
q~ Serveurs Whois de recherche IP:<br /><span class="small">Ici vous pouvez ajouter ou supprimer des serveurs Whois de/vers la page de recherche IP.<br />Utilisez {ip} dans l'URL pour substituer l'adresse IP réelle et séparer le titre et l'URL avec un symbole de pipe '|'.<br />Une URL par ligne. Les espaces dans le nom du site doivent être remplacés par '_'.<br />Exemple: Mon_sitelookup | Monsitelookup.com?ip={ip}</span>~,
    'iplookup_protocols' => q~Les protocoles valides sont http et https.~,
    'show_user_age' =>
      q~Afficher l'âge de l'utilisateur dans la vue des publications?~,
    'show_reg_date' =>
q~Afficher la date d'enregistrement de l'utilisateur dans la vue des publications?~,
    'edit_gender_limit' =>
q~Fixe une limite au nombre de fois que les membres peuvent éditer leur genre:<br /><span class="small">1 = Ne peut pas être édité après la première fois qu'il a été entré.<br />0 = Aucune limite.</span>~,
    'edit_age_limit' =>
q~Fixe une limite au nombre de fois que les membres peuvent modifier leur date de naissance:<br /><span class="small">1 = Ne peut pas être édité après la première fois qu'il a été entré.<br />0 = Aucune limite.</span>~,
    'min_reg_time' =>
q~Durée minimale en secondes qui doit être passée sur la page d'inscription:<br /><span class="small">C'est pour arrêter les spambots qui remplissent automatiquement le formulaire d'inscription dans un temps qui est humainement impossible.<br />Mettre à 0 pour désactiver.</span>~,
    'ipblock'  => q~Block IP dans Guardian~,
    'ipblock2' => q~Bloquer IP dans .htaccess~,
    'ipblock_confirm' =>
      q~Êtes-vous sûr de vouloir bloquer cette adresse IP? \ n \ n~,
    'ipban_confirm' =>
      q~Es-tu sûr de vouloir interdire cette adresse IP? \ n \ n~,
    'userpicml' =>
      q~Afficher l'avatar de l'utilisateur dans la liste des membres?~,
    'group_stars_ml' =>
      q~Afficher les étoiles de groupe dans la liste des membres?~,
    'default_avatar' =>
      q~Montrer un avatar par défaut si le membre n'a pas ajouté de photo?~,
    'default_userpic' =>
q~Image avatar par défaut:<br /><span class="small">Types de fichiers autorisés: png jpg jpeg gif<br />Taille du fichier maximum:250 Ko</span>~,
    'edit'   => q~Modifier~,
    'delete' => q~Supprimer~,
    'cancel' => q~Annuler~,
    'enable_guest_view_limit' =>
q~Activer la limite de vue du sujet invité?<br /><span class="small">Cochez cette option pour configurer un cookie afin de limiter le nombre de sujets que les invités peuvent consulter avant de les enregistrer. Vous pouvez définir le nombre de vues de sujet et la manière dont vous voulez qu'il se comporte ci-dessous.</span>~,
    'guest_view_limit' =>
q~Limite de la vue du sujet invité:<br /><span class="small">Définir le nombre de sujets que les invités peuvent consulter avant d'être invités à s'enregistrer.</span>~,
    'guest_view_limit_block' =>
q~Empêche les invités d'afficher les sujets après avoir atteint la limite de vue du sujet?<br /><span class="small">Cochez cette option pour empêcher les invités d'afficher d'autres sujets après que la limite de la vue du sujet a été atteint.<br />Ne pas cocher affichera un message amical en haut de l'affichage de la publication.</span>~,
    'topichover'   => q~Activer le survol des sujets sur l'index des messages~,
    'staff_reason' => q~Activer 'Motif de l'édition' pour les membres du Staff~,
    'user_reason'  => q~Activer 'Motif de l'édition' pour les membres~,
    'brdrss1'      => q~RSS~,
    'brdrss2' =>
q~Cochez cette case pour afficher le flux RSS de cette catégorie dans l'index du forum.<br /><strong>Note:</strong> Uniquement si le flux RSS est activé.~,
    'brdrss3' =>
q~Cochez cette case pour afficher le flux RSS de ce forum sur l'Index du forum.<br /><strong>Note:</strong> Uniquement pertinent si RSS est activé et si le forum n'est pas un forum de liaison externe.~,
    'actions'      => q~Actions~,
    'remove_file'  => q~Supprimer le fichier~,
    'current_img'  => q~Image actuelle~,
    'remove_img'   => q~Supprimer l'image~,
    'for_template' => q~Pour le modèle~,
    'setsettings'  => q~Paramètres envoyés~,
    'maxadminlog' =>
      q~Le nombre maximum d'entrées stockées dans le journal d'administration.~,
    'imp_email_check' =>
q~Activer la vérification améliorée des courriels?<br /><span class="small">Vérifie si le domaine de messagerie existe, si l'utilisateur est connu sur le serveur SMTP donné, si le serveur SMTP (s) sont en ligne et valide, et si la boîte aux lettres des utilisateurs est pleine. Ajoute également un deuxième champ de courriel à la page d'inscription pour vérification.<br />Notez que ce paramètre nécessite que Net :: DNS soit installé sur votre serveur.</span>~,
    'zodiac' => q~Afficher les signes du zodiaque dans le profil s'affiche?~,
    'no_imp_email_check' =>
q~<br /><span class="important"> Amélioration de la vérification des courriels non disponible. Besoins nets :: DNS</span>~,
    'error_spd' =>
q~Bannisement de vitesse ErrorLog. Nombre minimal de secondes entre plusieurs entrées du journal des erreurs provenant de la même adresse IP.<br /><span class="small">Les contrevenants sont bannis via .htaccess losqu'autorisé. Mettre à '0' pour désactiver</span>~,
    'profile_int' =>
q~Redirige les clics des invités sur les liens des noms de membres vers une page 'S'enregistrer ou se connecter'. Décochez pour désactiver les liens de nom de membre pour les invités.~,
    'ban_res' =>
q~Vous pouvez ajouter une courte raison au bannissement en utilisant le symbole "|" pour séparer l'adresse IP, l'adresse courriel, ou l'identifiant et la raison du bannissement.~,
    'p_ban'     => q~Permanent~,
    'expired'   => q~Expiré~,
    'expireon'  => q~Expire le~,
    'close_box' => q~Fermer~,
    'dupbrd' =>
q~<span class="important"> Attention: Il y a des forums dupliquées:</span>~,
    'dupbrdlnk' =>
q~<span class="important"><a href="{yabb adminurl}?action=fixboarddupes">Correction des forums dupliquées</a></span>~,
    'fixdupbrd' => q~Correction des doublons~,
    'fixduprem' => q~Dupliquer les forums enlevées~,
    'subbrd'    => q~Sous-forum~,
    'inbrd'     => q~dans le forum~,
    'incat'     => q~dans la catégorie~,
    'fixinstruct' =>
q~Sélectionnez le(s) forum(s) <strong>erroné</strong>. Vous devrez peut-être réorganiser la position des forums dans leurs catégories/forum lorsque vous aurez terminé.<br /><span class="important">Soyez très prudent avec vos sélections pour vous assurer de ne pas enlever la copie du forum que vous voulez garder.</span>~,
    'usercp' => q~PC de l'UTILISATEUR,~,
    'ppostperms' =>
q~Imprimez les autorisations de publication<br /><span class="small"> Désactivez Imprimer publication ou définissez-le sur "Tous les membres" si vous avez des problèmes de spambot avec cette fonction.</span>~,
    'ptopicperms' =>
q~Autorisations d'impression des messages<br /><span class="small">Désactivez l'option "Imprimer le message" ou définissez-la sur "Tous les membres" si vous rencontrez des problèmes de spambot avec cette fonction.</span>~,
    '813a' =>
q~Activer le champ déroulant changement de style?<br /><span class="small">Si activé, les groupes sélectionnés ont la possibilité de sélectionner et de modifier rapidement la disposition du forum, en supposant que d'autres modèles (template) ou feuilles de style CSS disponible.</span>~,
    '813b' =>
q~Sélectionnez les groupes de membres autorisés à utiliser le changement de style:</span>~,
    '10bak' => q~*.bak fichiers supprimés~,

## Paramètres de messagerie test ##
    '355b' => q~Test les paramètres du courriel du webmestre sur sauvegarde~,
    'testemail'   => q~Test Courriel~,
    'testsubject' => q~Test des paramètres de messagerie YaBB~,
    'testmessage' => q~Bonjour Webmestre {yabb mbname}

Ceci est un test des paramètres de messagerie de votre forum {yabb mbname}.

Merci d'utiliser YaBB!~,
    'mailfrom' =>
      q~"{yabb mbname} Test de messagerie" <{yabb webmaster_email}>~,
);

%detailed = (
    '429'      => q~Vérification détaillée de la version~,
    '430'      => q~Fichiers dans irepertoire Admin:~,
    '431'      => q~Fichiers dans le répertoire source:~,
    '431b'     => q~Fichiers dans les modèles Dir:~,
    'langpack' => q~Langue et fichiers d'aide~,
    'view'     => q~Afficher les fichiers {yabb fld}~,
    'hide'     => q~Cacher les fichiers {yabb fld}~,
    'modded'   => q~(Modifié)~,
    'nochng'   => q~Aucun changement~,
    'chngfle'  => q~Modifié le~,
    'upped'    => q~Téléchargé/modifié le~,
    '494'      => q~Version de l'utilisateur~,
    '495'      => q~Fichier YaBB~,
    '496'      => q~Paquet YaBB~,
    'col'      => q~Réduire~,
    'exp'      => q~Agrandir~,
);

%floodtxt = (
    '1' => q~Centre de sécurité YaBB:~,
    '2' =>
q~Activer le code de validation (CAPTCHA) lors de l'enregistrement et avoir oublié le mot de passe?~,
    '3' =>
q~Activer le code de validation (CAPTCHA) pour la publication d'un invité, diffusion de message d'un invité à l'admin, message envoyé au modérateur par un invité, Invité envoyant un sujet, Invité ajoutant un événement au Calendrier ou membre envoyant des MP sans le nombre minimum de messages?~,
    '5' =>
q~Nombre maximum de messages retournés pour les publications récentes sur le forum et/ou par l'utilisateur?<br /><span class="small">- 1 désactivera les publications récentes.</span>~,
    '5a' =>
q~Nombre maximum de messages retournés pour les sujets récents sur le forum?<br /><span class="small">- 1 désactivera les sujets récents.</span>~,
    '6' =>
q~Nombre maximum de messages retournés pour une recherche?<br /><span class="small">- 1 désactivera la recherche.</span>~,
    '7' => q~Longueur maximum du code de validation (max 15)~,
    '9' => q~Transparence de l'image de validation?~,
    'f' =>
q~Couleur du premier plan de l'image de validation (valeur hexadécimale RVB)~,
    's' => q~Couleur de l'image de validation (valeur hexadécimale RVB)~,
    'b' =>
      q~Couleur de fond de l'image de validation (valeur hexadécimale RVB)~,
    'rnd' =>
q~Sélectionnez si et comment vous voulez ajouter du bruit aléatoire à votre fond d'image de validation~,
    'style' =>
q~Sélectionnez les caractères générés dans le CAPTCHA<br /><span class="small">Gardez à l'esprit que les majuscules et les minuscules peuvent rendre le CAPTCHA plus difficile à lire.</span>~,
    'lower' => q~Minuscules + Chiffres~,
    'upper' => q~Majuscules + Chiffres~,
    'all'   => q~Majuscules et minuscules + Chiffres~,
    'masterkey' =>
q~Définir une clé de chiffrement<br /><span class="small">Une chaîne de caractères aléatoire (&gt; 8 et &lt; 24 caractères de long)</span>~,
    'rm0' => q~Aucun bruit aléatoire~,
    'rm1' => q~En utilisant seulement la couleur de l'ombre~,
    'rm2' => q~Utiliser uniquement la couleur de premier plan~,
    'rm3' => q~Utilisation de la teinte et de la couleur de premier plan~,
    'dis' =>
q~Niveau de l'assombrisage alléatoire du fond de CAPTCHA<br /><span class="small">Il est possible que le CAPTCHA devienne très difficile à lire dans certaines combinaisons de couleurs.</span>~,
    'vpreview' =>
q~Pré visualisez votre code de validation<br /><span class="small">Cochez cette case après avoir cliqué sur "Enregistrer" pour appliquer les nouveaux paramètres</span>~,
    'extra_chars_start' =>
q~Nombre de caractères supplémentaires à ajouter au début du code de validation:~,
    'extra_chars_end' =>
q~Nombre de caractères supplémentaires à ajouter à la fin du code de validation:~,
    'extra_chars_desc' =>
q~Cela ajoutera des caractères aléatoires qui n'ont pas besoin d'être saisis par l'utilisateur et tromperont les spambots.<br />par exemple. XX<br /><span class="small">0 désactive</span>~,
    'casewarning' =>
q~Veuillez entrer les caractères qui apparaissent dans l'image. Les caractères doivent être entrés dans le même ordre, et ils sont sensibles à la casse.~,
    'casewarning_1' =>
q~Veuillez entrer les caractères exactement comme ils apparaissent dans l'image,~,
    'casewarning_2' => q~<br /><span style="font-weight:bold"> sans le premier~,
    'casewarning_3' => q~<br /><span style="font-weight:bold"> sans le dernier~,
    'casewarning_4' => q~et dernier~,
    'casewarning_5' =>
q~caractères.</span><br />Les caractères doivent être entrés dans le même ordre,<br />et ils sont sensibles à la casse.~,
);

