    '342'  => q~Un mot par ligne.~,
    '347' => q~Cette page vous permet de changer tous les paramètres de votre forum YaBB. Soyez très prudent avec ces paramètres, car ils peuvent rendre votre forum YaBB non fonctionnel. Il est également possible que certains paramètres soient disponibles pour les invités ou les nouveaux membres.~,
    '348' => q~Définir le mode de maintenance?~,
    '348Text' => q~Texte "Mode de maintenance" défini par l'utilisateur<br /><span class="small">(Laissez vide pour le message par défaut)</span>~,
    '348lang' => q~Langue pour le texte "Mode de maintenance" défini par l'utilisateur<br /><span class="small">(langue de l'utilisateur courant)</span>~,
    '350'  => q~Nom du forum~,
    '350a' => q~Date de début du forum~,
