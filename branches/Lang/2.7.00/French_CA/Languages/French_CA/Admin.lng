q~Autoriser les invités à envoyer des messages personnels/d'alerte aux administrateurs?~,
    '89' =>
q~Activer le bouton "Alerter Modérateur" dans les messages?<br /><span class="small">(Envoie un message personnel aux modérateurs d'un forum avec un lien vers le message)</span>~,
    '90' =>
q~Afficher le bouton Modérateur d'alerte dans les fils de messages pour les invités?~,
    '381' =>
q~Autoriser les utilisateurs à activer la notification par courriel lors de la réception de nouveaux MPs?~,
    'pmspamchk' =>
q~Autoriser les membres ayant moins de {yabb numposts} publications à envoyer des MPs en utilisant des mesures anti-spam.~,
);

