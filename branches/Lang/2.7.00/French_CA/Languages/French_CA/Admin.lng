##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$french_caadminlngver  = 'YaBB 2.7.00 $Revision$';
@french_caadminlngmods = ();
if (@french_caadminlngmods) {
    $french_caadminlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' && $language ne 'francais' ) { return 1; }

@days   = qw(Dimanche Lundi Mardi Mercredi Jeudi Vendredi Samedi);
@months = qw(Jan Fév Mar Avr Mai Jun Jul Aug Sep Oct Nov Déc);

$abbr_lang = 'fr-ca';

%admin_txt = (
    '2' => q~dans~,
    '3' => q~Ajouter/éditer Catégories~,
    '4' => q~Garder épinglé?~,
    '5' => q~Vous devez sélectionner quelque chose à éditer ou à supprimer. Veuillez réessayer.~,
'6' => q~Envoyer un courriel aux membres~,
    '7'  => q~Éditer les nouvelles du forum~,
    '8'  => q~Éditer les groupes de membres~,
    '9'  => q~Voir tous les membres~,
    '10' => q~Sauvegarder~,
    '11' => q~Ici vous pouvez ajouter et éditer des groupes de membre.<br /><span class="small">Note: les groupes de membres sans les couleurs de texte attribuées n'apparaîtront pas dans la liste des groupes de l'index du forum.</span>~,
    '12' => q~Groupes de membres du Staff (ces groupes ne peuvent pas être supprimés)~,
    '13' => q~Groupes de modérateurs~,
    '14' => q~(Maintenez la touche Ctrl ou (touche Pomme sur Mac) enfoncée pour sélectionner ou désélectionner plusieurs entrées)~,
    '15' => q~Vous devez avoir au moins un "groupe de membres indépendant" avant de pouvoir attribuer des groupes de modérateurs.~,
    '18' => q~Modifier les identifiants de moteur de recherche~,
    '19' => q~Veuillez placer une entrée dans le moteur de recherche par ligne. Format:<br /><em>nom de domaine (partiel) e.g. googlebot </em>|<em>Nom tel qu'il apparaît à l'écran</em><br />Les moteurs ayant le même nom d'affichage seront comptés ensemble, quel que soit le nom de domaine. Si vous souhaitez que chaque domaine soit compté séparément, vous devez leur attribuer des noms d'affichage différents.~,
    '21' => q~Posts~,
    '22' => q~Autoriser les environnements permalien simple?<span class="small">Publier les messages uniquement avec un lien permanent séparé.</span>~,
    '22a' => q~Permettre les environnements premaliens Complet?<br /><span class="small">Tous les liens de accessibles aux visiteurs comme permaliens.</span>~,
    '22r' => q~Autoriser les environnements permalien RSS?<br /><span class="small">Liens vers le flux RSS comme permaliens.</span>~,
'23' => q~Domaine permalien<br /><span class="small">(incluez "http://") Note: ceci est aussi le domaine pour votre permalien RSS(ci-dessous)</span>~,
    '23a' => q~Texte permalien pour .htaccess: (Simple)~,
    '23b' => q~Texte permalien pour .htaccess: (Complet)~,
    '24'  => q~Configuration des liens permaliens~,
    '25' => q~URL du lien symbolique (omettre la barre oblique devant et après (par exemple, articles))~,
    '26' => q~Ceci est la partie de l'URL qui se trouve entre votre nom de domaine et la partie URL du lien symbolique permalien (par exemple http://www.votredomaine.com/<strong>articles/</strong>nouvelles/ceci-est-le-titre)~,
    '25r' => q~Partie du l ien symbolique de l'URL du permaliens RSSrecent (omettre la barre oblique devant et après (par exemple RSSrecent))~,
    '26r' => q~Ceci est la partie de l'URL du lien symbolique permaliens RSSrecent<br />(par exemple http://www.votredomaine.com/<strong>RSSrecent</strong>)~,
    '25b' => q~Partie du lien symbolique de l'URL du permaliens RSSboard (omettre la barre oblique devant et après (par exemple RSSboard))~,
    '26b' => q~Ceci est la partie de l'URL du lien symbolique permaliens RSSboard<br />(par exemple http://www.votredomaine.com/<strong>RSSboard</strong>)~,
    '25a' => q~Lien permanent RSS pour .htaccess:~,
    '31'  => q~Enlever~,
    '32'  => q~Aller~,
    '39'  => q~Mot de passe erroné~,
    '40'  => q~Utilisateur inexistant.~,
    '43'  => q~Ici, vous pouvez ajouter ou modifier plusieurs catégories.~,
    '44'  => q~Catégorie~,
    '45'  => q~Autorisé à voir la catégorie:~,
    '47'  => q~Ajouter des catégories~,
    '48'  => q~a été ajouté / modifié avec succès.~,
    '49'  => q~Gérer les catégories~,
