    '522' =>
q~Afficher la position actuelle dans le forum en tant que lien au lieu du texte?~,
    '523' => q~Afficher le bouton "Afficher le profil" sous chaque article?~,
    '524' => q~URL de liaison automatique?~,
    '525' =>
q~Vérifier TOUTES les majuscules?<br /><span class="small">Si mis à 0, aucune vérification n'est faite. Sinon, le nombre détermine le nombre de caractères requis pour ouvrir une alerte JavaScript lors de la soumission de la publication.</span>~,
    '526' =>
q~Afficher les outils utilisateur (QuickLinks) pour les liens de nom de membre?~,
    '530' =>
q~Reconstruire l'index des messages peut prendre beaucoup de temps dans les forums avec beaucoup de messages.<br />Voulez-vous vraiment faire cela?<br />~,
    '531' => q~Cliquez ici pour commencer maintenant.~,
    '532' => q~L'intervalle de temps du processus est réglé sur~,
    '533' => q~secondes~,
    '534' =>
q~Reconstruction de l'index des messages peut prendre beaucoup de temps dans les forums avec de nombreuse publications.<br />L'intervalle de temps ($max_process_time) est défini sur~,
    '535'  => q~La dernière étape a pris~,
    '536'  => q~Vous reconstruisez~,
    '537'  => q~minutes~,
    '538'  => q~les publications perdus ou vides ont été supprimés~,
    '539'  => q~Les publications ont été chargés et traités.~,
    '540'  => q~Les forums ont été réécrits.~,
    '540a' => q~Suppression des fichiers morts.~,
    '541'  => q~Comptage des publications dans chaque forum et finition.~,
    '542'  => q~Si rien ne se passe en 5 secondes~,
    '543'  => q~cliquez ici pour continuer~,
    '544' =>
q~Si vous voulez arrêter la reconstruction de l'index des messages <a href="javascript:stoptick();"> cliquez ici</a>.<br />Ensuite, copiez l'URL réelle et tapez-la lorsque vous vont continuer.<br />Sachez que le mode maintenance est toujours activé. Si vous l'éteignez, tout ce que la routine de reconstruction a fait se perdra.~,
    '545' =>
q~Reconstruction de l'index des messages - veuillez patienter.<br />Si vous voulez arrêter, cliquez sur (STOP) avant que le message rouge apparaisse à nouveau sur la page suivante.~,
    '579' => q~jours~,
    '584' =>
q~Afficher et exiger un accord d'enregistrement lorsque l'utilisateur s'enregistre?~,
