    '470' => q~N/A~,
    '471' => q~Smart Image Resize<br />(redimensionne l'affichage de l'image aux valeurs suivantes si l'image les dépasse)~,
    '472' => q~Largeur d'affichage de l'image avatar (0 = pas de limite)~,
    '473' => q~Hauteur de l'image de l'avatar (0 = pas de limite)~,
    '473x' => q~Désactiver la fonction Smart Image Resize pour Avatars?<br /><span class="small">Si cette case est cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement définie. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    '473a' => q~Avatar dans la largeur d'affichage de l'image de la liste des membres (0 = aucun ensemble de limites)~,
    '473b' => q~Avatar dans la hauteur d'affichage de l'image de la liste des membres (0 = aucun ensemble de limites)~,
    '473c' => q~Désactiver la fonction Smart Image Resize pour les Avatars dans la liste des membres?<br /><span class="small">Si cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement au-dessus. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    '474' => q~Afficher la largeur d'affichage de l'image (0 = pas de limite)~,
    '475' => q~Afficher la hauteur d'affichage de l'image (0 = pas de limite)~,
    '475x' => q~Désactiver la fonction Smart Image Resize (Redimensionnement intelligent d'image) dans les publications?<br /><span class="small">Si cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement définie. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    '476' => q~Largeur de l'image de la signature (0 = pas de limite)~,
    '477' => q~Hauteur d'affichage de l'image de la signature (0 = aucune limite)~,
    '477x' => q~Désactiver la fonction Redimensionner Smart Image dans Signatures?<br /><span class="small">Si cette case est cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement définie. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    '478' => q~Largeur d'affichage de l'image d'attachement (0 = pas de limite)~,
    '479' => q~Hauteur d'affichage de l'image d'attachement (0 = aucune limite)~,
    '479x' => q~Désactiver la fonction Smart Image Resize pour les pièces jointes?<br /><span class="small">Si cochée, la fonctionnalité de redimensionnement intelligent de l'image est désactivée et la taille de l'image est définie exactement aux valeurs ci-dessus. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    'brd_pic_w' => q~Largeur de l'image du forum (0=pas de limite)~,
    'brd_pic_h' => q~Hauteur de l'image du affichée forum (0=pas de limite)~,
    'brd_pic' =>
q~Désactive la fonction "Smart Image Resize" pour les images du forum?<br /><span class="small">Si cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement définie. Cela</em>peut déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    'ext_pic_w' =>
      q~Largeur d'affichage de l'image de profil étendu (0 = aucune limite)~,
    'ext_pic_h' =>
      q~Hauteur d'affichage de l'image du profil étendu (0 = aucune limite)~,
    'ext_pic' =>
q~Désactive la fonction Smart Image Resize pour les images de profil étendues? <span class="small">Si cochée, la fonction Smart Image Resize (Redimensionnement intelligent d'image) est désactivée et la taille de l'image est exactement définie au-dessus. Cela <em> peut </em> déformer les images. Si l'une des valeurs est 0, l'image est mise à l'échelle proportionnellement à l'autre valeur. Si les deux sont 0, l'image est affichée à sa taille d'origine sans aucun redimensionnement.</span>~,
    '479a' =>
q~Utilisez la "boîte grise" pour les images?<br /><span class="small">Si activé, les images dans les messages (y compris les pièces jointes) seront affichées sur une surface grise légèrement translucide si vous cliquez dessus. Pour les images de pièces jointes, vous disposez également d'une deuxième option: Afficher toutes les images jointes de cette page les unes après les autres dans une seule case et les afficher séparément.<br />Si cette option est "désactivée", les images de pièces jointes seront affichées dans une nouvelle fenêtre et les images publié incorporées sont laissées dans la zone de texte.</span>~,
    '479b' => q~Désactiver la "boîte grise"~,
    '479c' => q~Activer' boîte grise" avec une image par boîte~,
    '479d' =>
q~Activer "boîte grise" + toutes les images de pièces jointes dans une seule case~,
