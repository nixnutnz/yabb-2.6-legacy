%domain_filter_txt = (
    '1' => q~Qui peut s'inscrire ou publier en tant qu'invité~,
    '2' => q~Filtre de domaine courriel~,
    '3' =>
q~Entrez les domaines de messagerie qui seront les seuls à pouvoir être sélectionnés lors de l'enregistrement, de l'enregistrement des invités ou des changements de profil.<br />Laissez vide pour désactiver.<br />Un domaine par ligne. (Par exemple, mycompany.com)~,
    '4' => q~Domaines courriel obligatoires~,
    '5' => q~Modifier les domaines de messagerie obligatoires~,
    '6' => q~Domaines de messagerie bloqués~,
    '7' =>
q~Entrez les domaines de messagerie qui seront bloqués lors de l'inscription, de l'enregistrement des invités ou des changements de profil.<br />Laissez vide pour désactiver.<br />Un domaine par ligne. (Ex. Unwanted.com)~,
    '8' =>
q~Vous ne pouvez pas vous inscrire, publier en tant qu'invité ou changer votre adresse courriel à une adresse du domaine~,
