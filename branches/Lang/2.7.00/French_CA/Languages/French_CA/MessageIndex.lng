%messageindex_sort = (
    'sort_az'    => q~Trier (A-Z)~,
    'sort_za'    => q~Trier (Z-A)~,
    'sort_min'   => q~Trier (réponse min)~,
    'sort_max'   => q~Trier (réponse max)~,
    'sort_last'  => q~Trier (nouvelle réponse)~,
    'sort_first' => q~Trier (vielle réponse)~,
);

%messageindex_stickygrp = (
    '1' => q~Sujet important~,
    '2' => q~Forum important~,
);

%messageindex_tp = (
    'enabletp'  => q~Activer la prévisualisation de sujet~,
    'disabletp' => q~Désactiver la prévisualisation de sujet~,
    'code_tp'   => q~CODE~,
    'image_tp'  => q~IMAGE~,
