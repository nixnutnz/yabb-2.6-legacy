##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$french_camessageindexlngver  = 'YaBB 2.7.00 $Revision$';
@french_camessageindexlngmods = ();
if (@french_camessageindexlngmods) {
    $french_camessageindexlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

