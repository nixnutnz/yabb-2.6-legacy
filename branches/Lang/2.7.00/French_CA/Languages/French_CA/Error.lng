    'not_logged_in' => q~Pour effectuer cette action, vous devez être connecté. Si vous n'avez pas encore de compte, veuillez-vous enregistrer.~,
    'logged_in_already' => q~Vous êtes déjà connecté avec l'Identifiant:~,
