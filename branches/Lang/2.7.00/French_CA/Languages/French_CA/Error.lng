    'cannot_open_dir' => q~Impossible d'ouvrir le répertoire~,
    'cannot_open_language' => q~Impossible de trouver le fichier de langue requis. Veuillez informer l'administrateur de ce problème.~,
    'cannot_delete' => q~Impossible de supprimer~,
