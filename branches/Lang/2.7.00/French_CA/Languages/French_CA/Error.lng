    'im_spam_alert' => q~Vous essayez d'envoyer un message personnel à un trop grand nombre d'utilisateurs à la fois, ce qui est interprété comme du spamming possible.~,
    'im_bad_users' => q~Le (s) membre (s) suivant (s) n'a (ont) pas pu être envoyé (s).<br />Le (s) nom (s) membre (s) est (sont) invalide (s) ou ignoré (s):~,
    'cannot_find_draftmess' => q~Le brouillon du message est introuvable.~,
    'im_folder_exists'      => q~Un dossier avec ce nom existe déjà.~,

## LogInOut ##
    'not_activated' => q~Votre compte n'est pas encore activé<br />Veuillez l'activer en cliquant sur le lien dans le courriel que vous avez reçu.~,
    'time_out' => q~Vous n'avez pas activé votre compte dans les {yabb preregspan} heures.<br />Par conséquent, votre pré-inscription a été supprimée.<br />Veuillez-vous réinscrire.~,
    'wrong_code' => q~Votre code d'activation est erronée.~,
    'admin_login_only' => q~Seul l'administrateur peut se connecter pour le moment, car notre forum est en mode maintenance.<br />Veuillez réessayer plus tard Merci.~,
    'wrong_id' => q~L'identifiant que vous avez envoyé n'est pas valide. Veuillez réessayer.~,

