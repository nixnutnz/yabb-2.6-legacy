##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$french_caerrorlngver  = 'YaBB 2.7.00 $Revision$';
@french_caerrorlngmods = ();
if (@french_caerrorlngmods) {
    $french_caerrorlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%error_txt = (
## General Errors ##
    'error_occurred'  => q~Une erreur est survenue.~,
    'untrapped'       => q~Erreur non interceptée~,
    'cannot_open'     => q~Incapable d'ouvrir~,
