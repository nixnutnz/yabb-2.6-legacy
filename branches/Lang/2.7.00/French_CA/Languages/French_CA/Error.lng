    'poll_not_found' => q~Le sondage n'a pas pu être trouvé~,
    'no_vote_option' => q~Veuillez sélectionner une option pour voter avant de voter.~,
    'locked_poll_no_delete' => q~Ce sondage est verrouillé pour que votre vote ne puisse pas être supprimé~,
    'locked_poll_no_count' => q~Ce sondage est verrouillé pour que votre vote ne puisse pas être compté~,
    'ip_guest_used' => q~Un invité a déjà utilisé cette adresse IP pour enregistrer son vote~,
    'ip_member_used' => q~Un membre a déjà utilisé cette adresse IP pour enregistrer son vote~,
    'voted_already' => q~Vous avez déjà voté dans ce sondage~,
    'guest_taken' => q~L'identifiant ou l'adresse courriel donnée est déjà prise par un membre.<br />Identifiant ou adresse courriel en conflit:~,
    'quote_too_long' => q~Le texte que vous avez essayé de citer est trop long, merci de le raccourcir.~,
    'no_links_allowed' => q~Désolé, vous n'êtes pas autorisé à publier des messages contenant des liens actifs vers des sites ou des images avant que vous ayez posté des messages {yabb minlinkpost} normaux.~,
