    'no_name'  => q~Le champ Nom n'a pas été remplis, il est obligatoire.~,
    'no_ip'    => q~Adresse IP introuvable~,
    'no_username' =>q~Le champ "User ID" n'a pas été remplis, il est obligatoire.~,
    'no_password'       => q~Le champ Mot de passe est vide~,
    'no_action'         => q~Aucune action spécifiée.~,
    'no_info'           => q~Aucune information spécifiée dans l'URL~,
    'password_mismatch' => q~Les mots de passe ne sont pas identiques.~,
    'bad_credentials' => q~Identifiant/Mot de passe ne correspondent pas.<br />L'Identifiant que vous avez spécifié n'existe pas ou vous avez entré un mot de passe incorrect.~,
    'invalid_character' => q~Il y a un caractère non valide détecté dans le~,
    'invalid_email' => q~S'il vous plaît, veuillez entrer une adresse courriel valide.~,
    'invalid_picture'  => q~Saisie d'image de forum erronéee.~,
    'no_secret_answer' => q~Vous devez entrer une réponse à la question posée.~,
    'no_verification_code' => q~Le code de vérification n'a pas été rempli, il est obligatoire.~,
    'wrong_verification_code' => q~Le code de vérification n'est pas le même que l'image présentée à l'écran, revenez en arrière, actualisez (appuyez sur F5 sur la plupart des navigateurs) et réessayez.~,
    'invalid_verification_code' => q~Le code de vérification contient des caractères non valides, seuls les caractères a-z et 0-9 sont valides~,
    'form_spoofing' => q~<strong>ALERTE</strong>Contrefaçon de formulaire détecté provenant de l'adresse IP:~,
    'post_flooding' => q~La dernière requête POST de votre adresse IP était inférieure à~,
    'denial_of_service' => q~La dernière requête POST a créé un message d'erreur:~,
    'speed_alert' => q~Publier trop rapidement est considéré comme du spam.<br />Vous êtes autorisé à seulement<strong>{yabb spam_hits_left_count}</strong> tentatives supplémentaires, après quoi vous serez banni en tant que spammeur.~,

    'tsc_alert' => q~L'un des champs de formulaire contient du texte considéré comme spam.<br />Vous n'êtes autorisé à <strong>{yabb spam_hits_left_count}</strong> plus de tentatives après lesquelles vous serez banni en tant que spammeur.~,
    'speedpostban' => q~Vous êtes actuellement banni de la publication en raison d'un possible spam.<br />Après <strong>{yabb detention_left}</strong> seconde(s) votre interdiction sera automatiquement levée.~,
    'truncation_error' => q~Assurez-vous que la "fausse troncation" est activée dans votre fichier Settings.pm.<br />\$faketruncation = 1;<br />Impossible de tronquer le fichier~,
    'referer_violation' => q~Cette action n'est pas autorisée depuis un domaine extérieur.<br />L'action est:~,
    'egg' => q~Séquence d'autodestruction commencée!<br />~,
    'domain_not_allowed' => q~Vous ne pouvez pas vous inscrire, publier en tant qu'invité ou changer votre adresse courriel à une adresse du domaine~,
    'module_missing' => q~Module (s) ou fonctionnalité (s) nécessaire (s) sur ce serveur.~,
    'low_diskspace' => q~Le disque / hostspace disponible est bas Le forum a été mis en maintenance pour éviter la corruption de fichiers Veuillez informer l'administrateur de cette erreur.~,
    'invalid_key' => q~La clé principale est invalide.<br />Cela devrait être une chaîne de texte entre 8 et 24 caractères.~,
    'wrong_pass' => q~Le mot de passe que vous avez entré est incorrect~,
    'corrupt_member_file' => q~Le fichier de données du membre est corrompu. Veuillez informer l'administrateur de cette erreur.~,
    'no_admin_passwrd' => q~Vous devez entrer le mot de passe administrateur correct pour entrer dans le Centre d'administration.~,
    'default_password' => qq~ Vous utilisez toujours le mot de passe par défaut de YaBB. Veuillez-vous connecter à votre <a href="$scripturl?action=myprofile;username=$username;sid=$mysid"> profil utilisateur</a> et changer votre mot de passe pour quelque chose de plus sécuritaire.~,
    'missingvars' => q~Quelque chose de mal est arrivé. Veuillez informer l'administrateur de ce forum de ce que vous étiez en train de faire lorsque cette erreur s'est produite.~,

## BoardIndex ##
    'collapse_no_member' => q~Vous devez être membre pour utiliser les catégories réductibles / extensibles.~,
    'collapse_invalid_state' => q~L'état que vous avez spécifié n'était pas valide. Veuillez revenir en arrière et réessayer~,
    'collapse_no_usercat' => q~Fichier de catégorie d'utilisateur introuvable - essayez d'actualiser l'index du forum (à l'époque F5). \ n Si vous recevez à nouveau ce message, veuillez en informer un administrateur.~,

## Guardian ##
    'proxy_reason'   => q~L'accès par proxy à ce forum est refusé.~,
    'referer_reason' => q~L'accès au forum depuis l'URL actuelle est interdit.~,
    'harvester_reason' => q~Cet intercepteur se voit refuser l'accès au forum.~,
    'request_reason' => q~La méthode de requête que vous avez essayé d'utiliser n'est pas autorisée ici.~,
    'string_reason' => q~Votre URL contient des mots non autorisés ici.~,
    'clike_reason' => q~Il est inutile d'essayer CLIKE de pirater ce site car il ne fonctionne pas MySQL.~,
    'union_reason' => q~Il est inutile d'essayer UNION de pirater ce site car il ne fonctionne pas MySQL.~,
    'script_reason' => q~Vous avez essayé d'utiliser des scripts dans l'URL ou l'entrée de formulaire, ce qui n'est pas autorisé.~,

## InstantMessage ##
    'im_deleted' => q~Le message a déjà été lu par le destinataire, il n'a donc pas été rappelé.~,
    'im_deleted_multi' => q~Au moins un des destinataires a déjà lu le message, donc aucun message n'a été rappelé.~,
    'im_members_only' => q~La messagerie personnelle est réservée aux membres~,
