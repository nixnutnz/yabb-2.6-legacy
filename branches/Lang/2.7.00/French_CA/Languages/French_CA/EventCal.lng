### Event Calendar YaBBC ###

%var_calpost = (
    'getaddevent' => q~Ajouter un nouvel événement~,
    'event_send'  => q~Ajouter événement~,
);

### Event Calendar Settings ###

%event_cal = (
    '1' => q~Paramètres du calendrier des événements~,
    '3' => q~Afficher le calendrier des événements à:~,
    '4' => q~Afficher bouton Calendrier des événements sur le menu YaBB à:~,
    '5' => q~Afficher les anniversaires dans le calendrier/événements à:~,
    '6' => q~Déterminer la longueur des caractères de chaque événement (s)?~,
    '7' => q~Affiche un lien "LIRE PLUS" vers l'évènement affiché<br />(0 = désactivé)~,
    '8' => q~Mettre en évidence la date du jour avec cette couleur dans le mini calendrier~,
    '9'  => q~Activer la fonction "Défilement d'événement"~,
    '10' => q~Très utile si vous avez beaucoup d'événements.~,
    '11' => q~Désactivé~,
    '12' => q~Défilement automatique~,
    '13' => q~Défilement manuel~,
    '14' => q~Sélectionnez les groupes de membres autorisés à ajouter/modifier des événements:~,
    '15' => q~NE RIEN sélectionner permet à tous les groupes, utilisateurs et invités d'ajouter/modifier des événements.<br /><br />{yabb admin_txt14}~,
    '16' => q~Permettre à ces membres d'ajouter des événements~,
    '17' => q~Lister plusieurs membres en tant que "pseudonyme1, pseudonyme2".~,
    '18' => q~Autoriser les membres à ajouter des "Événements privés"?~,
    '19' => q~Si cette option n'est pas cochée, seuls les modérateurs globaux et les administrateurs pourront ajouter des "événements privés"~,
    '20' => q~Activer "afficher événement" (défilement événement) sur l'index du forum?~,
    '21' => q~Paramètres standard~,
    '22' => q~Paramètres de l'événement~,
    '23' => q~Paramètres d'accès~,
    '24' => q~Afficher la boîte de sélection "Désactiver le pseudonyme" à:~,
    '26' => q~Paramètres de l'icône calendrier des événements~,
    '27' => q~Sélectionnez une image~,
    '28' => q~Description~,
    '29' => q~Image~,
    '30' => q~Ajouter un nouvel icônes d'événements ici~,
    '31' => q~Enregistrer les paramètres du calendrier des événements~,
    '32' => q~Enregistrer les paramètres de l'icône d'événement~,
    '33' => q~Cette section vous permet de personnaliser vos événements de calendrier en utilisant vos propres icônes d'événements.<br />Les images semblent meilleures lorsqu'elle ne dépassant pas 25x25px.<br />Types de fichiers autorisés: png jpg jpeg gif<br />Taille max. du fichier:100KB~,
    '34' => q~Liste des événements à venir pour __ jours à côté du calendrier des événements~,
    '35'  => q~(0 = Tous les événements du mois en cours)~,
    '36'  => q~Premier jour de la semaine (mini calendrier)?~,
    '37'  => q~(non coché = Lundi / coché = Dimanche)~,
    '42'  => q~Afficher la liste des anniversaires de membre à:~,
    '42a' => q~Afficher les signes zodiaque dans la liste d'anniversaire?~,
    '43'  => q~Ne Pas afficher les icônes d'événement dans le mini calendrier?~,
    '44'  => q~Appliquer les couleurs du groupe lors de l'affichage des liens membres?~,
    '44a' => q~Appliquer les couleurs du groupe lors de l'affichage des liens membres dans la liste d'anniversaire?~,
    '45' => q~Cocher cette option utilisera plus de ressources de forum.~,
    '48' => q~Afficher le bouton "Liste des anniversaires" dans le menu YaBB à:~,
    '49' => q~Paramètres de la liste d'anniversaire~,
    '50' => q~Afficher les dates de naissance à:~,
    '52' => q~Supprimer les anciens événements<br /><span class="small">Cochez cette case pour supprimer les événements antérieurs à la date actuelle lors de l'ajout d'un nouvel événement.</span>~,
    '54' => q~Reconstruire la liste des anniversaires~,
    '56' => q~Texte défilant~,
    '57' => q~XHTML~,
    '58' => q~Désactiver les balises YaBBC dans le texte de prévisualisation?~,
    '59' => q~Ajouter une icône d'événement~,
    '60' => q~Supprimer l'icône d'événement~,
    'error_image' => q~Veuillez sélectionner une image pour l'icône d'événement.~,
    'error_desc' => q~Veuillez entrer une description de l'icône d'événement.~,
    'del'        => q~Supprimer les anciens événements~,
    'showtoday' => q~Utilisez "Aujourd'hui", "Hier" et "Demain" dans les affichages d'événements et d'anniversaires.~,
    'new' => q~Si activé, "Afficher anniversaire" ou "Voir la liste des anniversaires des membres" vous devrez exécuter "Reconstruire la liste des membres" ci-dessous.~,
);

