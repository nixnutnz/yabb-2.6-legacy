our $VERSION = '2.7.00';
$french_caeventcallngbase = 1938;
##  Based on English Rev 1938 ##

$french_caeventcallngver  = 'YaBB 2.7.00 $Revision$';
@french_caeventcallngmods = ();
if (@french_caeventcallngmods) {
    $french_caeventcallngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

