'404' => q~eMails versenden mit~,
'407' => q~SMTP-Server<br /><span class="small">Für Net::SMTP::TLS oder Net::SMTPS, spezifiziert die Portkennzeichnung mit einer ":&lt;Portnummer&gt;" am Ende. Beispiel: <em>smtp.gmail.com:587</em></span>~,
