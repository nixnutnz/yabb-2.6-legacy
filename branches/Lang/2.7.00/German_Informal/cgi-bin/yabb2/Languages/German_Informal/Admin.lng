%floodtxt = (
'1' => q~YaBB-Sicherheitszentrum:~,
'2' => q~Validierungscode auf die Bereiche Registrierung, Passwort vergessen, und Thema versenden aktivieren?~,
'3' => q~Validierungscode im Gast Posting, Gast Nachricht an Moderator und PN an Administrator aktivieren?~,
'5' => q~Maximale Anzahl Nachrichten, die auf der Startseite als "neueste Beiträge" bzw. im Profil eines Benutzers abgefragt werden können?<br /><span class="small"> -1 schaltet die Funktion ab.</span>~,
'5a' => q~Maximale Anzahl Nachrichten, die auf der Startseite als "neueste Themen" abgefragt werden können?<br /> <span class="small"> -1 schaltet die Funktion ab.</span>~,
'6' => q~Maximale Nachrichten, die bei der Suche angezeigt werden?<br /> <span class="small"> -1 schaltet die Suche ab.</span>~,
'7' => q~Länge des Validierungscodes (maximal 15)~,
'9' => q~Transparenter Bildhintergrund des Codes~,
'f' => q~Bildvordergrundfarbe des Validierungscodes (RGB Hex Werte)~,
's' => q~Bildschattenfarbe des Validierungscodes (RGB Hex Werte)~,
'b' => q~Bildhintergrundfarbe des Validierungscodes (RGB Hex Werte)~,
