'extrastore' => q~Aktiviert zusätzlichen Archiv Ordner<br /><span class="small">(Ein-/Ausgang sind Standardwert für alle, 0 = Deaktivert, Erhöhung um maximal 25)</span>~,
'NewNotificationAlert' => q~Infos über neue Foren- und Themenbenachrichtigungen oben auf jeder Seite einblenden, und die Verwendung eines Popup für diese neuen Benachrichtigungen auf der Übersicht-Seite erlauben (entsprechend der individuellen Einstellung des Mitglieds)?~,
'enable_PMsearch' => q~Mitgliedern erlauben, ihre PN nach Betreff zu durchsuchen<br /><span class="small">(0 = Aus / 5 - 50 Wert zum Anzeigen der maximalen Ergebnisse setzen)</span>~,
'enablePM' => q~Private Nachrichtenübermittlung aktivieren für~,
'87' => q~Broadcast-Nachrichtenübermittlung aktivieren für~,
'88' => q~Gästen das Senden von Privat-Nachrichten zum Administrator erlauben?~,
'89' => q~'Moderator melden'-Button im Thema aktivieren?<br /><span class="small">(Sendet eine Privat Nachricht an die Moderatoren eines Forums)</span>~,
'90' => q~'Moderator melden'-Button für Gäste anzeigen?~,
'381' => q~Eine eMail-Benachrichtigung beim Eingang neuer PN erlauben?~,
'pmspamchk' => qq~Erlaube Mitgliedern mit weniger als {yabb numposts} Beiträgen, PN mit Anti-Spam-Maßnahmen zu senden.~,
);

