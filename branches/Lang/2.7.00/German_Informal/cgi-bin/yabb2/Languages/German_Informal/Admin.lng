'style' => q~Wähle, welche Zeichen im CAPTCHA erzeugt werden<br /><span class="small">Beachte, dass bei Groß- und Kleinbuchstaben die CAPTCHA\'s schwieriger zu lesen sind</span>~,
'lower' => q~Kleinbuchstaben + Ziffern~,
'upper' => q~Großbuchstaben + Ziffern~,
'all' => q~Groß- und Kleinbuchstaben + Ziffern~,
'masterkey' => q~Einen Masterkey für die Verschlüsselung setzen<br /><span class="small">Eine Zufallstextfolge (> 8 und < 24 Zeichen lang)</span>~,
'rm0' => q~Kein Hintergrund Störung~,
'rm1' => q~Nur die Schattenfarbe benutzen~,
'rm2' => q~Nur die Vordergrundfarbe benutzen~,
'rm3' => q~Schattenfarbe und Vordergrundfarbe benutzen~,
'dis' => q~Die Stärke der CAPTCHA Hintergrundverzerrung festlegen.<br /><span class="small">Die Lesbarkeit der Captcha Grafik wird dadurch bei Verwendung bestimmter Farbkombinationen erheblich erschwert.</span>~,
'vpreview' => q~Vorschau Deines Validierungscodes<br /><span class="small">Überprüfe dies, nachdem neue Einstellungen gespeichert sind</span>~,
'extra_chars_start' => q~Füge zusätzliche Zeichen zum Anfang des Validierungscode´s hinzu:~,
'extra_chars_end' => q~Füge zusätzliche Zeichen zum Ende des Validierungscode´s hinzu:~,
'extra_chars_desc' => q~Dies fügt Zeichen hinzu, die nicht vom Benutzer eingegeben werden müssen, wird aber Spambots täuschen.<br />e.g. XX~,
'casewarning' => q~Bitte gebe die Zeichen ein, die im Bild erscheinen. Die Zeichen müssen in der gleichen Reihenfolge eingegeben werden, wobei zwischen Groß- und Kleinschreibung unterschieden wird.~,
'casewarning_1' => q~Bitte gebe die Zeichen genau so ein, wie sie im Bild erscheinen,~,
'casewarning_2' => q~<br /><span style="font-weight: bold;">außer dem ersten Zeichen~,
'casewarning_3' => q~<br /><span style="font-weight: bold;">außer dem letzten Zeichen~,
'casewarning_4' => q~und letztes~,
'casewarning_5' => q~Zeichen.</span><br />Die Zeichen müssen in der gleichen Reihenfolge eingegeben werden,<br />und es wird zwischen Groß- und Kleinschreibung unterschieden.~,
);

