'470' => q~N/A~,
'471' => q~Bildgrößenanpassung<br />(Bilder werden mit den nachfolgend festgelegten Werten im Größenformat angepasst, sofern die Bildgröße die unten festgelegten Werte überschreitet)~,
'472' => q~Maximale Breite für Benutzerbilder (Avatare) (0 = ohne Limit)~,
'473' => q~Maximale Höhe für Benutzerbilder (Avatare) (0 = ohne Limit)~,
'473x' => q~Deaktivieren der Bildgrößenanpassung für Avatare?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'473a' => q~Maximale Breite für Benutzerbilder (Avatare) in der Mitgliederliste (0 = ohne Limit)~,
'473b' => q~Maximale Höhe für Benutzerbilder (Avatare) in der Mitgliederliste (0 = ohne Limit)~,
'473c' => q~Deaktivieren der Bildgrößenanpassung für Avatare in Mitgliederliste?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'474' => q~Maximale Breite für Bilder in Beiträgen (0 = ohne Limit)~,
'475' => q~Maximale Höhe für Bilder in Beiträgen (0 = ohne Limit)~,
'475x' => q~Deaktivieren der Bildgrößenanpassung in Beiträgen?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'476' => q~Maximale Breite für Bilder in Signaturen (0 = ohne Limit)~,
'477' => q~Maximale Höhe für Bilder in Signaturen (0 = ohne Limit)~,
'477x' => q~Deaktivieren der Bildgrößenanpassung in Signaturen?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'478' => q~Maximale Breite für Bilder bei vorhandenen Anhängen (0 = ohne Limit)~,
'479' => q~Maximale Höhe für Bilder bei vorhandenen Anhängen (0 = ohne Limit)~,
'479x' => q~Deaktivieren der Bildgrößenanpassung für Anhänge?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'brd_pic_w' => q~Maximale Breite für Bilder im Boardbild (0 = ohne Limit)~,
'brd_pic_h' => q~Maximale Höhe für Bilder im Boardbild (0 = ohne Limit)~,
'brd_pic' => q~Deaktivieren der Bildgrößenanpassung für Boardbilder?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'ext_pic_w' => q~Erweiterte Profilbildanzeigebreite (0 = ohne Limit)~,
'ext_pic_h' => q~Erweiterte Profilbildanzeigehöhe (0 = ohne Limit)~,
'ext_pic' => q~Deaktiviere die Bildgrößenanpassung für die erweiterte Profilbildanzeige?<br /><span class="small">Wenn aktiviert, wird die Bildgrößenanpassung deaktiviert und die Bildgröße exakt auf die oben genannten Werte gesetzt. Dies <em>kann</em> zu Bildverzerrungen führen. Wenn einer der oben genannten Werte auf 0 gesetzt ist, wird das Bild in den originalen Proportionen des anderen Wertes angezeigt. Sind beide Werte auf 0 gesetzt, wird das Bild in seiner Originalgröße, ohne Anpassungen, angezeigt.</span>~,
'479a' => q~"Greybox" für Bilder nutzen?<br /><span class="small">Wenn aktiviert, werden Bilder in Dateianhängen oder Beiträgen in einer leicht gräulich transparenten Oberfläche dargestellt, wenn sie angeklickt werden. Für Bilder in Dateianhängen steht eine zweite Option zur Verfügung: Anzeige aller Bilder in Dateianhängen von dieser Seite nacheinander in einer Box.<br />Wenn deaktiviert, werden die Bilder aus Dateianhängen in einem neuen Fenster und Bilder innerhalb von Beiträgen an der linken Seite des Textbereiches angezeigt.</span>~,
'479b' => q~"Greybox" deaktivieren~,
'479c' => q~"Greybox" für ein Bild in jeder Box aktivieren~,
'479d' => q~"Greybox" für alle Bilder in einer Box (Anhänge) aktivieren~,
