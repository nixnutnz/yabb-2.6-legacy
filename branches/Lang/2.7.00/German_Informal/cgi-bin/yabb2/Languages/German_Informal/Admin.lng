%modulecheck = (
'1' => q~Modulcheck~,
'2' => q~Überprüft, ob alle von YaBB verwendeten Module installiert bzw. vorhanden sind.~,
'3' => q~Name des Moduls~,
'4' => q~Info~,
'5' => q~Vom System gelieferte Information:~,
'6' => q~Installiert~,
'7' => q~Einige Module sind auf Deinen Server nicht installiert.~,
'8' => q~<b>Sollte eine Modulinstallation unbedingt erforderlich sein (Info lesen),<br /> frage bitte zunächst Deinen Internet-Service-Provider (ISP), ob er für Dich die benötigten Module installiert.<br /><br />Wenn Du Deinen eigenen Server verwendest oder Dein ISP die benötigten Module nicht für Dich installiert,<br />schaue in <a href="http://www.yabbforum.com/cgi-bin/codex/YaBB.pl?num=1225217016" target="_blank"><b>dieses Thema im <em>YaBB Codex</em> für weitere Hilfe</b></a>.</b>~,
'Digest::MD5' => q~Genutzt für die Passwort-Verschlüsselung.<br />Dieses Modul ist von wesentlicher Bedeutung und unbedingt für die Nutzung eines YaBB-Forum erforderlich.~,
'Time::HiRes' => q~Genutzt für die Benchmark-Zeit, wenn der Debug-Modus aktiviert ist.<br />Ist dieses Modul nicht installiert, wird die Benchmark-Zeit nicht in vollen und hochauflösenden Sekunden angezeigt.~,
'Time::Local' => q~Genutzt zur Umwandlung von Zeitzeichenketten in Zeitstempel.<br />Ist dieses Modul nicht installiert, wird die Benchmark-Zeit nicht in vollen und hochauflösenden Sekunden angezeigt.~,
'File::Find' => q~Genutzt zum Hochladen für Avatare und Dateianhänge.<br />Ist dieses Modul nicht installiert, die Funktion aber aktiviert, wirst Du eine Fehlermeldung erhalten, sobald Du versuchst, etwas hochzuladen.~,
'CGI' => q~Genutzt zum Hochladen für Avatare und Dateianhänge.<br />Ist dieses Modul nicht installiert, dass Feature aber aktiviert, wirst Du eine Fehlermeldung erhalten sobald Du versuchst, etwas hochzuladen.~,
'CGI2' => q~<strong>Ihre Version</strong>:~,
'Net::SMTP' => q~Genutzt zum eMail-Versand über SMTP.<br />Dieses Modul ist nur erforderlich, wenn Du Deine eMails über Net::SMTP versenden willst.~,
'Net::SMTPS' => q~Genutzt zum eMail-Versand über SMTPS.<br />Dieses Modul ist nur erforderlich, wenn Du Deine eMails über Net::SMTPS versenden willst (in der Regel, wenn Du einen externen Mailserver wie Google Mail verwenden mußt). Wenn Du Deine eMails nicht über Net::SMTPS versenden willst, benötigst Du dieses Modul nicht.~,
'Compress::Zlib' => q~Wird für die Backup-Funktion und die Browser-Komprimierung verwendet.<br />Dieses Modul wird nur benötigt, wenn Du keine anderen Backup-Methoden zur Verfügung hast(siehe <a href="{yabb adminurl}?action=backup">Backup-Funktion</a> für Details) und/oder wenn Du "GZip-Kompression verwenden" aktivieren möchtest. Ansonsten brauchst Du dieses Modul nicht.~,
'Compress::Bzip2' => q~Wird für die Backup-Funktion verwendet.<br />Dieses Modul wird nur benötigt, wenn Du keine anderen Backup-Methoden zur Verfügung hast (siehe <a href="{yabb adminurl}?action=backup">Backup-Funktion</a> für Details). Ansonsten brauchst Du dieses Modul nicht.~,
'Archive::Tar' => q~Wird für die Backup-Funktion verwendet.<br />Dieses Modul ist nur erforderlich, wenn keine andere Backup Methode zur Verfügung steht (siehe <a href="{yabb adminurl}?action=backup">Backup-Funktion</a> für weitere Details). Ansonsten brauchst Du dieses Modul nicht.~, 
'Archive::Zip' => q~Wird für die Backup-Funktion verwendet.<br />Dieses Modul ist nur erforderlich, wenn keine andere Backup Methode zur Verfügung steht (siehe <a href="{yabb adminurl}?action=backup">Backup-Funktion</a> für weitere Details). Ansonsten brauchst Du dieses Modul nicht.~,
'MIME::Lite' => q~Genutzt zum Versenden von Backups per eMail.<br />Dieses Modul ist nur erforderlich, wenn Du ein Backup per eMail erhalten möchtest und nicht den direkten Download über das Admin-Center willst. Ansonsten brauchst Du dieses Modul nicht.~,
'IO::Socket::INET' => q~Genutzt zum eMail-Versand über die "YaBB SMTP Engine".<br />Dieses Modul ist nur erforderlich, wenn Du eMails über die YaBB SMTP Engine versenden willst.~,
'Digest::HMAC_MD5' => q~Genutzt zum eMail-Versand über die "YaBB SMTP Engine".<br />Dieses Modul ist nur erforderlich, wenn Du eMails die YaBB SMTP Engine versenden willst.~,
'Carp' => q~Genutzt zum eMail-Versand über die "YaBB SMTP Engine".<br />Dieses Modul ist nur erforderlich, wenn Du eMails die YaBB SMTP Engine versenden willst.~,
'bytes' => q~Genutzt zum eMail-Versand über die "YaBB SMTP Engine".<br />Dieses Modul ist nur erforderlich, wenn Du eMails die YaBB SMTP Engine versenden willst.~,
'integer' => q~Genutzt zum eMail-Versand über die "YaBB SMTP Engine".<br />Dieses Modul ist nur erforderlich, wenn Du eMails die YaBB SMTP Engine versenden willst.~,
'DateTime' => q~Benötigt von DateTime::TimeZone.<br />Dieses Modul wird benötigt, wenn Du Foren / Mitglieder - Zeitzonen auf etwas anderes als UTC setzen möchtest.~,
'DateTime::TimeZone' => q~Wird verwendet, um Benutzer- und Forumzeitzone auszugleichen auf Basis der tatsächlichen Zeitzone des Benutzers.<br />Dieses Modul wird benötigt, wenn Forum und Mitglieder eine andere Zeitzone als UTC haben wollen/sollen.<br /><span class="important">Dieses Modul muss aktuell gehalten werden, da es zeitkritische Daten der Zeitzonen enthält.~,
'DateTime::TimeZone2' => q~<br /><span class="important">Dieses Modul muss aktuell gehalten werden, da es zeitkritische Daten der Zeitzonen enthält. Prüfe dies mit Deinem Server-Betreiber, um dies sicherzustellen.</span><br /><b>Deine Version</b>:~,
'URI::Escape' => q~Wird von der Post / Nachrichtenvorschau-Funktion verwendet.<br />Dieses Modul ist erforderlich. Ohne diesem Modul wird die Vorschau-Funktion nicht funktionieren.~,
'perlver' => q~Deine Perl Version~,
'Net::DNS' => q~Benutzt von der verbesserten eMail-Prüfung. Wenn dieses Modul nicht installiert ist, kannst Du die verbesserte eMail-Prüfung nicht nutzen.~,
'Mail::CheckUser' => q~Benutzt von der verbesserten eMail-Prüfung. Dieses Modul wird von YaBB installiert.~,
'Module::Load' => q~Benötigt für erweitertes Backup.<br />Dieses Modul ist notwendig. Ohne diesem Modul funktionieren die Backupmethoden nicht.~,
'server' => q~Dein Server~,
'LWP::Simple' => q~Benötigt für YaBMod.<br />Wenn dieses Modul nicht installiert ist, kannst Du YaBMod nicht verwenden. Ansonsten benötigst Du dieses Modul nicht.~,
'noserver' => q~Keine Serverinformation verfügbar.~,
'mod_access_compat' => q~Kein Modzugriff~,
);

