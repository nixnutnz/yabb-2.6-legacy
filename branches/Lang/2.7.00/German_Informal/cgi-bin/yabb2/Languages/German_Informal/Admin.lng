'show_ip_admin' => q~Dem Administrator IP-Adressen aller Benutzer in der Onlineliste im Forenindex anzeigen?~,
'show_ip_gmod' => q~Den Global-Moderatoren IP-Adressen aller Benutzer in der Onlineliste im Forenindex anzeigen?~,
