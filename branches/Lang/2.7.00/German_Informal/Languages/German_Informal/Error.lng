    'no_email'    => q~Das eMailfeld ist nicht wie erforderlich ausgefüllt.~,
    'no_name'     => q~Das Namensfeld wurde nicht wie erforderlich ausgefüllt.~,
    'no_ip'       => q~IP wurde nicht gefunden~,
