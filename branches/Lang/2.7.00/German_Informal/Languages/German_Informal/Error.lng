##  Based on English Rev 1920 ##
our $VERSION = '2.7.00';

no warnings;
$german_informalerrorlngver  = 'YaBB 2.7.00 $Revision$';
@german_informalerrorlngmods = ();
if (@german_informalerrorlngmods) {
    $german_informalerrorlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%error_txt = (
## General Errors ##
    'error_occurred'  => q~Ein Fehler ist aufgetreten!~,
    'untrapped'       => q~Nicht abgefangene Fehler~,
    'cannot_open'     => q~Kann nicht geöffnet werden:~,
