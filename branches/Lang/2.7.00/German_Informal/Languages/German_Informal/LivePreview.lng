our $VERSION = '2.7.00';
$german_informallivepreviewlngbase = 1938;
##  Based on English Rev 1938 ##

$german_informallivepreviewlngver  = 'YaBB 2.7.00 $Revision$';
@german_informallivepreviewlngmods = ();
if (@german_informallivepreviewlngmods) {
    $german_informallivepreviewlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%livepreview_txt = (
    'info_missing' => q~Fehlende oder falsche Information:~,
    'name_empty'   => q~Das Namensfeld ist nicht ausgefüllt.~,
    'long_name'    => q~Bitte kürze Deinen Namen, er ist zu lang~,
    'mail_empty'   => q~Das eMail-Feld ist nicht ausgefüllt.~,
    'valid_mail'   => q~Bitte gebe eine gültige eMail-Adresse ein.~,
    'veri_code'    => q~Das Verifizierungs-Feld ist nicht ausgefüllt.~,
    'veri_quest'   => q~Die Verifizierungs-Frage ist nicht ausgfüllt~,
    'subj_empty'   => q~Das Betreff-Feld ist nicht ausgefüllt.~,
    'mess_empty'   => q~Das Nachrichtentext-Feld ist leer.~,
    'subj_allcaps' =>
q~Es scheint, dass Du versuchst, zu viel Großbuchstaben in das Feld Betreff zu schreiben. Dies ist gegen die Forenregeln.~,
    'mess_allcaps' =>
q~Es scheint, dass Du versuchst, zu viel Großbuchstaben in das Feld Nachrichtentext zu schreiben. Dies ist gegen die Forenregeln.~,
    'pm_recipient' => q~Du mußt das Empfänger-Feld ausfüllen!~,
    'no_links' =>
q~Du bist nicht berechtigt, Links zu setzen, bevor Du nicht mindestens {yabb minlinkpost} Beiträge hast.~,
);

1;
