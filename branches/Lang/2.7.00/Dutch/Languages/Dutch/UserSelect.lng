##  Based on English Rev 1848 ##
our $VERSION = '2.7.00';

$dutchuserselectlngver  = 'YaBB 2.7.00 $Revision: 1848 $';
@dutchuserselectlngmods = ();
if (@dutchuserselectlngmods) {
    $dutchuserselectlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%usersel_txt = (
    'addselected' => q~Voeg selectie toe~,
    'instruct' =>
q~Dubbelklik op een naam of selecteer een of meer namen in de lijst en klik op de "Voeg selectie toe" button om toe te voegen aan de~,
    'instruct0' =>
q~Typ de eerste tekens van de nieuwe moderator in het bovenste formulierveld, dubbelklik vervolgens op de naam of selecteer een of meer namen in de lijst en klik op de "Voeg selectie toe" button om toe te voegen aan de~,
    'instruct1' =>
q~Dubbelklik op een naam of selecteer een naam in de lijst en klik op de "Voeg selectie toe" button om toe te voegen aan de~,
    'instruct2' => q~Zoek lid op naam of email:~,
    'instruct3' =>
q~In het bovenste zoekvak  kunt u een jokerteken gebruiken (alleen een *) in uw zoekreeks.~,
    'instruct4'       => q~Selecteer Leden Groepen~,
    'wildcardinfo'    => q~Gebruik * voor jokerteken~,
    'searchresult'    => q~Zoek Resultaat:~,
    'nofound'         => q~Sorry - geen resultaten gevonden voor~,
    'pmpagetitle'     => q~Selecteer PM geadresseerden~,
    'grouppagetitle'  => q~Selecter BC Geadresseerden Groepen~,
    'modpagetitle'    => q~Selecteer Moderatoren~,
    'buddypagetitle'  => q~Selecteer uw vrienden~,
    'ignorepagetitle' => q~Selecteer leden om te negeren~,
    'searchpagetitle' => q~Selecteer lid om naar te zoeken~,
    'pageclose'       => q~Sluiten~,
    'recentlist'      => q~Recente Lijst~,
    'alllist'         => q~Leden Lijst~,
    'gobutton'        => q~Ga~,
    'reciepientlist'  => q~Lijst met geadresseerden~,
    'moderatorlist'   => q~Moderator Lijst~,
    'buddylist'       => q~Vrienden Lijst~,
    'groups'          => q~Leden Groepen~,
    'ignorelist'      => q~PM Negeer lijst~,
    'searchlist'      => q~Zoek met de Gebruikersveld~,
    'pmto'            => q~Naar~,
    'pmcc'            => q~Cc~,
    'pmbcc'           => q~Bcc~,
    'allsearch'       => q~Allen~,
    'bmallmembers'    => q~Alle forum leden~,
    'bmadmins'        => q~Beheerders~,
    'bmgmods'         => q~Global moderatoren~,
    'bmfmods'         => q~Forum moderatoren~,
    'bmmods'          => q~Alle board moderatoren / mod groepen~,
    'pages'           => q~Pagina's~,
    'of'              => q~van~,
    'noentries'       => q~Er zijn geen gegevens beschikbaar voor deze brief.~,
    'other'           => q~Ander~,
    'noresults'       => q~Geen Resultaten~,
    'qsearch'         => q~Zoek Leden~,
    'illegal'         => q~Invalid character~,
);

1;
