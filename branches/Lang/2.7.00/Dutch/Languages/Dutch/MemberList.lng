    '87'  => q~Positie~,
    '96'  => q~Website~,
    '139' => q~Pagina's~,
    '233' => q~Registratie datum~,
    '234' => q~Reg. Datum~,
    '307' => q~e-mail~,
    '308' => q~verborgen E-mail adres~,
    '309' => q~van~,
    '312' => q~Toon leden geordend op alfabet~,
    '313' => q~Bekijk de~,
    '314' => q~Leden geordend naar het aantal bijdragen~,
    '331' => q~Leden~,
