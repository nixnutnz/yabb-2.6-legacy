our $VERSION = '2.7.00';

$dutchmemberlistlngver  = 'YaBB 2.7.00 $Revision: 1933 $';
@dutchmemberlistlngmods = ();
if (@dutchmemberlistlngmods) {
    $dutchmemberlistlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

