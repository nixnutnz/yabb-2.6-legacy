    '136'      => q~Board Notificatie~,
    '137'      => q~Wijzig of verwijder de notificatie op dit board.~,
    '138'      => q~Wijzig~,
    '139'      => q~Er zijn geen boards met notificatie op actief.~,
    '140'      => q~Topic~,
    '144'      => q~Selecteer allen~,
    '145'      => q~Nieuwe persoonlijke boodschap van~,
    '200'      => q~U hebt~,
    '201'      => q~nieuw~,
    '202'      => q~en~,
    '203'      => q~Wilt u uw notificaties bekijken?~,
