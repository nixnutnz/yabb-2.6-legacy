our $VERSION = '2.7.00';
##  Based on English Rev 1938 ##
$dutchnotifylngbase = 1938;

$dutchnotifylngver  = 'YaBB 2.7.00 $Revision$';
@dutchnotifylngmods = ();
if (@dutchnotfylngmods) {
    $dutchnotifylngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%notify_txt = (
    '118' => q~Topic Notificatie~,
    '119' => q~Er zijn geen onderwerpen voor notificatie gemarkeerd.~,
