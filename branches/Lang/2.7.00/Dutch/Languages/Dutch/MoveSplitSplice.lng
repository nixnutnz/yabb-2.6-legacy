    '28' => q~&raquo;&raquo; Categoriën &laquo;&laquo;~,
    '29' => q~&raquo;&raquo; Boards &laquo;&laquo;~,
    '30' => q~&raquo;&raquo; Nieuwe Topic &laquo;&laquo;~,
    '31' => q~&raquo;&raquo; Topic Einde &laquo;&laquo;~,
    '32' => q~&raquo;&raquo; Topic Begin &laquo;&laquo;~,

    '40' => q~Reageer~,
    '41' => q~Topic Start~,

    '50' =>
q~Ga terug en herlaad deze pagina eerst, of u bent niet in staat uit te voeren.~,
