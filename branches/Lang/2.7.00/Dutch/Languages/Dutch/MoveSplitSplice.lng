our $VERSION = '2.7.00';

$dutchmovesplitsplicelngver  = 'YaBB 2.7.00 $Revision: 1848 $';
@dutchmovesplitsplicelngmods = ();
if (@dutchmovesplitsplicelngmods) {
    $dutchmovesplitsplicelngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%sstxt = (
    '1'  => q~Verplaatsen, splitsen &amp; verbinden~,
    '2'  => q~Bijdrage Splitsen~,
    '3'  => q~Bijdrage~,
    '4'  => q~Behouden~,
    '5'  => q~Verbinden met~,
    '6'  => q~Categorie~,
    '7'  => q~Board~,
    '8'  => q~Topic~,
    '9'  => q~Titel nieuwe Topic invoeren~,
    '10' => q~Positie~,
    '11' => q~'Verplaatst/Verbonden met...' Info~,
    '12' => q~Ooorspronkelijke bijdrage behouden~,
    '13' => q~Geen indicatie~,
    '14' =>
      q~Selecteer hier welke berichten verplaatst of verbonden moeten worden:~,
    '14a' =>
q~Houdt de toets SHIFT of CTRL ingedrukt terwijl u klikt om meerdere berichten te selecteren.~,
    '15' =>
q~Kies wat er in plaats van de bijdrage achtergelaten moet worden.<br />Als u wilt verplaatsen &raquo;&raquo; Alle Bijdragen &laquo;&laquo;, wordt in ieder geval een notitie achtergelaten.~,
    '15a' =>
q~Een nieuwe Bijdrage achter de verplaatste bijdrage, bevat de info van waar ze kwamen en wie hen verplaatste.~,
    '16' =>
q~Selecteer naar welke categorie de geselecteerde bijdrage verplaatst moeten worden.~,
    '17' =>
q~Selecteer naar welk board de geselecteerde bijdrage verplaatst moeten worden.~,
    '18' =>
q~Selecteer naar welke Topic de geselecteerde bijdragen verplaatst moeten worden.~,
    '19' =>
q~Selecteer de positie, om de geselecteerde bijdrage te verbinden.<br />De Bijdragen worden geplaatst onder de aangegeven positie.~,
    '20' =>
q~Voer het onderwerp van de nieuwe topic hier in.<br />Laat dit vak leeg als u het onderwerp wilt gebruiken van de eerste geselecteerde bijdrage.~,
    '21'  => q~Re:~,
    '22'  => q~U moet een categorie aanwijzen.~,
    '22a' => q~U moet minstens een board aanwijzen.~,
    '22b' => q~U moet minstens een~,
    '23'  => q~Bijdrage uitkiezen om te kunnen verplaatsen.~,
    '24'  => q~Uitvoeren~,
    '25'  => q~Terugzetten~,
    '26'  => q~&raquo;&raquo; Alle Bijdragen &laquo;&laquo;~,
    '27' =>
