our $VERSION = '2.7.00';

$dutchegisterlngver   = 'YaBB 2.7.00 $Revision$';
@dutchregisterlngmods = ();
if (@dutchregisterlngmods) {
    $dutchregisterlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

