our $VERSION = '2.7.00';

$dutcheventcallngver  = 'YaBB 2.7.00 $Revision: 1888 $';
@dutcheventcallngmods = ();
if (@dutcheventcallngmods) {
    $dutcheventcallngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

