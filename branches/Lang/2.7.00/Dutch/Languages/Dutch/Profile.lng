    '581'  => q~http://www.youtube.com/~,
    '592'  => q~Uw persoonlijk avatar url of fotonaam.~,
    '598' =>
q~Dit moet worden toegevoegd indien u hieronder een url adres heeft opgegeven.~,
    '599' => q~Dit moet een compleet url adres zijn.~,
    '600' => q~Dit is uw ICQ nummer.~,
    '601' => q~Dit is uw AOL instant messenger alias.~,
    '602' => q~Dit is uw Yahoo! instant messenger alias.~,
    '603' => q~AIM~,
    '604' => q~YIM~,
    '606' =>
q~Handtekeningen worden aan de onderkant van iedere post of Persoonlijk bericht getoond. YaBBC code kan gebruikt worden (ex: <b>[img]http:&thinsp;//&thinsp;www.mypage.com&thinsp;/&thinsp;mypic.gif[/img]</b>) om een afbeelding in uw handtekning te tonen.~
    , # gebruik &thinsp; (kleine ruimte) of uw layout kan verknald zijn in IE en lage beeldscherm resolutie
    '638' =>
q~U heeft uw e-mail adres verandert. U zult een nieuw wachtwoord per e-mail ontvangen.~,
    '664'  => q~Max {yabb max_siglen} characters. nog resterend: ~,
    '664a' => q~Max {yabb max_awaylen} characters. nog resterend: ~,
    '679'  => q~Het e-mailadres moet geldig zijn.~,
    '681' =>
q~Informeer de administrator van dit forum alsjeblieft dat de \$facesdir instellingen gecorrigeerd moeten worden.~,
    '686' => q~online~,
    '687' => q~offline~,
    '688' => q~Klik om een persoonlijke boodschap te sturen naar~,
    '698' =>
q~Dit is uw profiel. U kunt buiten de 'verplichte gegevens' informatie invullen welke u wilt. Deze informatie wordt op diverse plekken binnen {yabb mbname} getoond.~,
    '700' => q~Welkom op~,
    '701' =>
q~U kunt hen na inloggen in uw profiel veranderen of indien u bent ingelogd deze link volgen:~,
    '721' => q~Verberg e-mailadres voor andere gebruikers/gasten?~,
    '722' => q~verborgen~,
    '733' => q~Uw wachtwoord is gewijzigd. Het is nu~,
    '734' => q~en uw gebruikersnaam is~,
    '755' => q~Deze gebruiker heeft 0 berichten.~,
    '757' =>
      q~Uw gebruikerstekst is te lang! Deze moet minder dan 51 tekens zijn.~,
    '775' => q~Wilt u werkelijk~,
    '776' => q~Uw Profiel~,
    '777' => q~de gebruiker~,
    '778' => q~van het forum verwijderen?~,
    '810' =>
q~Wilt u dat de antwoorden in de Topic in een andere volgorde weergeven worden?~,
    '811' =>
q~Als geselecteerd, wordt de meest recente antwoord op het onderwerp op de eerste pagina aan de bovenkant getoond.  Als het selectievakje is uitgeschakeld, wordt de oudste post het eerste, en de nieuwste post het laatste weergegeven.<br /><b>Notitie:</b> U kunt deze optie wijzigen door op de naam van de topic te klikken op de topicpagina.~,
    '814' => q~Welke template wilt u gebruiken?~,
    '815' => q~(Als er meer dan een beschikbaar is)~,
    '817' => q~Welke taal wilt u graag in de menu's gebruiken?~,
    '818' => q~Opties~,
    '819' => q~Contact Informatie~,
    '820' => q~Admin instellingen~,
    '821' => q~Huidig Wachtwoord:~,
    '823' => q~MSN~,
    '824' => q~Dit is uw MSN Instant Messenger adres.~,
    '825' => q~Google Talk~,
    '826' => q~Dit is uw Google Talk adres.~,
    '827' => q~Skype/VoIP~,
    '828' => q~Dit is uw Skype of VoIP adres.~,
    '888' => q~U heeft uw huidige wachtwoord niet ingevuld.~,
    '889' => q~Klik om een e-mail te sturen naar~,
    '890' =>
q~U heeft een gecensureerd woord gebruikt in uw schermnaam. Dit is niet toegestaan. Ga terug en verander uw naam a.u.b.. Het woord, of woorden die het probleem veroorzaakt zijn:~,
    '891' =>
q~De naam die u heeft gekozen is al in gebruik door een ander lid. Ga Alstublieft terug en kies een andere schermnaam.~,
    '892' => q~% van alle forum berichten~,
    '893' => q~Posts per dag~,
    '894' => q~Dagen sinds registratie~,
    '895' =>
      q~Om de informatie op te slaan moet u uw huidige wachtwoord invoeren~,
    '896' => q~Vul dit alleen in als u uw wachtwoord wilt wijzigen~,
    '897' =>
q~Uw profielsessie is afgelopen.\nGeen wijzigingen zijn opgeslagen.\nNa een hernieuwde verificatie wordt u doorgestuurd naar de vorige pagina.~
    ,    # inside JS. Don't use " inside!
    '898' => q~Profiel Sessie afgelopen.~,
    '899' => q~Maak alstublieft nieuwe verificatie~,
    '900' => q~Bevestig wachtwoord~,
    '901' => q~Bevestig uw wachtwoord a.u.b~,
    '902' => q~Gebruikersnaam~,
    '903' => q~Verbanning van de gebruikersnaam opheffen~,
    '903a' =>
q~Bent u zeker dat u de verbanning van deze gebruikersnaam wilt opheffen?\n\n~,
    '904' => q~Verbanning van dit e-mail opheffen~,
    '904a' =>
q~Bent u zeker dat u de verbanning van dit e-mail adres wilt opheffen?\n\n~,
    '905' => q~Verbanning van dit IP adres opheffen~,
    '905a' =>
      q~Bent u zeker dat u de verbanning van dit IP adres wilt opheffen?\n\n~,
    '906'  => q~Ban deze gebruikersnaam~,
    '906a' => q~Bent u zeker dat u deze gebuikersnaam wilt bannen?\n\n~,
    '907'  => q~Ban dit e-mail adres~,
    '907a' => q~Bent u zeker dat u dit e-mail adres wilt bannen?\n\n~,
    '908'  => q~Ban dit IP adres~,
    '908a' => q~Bent u zeker dat u dit IP adres wilt bannen?\n\n~,
    '909'  => q~Laatste IP adres~,
    '910'  => q~Word lid van ledengroep~,
    '910a' =>
q~Hier kunt u uzelf toevoegen aan een extra leden groep(en). Houdt Shift of Ctrl ingedrukt (Apple op de Mac) en klik om meer groepen te selecteren (indien beschikbaar).~,
    'ignorelistadd' =>
q~Klik hier om gebruikers te selecteren of toe te voegen aan de Negeerlijst~,
    'ignoreall' => q~Vink deze optie aan om alle Privéberichten te negeren~,
    'ignoreexplain' =>
q~Als u geen PBs wenst te ontvangen van iemand of alle andere forumleden(i.e. negeer), ofwel hun lid namen wilt toevoegen aan de box met behulp van de link, of de box selecteren om alle PM.s te blokkeren.<br /><b>Notitie:</b> Dit zal geen PB\'s of Broadcast-berichten blokkeren die door de forum Admin of Gmod naar u verzonden zijn.~,
    'showingemail' => q~Uw e-mail adres is zichtbaar.~,
    'notshowingemail' =>
      q~Uw e-mail adres is verborgen voor alle leden behalve~,
    'notshowingemailend' => q~.~,
    'showstatus'         => q~Als ik offline ben, toon mijn status als~,
    'statusexplain' =>
      q~Staat u toe als 'Afwezig' of 'Offline' gezien te worden~,
    'onlinealert' => q~Post en Bord kennisgeving~,
    'onlinealertexplain' =>
q~Als deze optie is ingeschakeld, krijgt u een extra melding via een pop-upvenster dat u nieuwe forums hebt of post meldingen heeft.~,
    'stealth' => q~Sta me toe in Stealth Mode te werken~,
    'stealthexplain' =>
q~Gebruik dit om in het geheim in te loggen. Uw schermnaam zal niet getoond worden in de "Online" lijst, en uw status in Profiel and berichten pagina's zal getoond worden als "Offline" (Notitie:  Status zal getoond worden als "Afwezig" als u de afwezig mogelijkheid hebt ingesteld).~,
    'viewmess' =>
q~Berichten tekst weergeven in een overzicht van de persoonlijke berichten?~,
    'viewmessexplain' =>
q~Inschakelen eerste regel van de tekst van het bericht bekijken in lijstweergaven. Uitschakelen om alleen zender/ontvanger en datum enz te bekijken.~,
    'view'     => q~Ga naar~,
    'asubj'    => q~Afwezig onderwerp:~,
    'amess'    => q~Afwezig bericht:~,
    'awaydesc' => q~To send an automatic 'Away' reply PM to other Members: ~,
    'awaydescription' =>
q~Wanneer u een automatisch 'Afwezigheid' bericht als antwoord op een PB wilt sturen, kunt u hier de tekst daarvoor invoegen. Elk lid zal dit eenmalig ontvangen, wanneer u (alleen) pb krijgt wanneer u afwezig bent,<br />Om uit te schakelen, laat dit dan leeg.~,
    'isbuddy'        => q~in mijn vrienden Lijst.~,
    'sid_expires_1'  => q~Uw profiel-sessie verloopt in~,
    'sid_expires_2'  => q~seconden.~,
    'sid_expires_3'  => q~seconde.~,
    'sid_expires_4'  => q~minuut en~,
    'sid_expires_5'  => q~minuten en~,
    'usernumbformat' => q~Selecteer uw getalnotatie~,
    'capslock'       => q~Caps lock is geactiveerd.~,
    'wrong_char'     => q~Dit teken in het wachtwoord is ongeldig~,
    'day'            => q~Dag~,
    'week'           => q~Week~,
    'month'          => q~Maand~,
    'perm'           => q~Permanent~,
    'd'              => q~Dag~,
    'w'              => q~Week~,
    'm'              => q~Maand~,
    'p'              => q~Permanent~,
    'regdate'        => q~Geregistreerd sinds: ~,
    'gender_edit_1' =>
q~Denk er om, dat u uw geslachtkenmerk niet kunt bewerken nadat deze reeds is ingevoerd.~,
    'gender_edit_2' =>
      q~Denk er om, dat u alleen uw eigen geslachtkenmerk kunt bewerken~,
    'gender_edit_3' => q~Uw geslachtkenmerk kan niet verandert worden.~,
    'dob_edit_1' =>
q~Denk er om, dat u uw geboorte-datum niet kan veranderen nadat deze is ingevoerd.~,
    'dob_edit_2' =>
      q~Denk er om, dat u alleen uw eigen geboorte-datum kunt bewerken~,
    'dob_edit_3'      => q~meer tijd.~,
    'dob_edit_4'      => q~meer tijden.~,
    'dob_edit_5'      => q~tijd.~,
    'dob_edit_6'      => q~tijden.~,
    'dob_edit_7'      => q~Uw geboorte-datum kan niet vernadert worden.~,
    'pass_reminder_1' => q~wachtwoord herinnering~,
    'pass_reminder_2' => q~Zend~,
    'pass_reminder_3' =>
      q~Weet u zeker dat u een wachtwoord herinnering wil verzenden naar~,
    'ban_page'   => q~Verbod op~,
    'ban_enter'  => q~Verbod~,
    'ban_cancel' => q~Annuleren~,
    'ban_reason' =>
      q~Reden voor het verbod op <span class="small">(Optioneel)</span>~,
    'email_ban' => q~Email gebruiker met betrekking tot verbod~,
    'ban_for'   => q~voor een~,
    'fntsze' =>
q~Grootte van je basis te geven lettertype<br /><span class="small">(Voor berichten, IM, en Gebeurtenissen)</span>~,
);

