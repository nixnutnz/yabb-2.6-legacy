    '232' => q~Afbeelding/Tekst~,
    '233' => q~Registratiedatum~,
    '234' => q~Reden voor registratie~,
    '238' => q~Mannelijk~,
    '239' => q~Vrouwelijk~,
    '241' =>
q~Veld. Geldige tekens zijn Letters(A-Z,a-z), Nummers (0-9), Spaties en ( _ ! @ # $ % ^ & * ( ) + | ` \~ - = \ : ; ' " , . / ? [ ] { } )~,
    '241re' =>
q~Veld. Geldige tekens zijn Letters, Nummers, Spaties en ( [ ] # % + , - | . : = ? @ ^ _ )~,
    '241e' =>
q~Veld. Geldige tekens zijn Letters (A-Z,a-z), Nummers (0-9), en ( + - . @ _ )~,
    '244' =>
q~De gebruiker die u probeert te registeren bevat een gereserveerde naam. Probeer alstublieft een andere naam. Gereserveerde naam is: ~,
    '245' => q~Registratie succesvol~,
    '323' => q~Instellingen~,
    '325' => q~Negeer Lijst~,
    '326' => q~Meldt mij nieuwe notificaties per e-mail~,
    '327' => q~Meldt mij nieuwe PB\'s per e-mail~,
    '371' => q~TijdZone~,
    '372' =>
q~<span class="small">Kies het gebied en de stad wat uw gewenste tijdzone presenteert.</span>~,
    '372a' => q~Gebruik Forum Tijdverschil~,
    '373'  => q~Momenteel weergegeven lokale tijd~,
    '420'  => q~Leeftijd~,
    '422'  => q~(geen afbeelding)~,
    '458'  => q~Nieuwste bijdrag van~,
    '459'  => q~Aanvullende Informatie~,
    '460'  => q~Toon de laatste~,
    '461'  => q~posts gemaakt door~,
    '462'  => q~GA!~,
    '470'  => q~Niet beschikbaar~,
    '473' =>
q~Als u een andere afbeelding upload, kan het gebeuren dat de dezelfde afbeelding als ervóór wordt getoond. In dat geval herlaad deze pagina of doe een rechter muisklik op de afbeelding en selecteer herlaad de afbeelding.~,
    '474' =>
      q~- Selecteer een afbeelding naam in de lijst aan de rechterkant.<br />~,
    '475' =>
q~- Of voeg de web URL in naar uw eigen afbeelding.<br />De web URL naar uw eigen afbeelding moet in de volgende form zijn:<br /><i>http:&thinsp;//&thinsp;www.mypage.com&thinsp;/&thinsp;mypic.gif</i><br />Uw afbeelding moet zijn in <i>.gif</i>, <i>.png</i>, <i>.jpg</i> or <i>.jpeg</i> formaat.~
    , # gebruik &thinsp; (kleine ruimte) of uw layout kan verknald zijn in IE en lage beeldscherm resolutie
    '476' =>
q~- Of selecteer een afbeeldingsbestand om te uploaden naar onze server.<br />TDe afbeelding moet de volgende format hebben: <i>.gif</i>, <i>.png</i>, <i>.jpg</i> or <i>.jpeg</i><br />De maximum toegestane bestandsgrootte is:~,
    '477' => q~<b>Opmerking: Uw beelden kunnen worden aangepast.</b>~,
    '479' =>
q~De selectie verandert het formaat van de datum en tijd in het hele Forum.~,
    '480a' =>
      q~Ik gebruik mijn eigen tijd en datum notatie (stel hier onder in)~,
    '480'  => q~01/31/01 bij 13:15:17~,
    '481'  => q~31.01.01 bij 13:15:17~,
