    '79'            => q~Profiel bewerken~,
    'editmyprofile' => q~Mijn Profiel bewerken~,
    '80' =>
q~<div class="message" style="background-color:white; padding:3px; overflow:auto; color:red; font-weight:bold;">Gefeliciteerd, uw wachtwoord is gereset. Voor uw account veiligheid, kies alstublieft in de volgende 10 minuten nieuw wachtwoord en update deze profiel pagina.</div>~,
    '81'  => q~Nieuw Wachtwoord~,
