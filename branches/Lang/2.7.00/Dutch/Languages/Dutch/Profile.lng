    '486a' => q~of Eigen tijd formaat~,
    '513'  => q~ICQ~,
    '519'  => q~Automatisch Zomer/Winter verandering aktiveren?~,
    '520'  => q~Dynamische klok aan de bovenkant van de pagina inschakelen?~,
    '521'  => q~Niet beschikbaar als u uw eigen tijd formaat schreef.~,
    '563'  => q~Geboortedatum~,
    '563a' => q~Verberg leeftijd en geboorte jaar?~,
