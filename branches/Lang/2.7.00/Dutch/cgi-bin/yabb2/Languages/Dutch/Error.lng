$dutcherrorlngver = 'YaBB 2.7.00 $Revision$';

@dutcherrorlngmods = ();
if (@dutcherrorlngmods) {
    $dutcherrorlngmods = 1;
}
$action ||= q{};
if ( $action eq 'detailedversion' ) { return 1; }

%error_txt = (
## General Errors ##
'error_occurred'       => q~Er is een fout opgetreden.~,
'untrapped'            => q~Onverklaarbare fout~,
'bad_data'             => q~File with bad data~,
'cannot_open'          => q~Kan niet geopend worden~,
'cannot_open_dir'      => q~Kan map niet openen~,
'cannot_open_language' => q~Kan het gevraagde taalbestand niet vinden. Informeer alstublieft de Admin over dit probleem.~,
'cannot_delete'        => q~Niet in staat om te verwijderen~,
