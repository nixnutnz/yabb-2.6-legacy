'no_email'             => q~Het e-mail veld was niet ingevuld. Dit is verplicht.~,
'no_name'              => q~Het gebruikersnaam veld is niet ongevuld. Dit is verplicht.~,
'no_ip'                => qq~IP niet gevonden~,
'no_username'          => q~Het Gebruiker ID veld is niet ingevuld. Dit is verplich.~,
'no_password'          => q~Het wachtwoord veld is leeg~,
'no_action'            => q~Geen actie gespecificeerd.~,
'no_info'              => q~Geen info gespecificeerd in de url~,
'password_mismatch'    => q~Wachtwoorden zijn niet hetzelfde.~,
'bad_credentials'      => q~Gebruikersnaam  / Wachtwoord komen niet overeen. <br />Of de gebruikersnaam die u specificeerde bestaat niet of u voerde een verkeerd wachtwoord in.~,
'invalid_character'    => q~Er is een ongeldig leesteken gevonden in de~,
'invalid_email'        => q~Vul alstublieft een geldig e-mail adres in.~,
'invalid_picture'      => q~Ongeldige invoer Board Afbeelding.~,
'no_secret_answer'     => q~U moet een antwoord invullen op de vraag die gesteld is~,
'no_verification_code' => q~De verificatie code is niet ingevuld. Dit is verplicht.~,
'wrong_verification_code'    => q~De verificatie code is niet gelijk aan die in de afbeelding op uw scherm, ga a.u.b. terug, ververs (druk op F5 bij de meeste browsers) en probeer het opnieuw.~,
'invalid_verification_code'  => q~De verificatie code bevat ongeldige leestekens. Alleen a-z en 0-9 zijn geldig~,
'form_spoofing'        => q~<b>ALARM!!</b> Form Spoofing Gedetecteerd! Misbruik komt van IP adres:~,
'post_flooding'        => q~De laatste POST aanvraag vanaf uw IP was minder dan~,
'denial_of_service'    => q~De laatste POST-aanvraag creëerde een foutbericht: ~,
'speed_alert'          => qq~Als u zo snel Post wordt dat gezien als Spam, u bent gewaarschuwd!<br />Het is u alleen toegestaan <b>{yabb spam_hits_left_count}</b> meer poging(en) waarna u geband zult worden als spammer.~,
'tsc_alert'            => qq~Een van de velden bevat tekst die wordt aangemerkt als SPAM.<br />Het is u alleen toegestaan <b>{yabb spam_hits_left_count}</b> meer poging(en) waarna u geband zult worden als spammer.~,
'speedpostban'         => qq~U bent momenteel geband van het forum voor mogelijk Spammen.<br />Na <b>{yabb detention_left}</b> second(en) zal de ban automatisch worden opgeheven.~,
'truncation_error'     => qq~Zorg ervoor dat u in uw Settings.pm 'fake truncation' ingeschakeld hebt.<br />\$faketruncation = 1;<br />Could not truncate file~,
'referer_violation'    => q~Deze aktie is niet toegestaan vanaf een ander domein. <br />Actie is: ~,
'egg'                  => q~Zelfvernietigings sequentie begonnen!<br />~,
'domain_not_allowed'   => q~U kunt zich niet registreren, als gast Posten of uw e-mailadres veranderen naar een van het domein~,
'module_missing'       => q~Module(s) of funtionaliteit die benodigd is, is niet geinstalleerd op deze server.~,
'low_diskspace'        => q~De beschikbare disc/hostruimte is laag. Het forum is in onderhoudsmodus gezet om beschadiging van bestanden te voorkomen. Waarschuw de admin over deze foutmelding.~,
'invalid_key'          => q~Masterkey is ongeldig.<br />Dit zou een tekststring moeten zijn tussen de 8 en 24 tekens lang.~,
'wrong_pass'            => q~Het wachtwoord dat u invoerde is niet correct~,
'corrupt_member_file'  => q~Het lid data-bestand is beschadigd. Waarschuw alstublieft de Admin over deze fout.~,
'no_admin_passwrd'    => q~U moet het juiste administrator wachtwoord invoeren om in het Admin center te komen.~,
'default_password'    => qq~U gebruikt nog steeds het Yabb Setup standaard wachtwoord. Log alstublieft in, in uw <a href="{yabb scripturl}?action=myprofile;username=$username">Gebruikers profiel</a> en verander uw wachtwoord in een die veiliger is.~,
'missingvars'         => q~Iets slechts is er gebeurd. Informeer alstublieft de Admin van dit forum over wat u aan het doen was toen deze fout verscheen.~,

## BoardIndex ##
'collapse_no_member'   => q~Alleen leden kunnen categorieën in- en uitvouwen.~,
'collapse_invalid_state'    => q~De status die u heeft opgegeven is ongeldig. Ga terug en probeer het opnieuw~,
