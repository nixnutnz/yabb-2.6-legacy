$dutchadmin_admin09_indexhelpver = 'YaBB 2.7.00 $Revision: 1888 $';
if ( $action eq 'detailedversion' ) { return 1; }
$section_name = "Help_Topic_Index";

### Section 1
#############################################
$section_sub1 = "Help_Topic_Index_Intro";
$section_body1 = qq~<p>De Help topic index kan u helpen uw YaBB functies snel te leren en u te helpen met het vinden van hulp topic’s in de YaBB Codex.</p>
~;
#############################################

### Section 2
#############################################
$section_sub2 = "Hoe_naar_Topics";
$section_body2 = qq~<p>Deze beantwoorden veel gestelde vragen door de nieuwe forum Administratoren over hoe de online functies gebruikt moeten worden.</p>
<p><b>Hoe......</b></p>
<ul>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217217800" target="_blank">Een nieuw board toe te voegen</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217217419" target="_blank">Een nieuwe Categorie toe tevoegen</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217294882" target="_blank">Een Moderator aan te maken</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217400265" target="_blank">Een Global Moderator aan te maken</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217819051" target="_blank">Een nieuwe post-afhankelijk Leden Groep aan te maken</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1218345096" target="_blank">Een nieuwe post-onafhankelijk Leden Groep aan te maken</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217819515" target="_blank">Verplaats ik een gebruiker naar een andere post-afhankelijk Leden Groep</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1218429222" target="_blank">Verplaats ik een gebruiker naar een andere post-onafhankelijk Leden Groep</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217261075" target="_blank">Schakel de zoek functie uit</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217258547" target="_blank">Gebruik de registratie opties</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1218776684" target="_blank">Verander het Forum Logo</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?num=1217706934" target="_blank">Gebruik uw eigen afbeelding als een Avatar</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?board=templates" target="_blank">Werk ik met Templates</a></li>
    <li><a href="http://www.yabbforum.com/codex/YaBB.pl?board=templates" target="_blank">Verander de kleuren in Grey Box functies</a></li>
</ul>
~;
